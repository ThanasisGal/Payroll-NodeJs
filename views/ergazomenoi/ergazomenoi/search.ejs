<%
    const anenerghValue = typeof anenergh !== 'undefined' ? anenergh : '';
    const showInactiveValue = typeof showInactive !== 'undefined' ? showInactive : false;
    const anenerghChecked = anenerghValue === 'on' || anenerghValue === true || showInactiveValue === true;
    const anenerghQuery = anenerghChecked ? '&anenergh=on' : '';
    const anenerghQueryFirst = anenerghChecked ? '?anenergh=on' : '';

    const formatInactiveDate = (value) => {
        if (!value) return '';

        if (typeof value === 'string') {
            const isoMatch = value.match(/^(\d{4})-(\d{2})-(\d{2})/);
            if (isoMatch) return `${isoMatch[3]}/${isoMatch[2]}/${isoMatch[1]}`;
        }

        const d = new Date(value);
        if (Number.isNaN(d.getTime())) return '';

        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear();

        return `${day}/${month}/${year}`;
    };
%>

<style nonce="<%= nonce %>">
    #anenergh.form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }

    tr.ergazomenos-anenergos > td {
        color: #b02a37 !important;
        font-weight: 600;
        background-color: #f8d7da !important;
    }

    .ergazomenoi-toggle-wrap {
        min-width: 11rem;
    }
</style>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-5 mb-3 border-bottom bg-hero-cdn">
    <div class="d-flex align-items-center gap-3 ms-auto flex-wrap justify-content-end">
        <div class="form-check form-switch mb-0 ergazomenoi-toggle-wrap">
            <input
                class="form-check-input"
                type="checkbox"
                role="switch"
                id="anenergh"
                name="anenergh"
                value="on"
                <%= anenerghChecked ? 'checked' : '' %> />
            <label class="form-check-label fw600" for="anenergh">
                Ανενεργοί: <span id="anenerghLabel"><%= anenerghChecked ? 'ΝΑΙ' : 'ΟΧΙ' %></span>
            </label>
        </div>

        <form class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0">
            <%- include('../../partials/_csrfField') %>
        </form>
    </div>
</div>

<div class="card d-flex flex-column z-depth-5 w-99 margin-left-0_5rem overflow-hidden">
    <div class="card-header p-0 height-rem-3_5">
        <label class="text-center w-100 headers-content mt-2">
            Εμφάνιση Εργαζομένων ( με κριτήριο αναζήτησης "<%= sTerm %>" )
            <% if (anenerghChecked) { %>
                <span class="badge bg-danger ms-2">Εμφάνιση και ανενεργών</span>
            <% } %>
        </label>
    </div>

    <div>
        <table class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
            <thead class="backgroundColor-brown font-size-rem-1_1 center-align">
                <tr class="color-brown">
                    <th scope="col" class="color-brown col-1">Κωδ.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-3-5">Επώνυμο<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-2">Όνομα<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-2">Πατρώνυμο<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-1">Α.Φ.Μ.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-1-5">Α.M.K.A.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-1">Α.Δ.Τ.<i class="sort-icon bi"></i></th>
                </tr>
            </thead>
        </table>
    </div>

    <div class="card-body p-0 overflow-auto flex-grow-1 height-vh-61 bg-white">
        <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
            <tbody>
                <% if (ergazomenoiFilteredRecs && ergazomenoiFilteredRecs.length > 0) { %>
                    <% ergazomenoiFilteredRecs.forEach(element => { %>
                        <% const isInactive = element.energos !== true; %>
                        <tr class="input-content-regular <%= isInactive ? 'ergazomenos-anenergos table-danger' : '' %>" data-id="<%- element._id %>" id="myTableRow">
                            <td class="col-1 padding-left-rem-0_5"><%- element.kodikos %></td>
                            <td class="col-3-5">
                                <%- element.eponymo %>
                                <% if (isInactive) { %>
                                    <% const inactiveSince = formatInactiveDate(element.hmeromhnia_apoxorhshs); %>
                                    <span class="badge bg-danger ms-2">
                                        ΑΝΕΝΕΡΓΟΣ<%= inactiveSince ? ` από ${inactiveSince}` : '' %>
                                    </span>
                                <% } %>
                            </td>
                            <td class="col-2"><%- element.onoma %></td>
                            <td class="col-2"><%- element.patronymo %></td>
                            <td class="col-1"><%- element.afm %></td>
                            <td class="col-1-5"><%- element.amka %></td>
                            <td class="col-1"><%- element.adt %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="card-footer cardFooter">
        <div class="d-inline-block d-flex cardFooter01">
            <div class="d-flex cardFooter02">
                <a
                    id="edit-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip"
                    data-bs-title="Εμφάνιση - Διόρθωση των στοιχείων του επιλεγμένου εργαζόμενου"
                    data-bs-placement="top"
                    data-tooltip-max-width="15vw"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.update) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.update) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
                </a>

                <a
                    id="delete-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip"
                    data-bs-title="Διαγραφή του επιλεγμένου εργαζόμενου"
                    data-bs-placement="top"
                    data-tooltip-max-width="15vw"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.delete) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.delete) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-trash"></i> Διαγραφή
                </a>

                <a
                    href="/ergazomenoi/ergazomenoi<%= anenerghQueryFirst %>"
                    role="button"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2">
                    <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
                </a>
            </div>

            <div class="d-flex width-percent-15"></div>

            <% if (ergazomenoiFilteredRecs) { %>
                <nav class="col-2" aria-label="Dashboard Pagination">
                    <ul class="pagination pagination-sm justify-content-end mt-2">
                        <% if (Number(current) === 1) { %>
                            <li class="page-item disabled"><a href="#" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a></li>
                            <li class="page-item disabled"><a href="#" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a></li>
                        <% } else { %>
                            <li class="page-item"><a href="/ergazomenoi/ergazomenoi/search/?page=1<%= anenerghQuery %>" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a></li>
                            <li class="page-item"><a href="/ergazomenoi/ergazomenoi/search/?page=<%= Number(current) - 1 %><%= anenerghQuery %>" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a></li>
                        <% } %>

                        <% var i = Number(current) > 2 ? Number(current) - 1 : 1; %>
                        <% if (i !== 1) { %>
                            <li class="page-item disabled"><a href="#" class="page-link font-size-vw-0_5">...</a></li>
                        <% } %>

                        <% for (; i <= (Number(current) + 1) && i <= pages; i++) { %>
                            <% if (i === Number(current)) { %>
                                <li class="page-item is-current" aria-current="page"><span class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></span></li>
                            <% } else { %>
                                <li class="page-item fsvw-0_7"><a href="/ergazomenoi/ergazomenoi/search/?page=<%= i %><%= anenerghQuery %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></a></li>
                            <% } %>

                            <% if (i === Number(current) + 1 && i < pages) { %>
                                <li class="page-item disabled"><a href="#" class="page-link font-size-vw-0_5">...</a></li>
                                <li class="page-item"><a href="/ergazomenoi/ergazomenoi/search/?page=<%= pages %><%= anenerghQuery %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= pages %></a></li>
                            <% } %>
                        <% } %>

                        <% if (Number(current) === Number(pages)) { %>
                            <li class="page-item disabled"><a href="#" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a></li>
                            <li class="page-item disabled"><a href="#" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a></li>
                        <% } else { %>
                            <li class="page-item"><a href="/ergazomenoi/ergazomenoi/search/?page=<%= Number(current) + 1 %><%= anenerghQuery %>" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a></li>
                            <li class="page-item fsvw-0_7"><a href="/ergazomenoi/ergazomenoi/search/?page=<%= pages %><%= anenerghQuery %>" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a></li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>
<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>
<script src="<%= script('common/blockInvalidClick') %>"></script>
<script src="<%= script('common/sortTable') %>"></script>
<script src="<%= script('ergazomenoi/genika/selectRowInTable') %>"></script>
<script src="<%= script('common/ergazomenoiAnenerghToggle') %>"></script>