<%
    const anenerghValue = typeof anenergh !== 'undefined' ? anenergh : '';
    const showInactiveValue = typeof showInactive !== 'undefined' ? showInactive : false;
    const anenerghChecked = anenerghValue === 'on' || anenerghValue === true || showInactiveValue === true;
    const anenerghQuery = anenerghChecked ? '&anenergh=on' : '';
    const anenerghQueryFirst = anenerghChecked ? '?anenergh=on' : '';

    const formatInactiveDate = (value) => {
        if (!value) return '';

        if (typeof value === 'string') {
            const isoMatch = value.match(/^(\d{4})-(\d{2})-(\d{2})/);
            if (isoMatch) return `${isoMatch[3]}/${isoMatch[2]}/${isoMatch[1]}`;
        }

        const d = new Date(value);
        if (Number.isNaN(d.getTime())) return '';

        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear();

        return `${day}/${month}/${year}`;
    };
%>

<style nonce="<%= nonce %>">
    #anenergh.form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }

    tr.ergazomenos-anenergos > td {
        color: #b02a37 !important;
        font-weight: 600;
        background-color: #f8d7da !important;
    }

    /*
        Bootstrap .table-striped / .table-hover / .table-danger δεν βάφουν μόνο το <tr>.
        Χρησιμοποιούν CSS variables και box-shadow στα <td>, οπότε για να γίνει
        πραγματικά πράσινη και η ανενεργή επιλεγμένη γραμμή πρέπει να κάνουμε
        override και τα Bootstrap table variables και το box-shadow.
    */
    #myTable tbody tr.selected-row,
    #myTable tbody tr.ergazomenos-anenergos.selected-row {
        --bs-table-color: #ffffff !important;
        --bs-table-bg: #198754 !important;
        --bs-table-striped-color: #ffffff !important;
        --bs-table-striped-bg: #198754 !important;
        --bs-table-active-color: #ffffff !important;
        --bs-table-active-bg: #198754 !important;
        --bs-table-hover-color: #ffffff !important;
        --bs-table-hover-bg: #198754 !important;
        --bs-table-accent-bg: #198754 !important;
        color: #ffffff !important;
        background-color: #198754 !important;
    }

    #myTable tbody tr.selected-row > th,
    #myTable tbody tr.selected-row > td,
    #myTable tbody tr.ergazomenos-anenergos.selected-row > th,
    #myTable tbody tr.ergazomenos-anenergos.selected-row > td {
        --bs-table-color: #ffffff !important;
        --bs-table-bg: #198754 !important;
        --bs-table-striped-color: #ffffff !important;
        --bs-table-striped-bg: #198754 !important;
        --bs-table-active-color: #ffffff !important;
        --bs-table-active-bg: #198754 !important;
        --bs-table-hover-color: #ffffff !important;
        --bs-table-hover-bg: #198754 !important;
        --bs-table-accent-bg: #198754 !important;
        color: #ffffff !important;
        background-color: #198754 !important;
        box-shadow: inset 0 0 0 9999px #198754 !important;
        font-weight: 600;
    }

    #myTable tbody tr.selected-row .badge {
        border: 1px solid rgba(255, 255, 255, 0.75);
    }

    .ergazomenoi-toggle-wrap {
        min-width: 11rem;
    }
</style>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom bg-hero-cdn">
    <div class="d-flex align-items-center gap-3 ms-auto flex-wrap justify-content-end">
        <div class="form-check form-switch mb-0 ergazomenoi-toggle-wrap">
            <input
                class="form-check-input"
                type="checkbox"
                role="switch"
                id="anenergh"
                name="anenergh"
                value="on"
                <%= anenerghChecked ? 'checked' : '' %> />
            <label class="form-check-label fw600" for="anenergh">
                Ανενεργοί: <span id="anenerghLabel"><%= anenerghChecked ? 'ΝΑΙ' : 'ΟΧΙ' %></span>
            </label>
        </div>

        <form
            name="Ergazomenoi"
            class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0"
            role="search"
            method="POST"
            action="/ergazomenoi/ergazomenoi/search">
            <%- include('../../partials/_csrfField') %>
            <input type="hidden" name="anenergh" value="<%= anenerghChecked ? 'on' : '' %>">

            <div class="input-group">
                <span><i class="bi bi-search bi-search-swing fsvw-1_3 fw600 cgreen"></i>&nbsp;</span>
                <input
                    type="search"
                    name="searchTerm"
                    id="searchInput"
                    class="form-control rounded-end-2 ms-auto fsvw-1_1 border-radius-10 use-default-enter"
                    placeholder="Αναζήτηση... ( πατείστε Enter )"
                    autocomplete="off"
                    aria-label="Search" />
            </div>
        </form>
    </div>
</div>

<div class="card d-flex flex-column z-depth-5 w-99 margin-left-0_5rem overflow-hidden">
    <div class="card-header p-0 height-rem-3_5">
        <label class="text-center w-100 headers-content mt-2">
            Διαχείριση Εργαζομένων
            <% if (anenerghChecked) { %>
                <span class="badge bg-danger ms-2">Εμφάνιση και ανενεργών</span>
            <% } %>
        </label>
    </div>

    <div>
        <table class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
            <thead class="backgroundColor-brown font-size-rem-1 center-align">
                <tr class="color-brown">
                    <th scope="col" class="color-brown col-1">Κωδ.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-3-5">Επώνυμο<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-2">Όνομα<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-2">Πατρώνυμο<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-1">Α.Φ.Μ.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-1-5">Α.M.K.A.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="color-brown col-1">Α.Δ.Τ.<i class="sort-icon bi"></i></th>
                </tr>
            </thead>
        </table>
    </div>

    <div class="card-body p-0 overflow-auto flex-grow-1 height-vh-62 bg-white">
        <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
            <tbody>
                <% if (ergazomenoi && ergazomenoi.length !== 0) { %>
                    <% ergazomenoi.forEach(element => { %>
                        <% const isInactive = element.energos !== true; %>
                        <tr
                            class="input-content-regular <%= isInactive ? 'ergazomenos-anenergos table-danger' : '' %>"
                            data-id="<%= element._id %>"
                            data-kod="<%= element.kodikos %>">
                            <td class="col-1 padding-left-rem-0_5"><%= element.kodikos %></td>
                            <td class="col-3-5">
                                <%= element.eponymo %>
                                <% if (isInactive) { %>
                                    <% const inactiveSince = formatInactiveDate(element.hmeromhnia_apoxorhshs); %>
                                    <span class="badge bg-danger ms-2">
                                        ΑΝΕΝΕΡΓΟΣ<%= inactiveSince ? ` από ${inactiveSince}` : '' %>
                                    </span>
                                <% } %>
                            </td>
                            <td class="col-2"><%= element.onoma %></td>
                            <td class="col-2"><%= element.patronymo %></td>
                            <td class="col-1"><%= element.afm %></td>
                            <td class="col-1-5"><%= element.amka %></td>
                            <td class="col-1"><%= element.adt %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <%
        const cur = Math.max(1, Number(current || 1));
        const total = Math.max(1, Number(pages || 1));
        const perxVal = Math.min(5, Math.max(1, parseInt(perx, 10) || 1));
        const qsParts = [];
        if (anenerghChecked) qsParts.push('anenergh=on');
        const qsKeep = qsParts.length ? '&' + qsParts.join('&') : '';
        const base = '/ergazomenoi/ergazomenoi';
        const href = (p) => `${base}?page=${p}&perx=${perxVal}${qsKeep}`;
        const perxHref = (n) => `${base}?page=1&perx=${n}${qsKeep}`;
        const start = Math.max(1, cur - 1);
        const end = Math.min(total, cur + 1);
    %>

    <div class="card-footer d-flex align-items-center flex-nowrap gap-0_75rem nowrap overflow-x-auto">
        <div class="d-flex align-items-center flex-nowrap gap-0_5rem">
            <a
                id="add-btn"
                href="/ergazomenoi/ergazomenoi/add"
                role="button"
                data-bs-toggle="tooltip"
                data-bs-title="Προσθήκη νέου εργαζόμενου"
                data-bs-placement="bottom"
                data-tooltip-max-width="15vw"
                class="btn btn-brown rounded-4 buttons-content <%= (!userPrivileges.admin && !userPrivileges.create) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.create) ? '1' : '0' %>">
                <i class="buttons-content bi bi-plus-circle"></i> Εισαγωγή
            </a>

            <a
                id="edit-btn"
                href="#"
                role="button"
                data-bs-toggle="tooltip"
                data-bs-title="Εμφάνιση - Διόρθωση των στοιχείων του επιλεγμένου εργαζόμενου"
                data-tooltip-max-width="15vw"
                data-bs-placement="bottom"
                class="btn btn-brown rounded-4 buttons-content <%= (!userPrivileges.admin && !userPrivileges.update) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.update) ? '1' : '0' %>">
                <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
            </a>

            <a
                id="delete-btn"
                href="#"
                role="button"
                data-bs-toggle="tooltip"
                data-bs-title="Διαγραφή των στοιχείων του επιλεγμένου εργαζόμενου"
                data-bs-placement="bottom"
                data-tooltip-max-width="15vw"
                class="btn btn-brown rounded-4 buttons-content <%= (!userPrivileges.admin && !userPrivileges.delete) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.delete) ? '1' : '0' %>">
                <i class="buttons-content bi bi-trash"></i> Διαγραφή
            </a>

            <a
                href="/mainapp"
                role="button"
                data-bs-toggle="tooltip"
                data-bs-placement="bottom"
                data-tooltip-max-width="15vw"
                data-bs-title="Επιστροφή στην Αρχική Σελίδα της εφαρμογής"
                class="btn btn-brown rounded-4 buttons-content">
                <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
            </a>
        </div>

        <div class="d-flex align-items-center flex-nowrap gap-0_5rem ms-2" id="perx-block">
            <span class="small text-muted font-size-rem-0_72">Εγγραφές: <strong><%= basePer %></strong></span>
            <ul class="pagination pagination-sm mb-0 margin-top--0_5rem perx-pagination">
                <% [1, 2, 3, 4, 5].forEach(n => { %>
                    <li class="page-item <%= perxVal === n ? 'active' : '' %>">
                        <a class="page-link" href="<%= perxHref(n) %>" <%= perxVal === n ? 'aria-current="true"' : '' %>>x<%= n %></a>
                    </li>
                <% }) %>
            </ul>
            <label class="small text-muted text-center font-size-rem-0_72"><strong>= <%= entries %></strong> / Σελίδα</label>
        </div>

        <div class="flex-grow-1"></div>

        <% if (ergazomenoi) { %>
            <nav aria-label="Πλοήγηση σελίδων">
                <ul class="pagination pagination-sm mb-0 margin-top--0_5rem">
                    <li class="page-item <%= cur === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="<%= cur === 1 ? '#' : href(1) %>" aria-label="First" <%= cur === 1 ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-bar-left"></i></a>
                    </li>
                    <li class="page-item <%= cur === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="<%= cur === 1 ? '#' : href(cur - 1) %>" aria-label="Previous" <%= cur === 1 ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-left"></i></a>
                    </li>

                    <% if (start > 1) { %>
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    <% } %>

                    <% for (let i = start; i <= end; i++) { %>
                        <li class="page-item <%= i === cur ? 'active' : '' %>" <%= i === cur ? 'aria-current="page"' : '' %>>
                            <% if (i === cur) { %>
                                <span class="page-link"><%= i %></span>
                            <% } else { %>
                                <a class="page-link" href="<%= href(i) %>"><%= i %></a>
                            <% } %>
                        </li>
                    <% } %>

                    <% if (end < total) { %>
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                        <li class="page-item"><a class="page-link" href="<%= href(total) %>"><%= total %></a></li>
                    <% } %>

                    <li class="page-item <%= cur === total ? 'disabled' : '' %>">
                        <a class="page-link" href="<%= cur === total ? '#' : href(cur + 1) %>" aria-label="Next" <%= cur === total ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-right"></i></a>
                    </li>
                    <li class="page-item <%= cur === total ? 'disabled' : '' %>">
                        <a class="page-link" href="<%= cur === total ? '#' : href(total) %>" aria-label="Last" <%= cur === total ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-bar-right"></i></a>
                    </li>
                </ul>
            </nav>
        <% } %>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>
<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>
<script src="<%= script('common/blockInvalidClick') %>"></script>
<script src="<%= script('common/sortTable') %>"></script>
<script src="<%= script('ergazomenoi/genika/selectRowInTable') %>"></script>
<script src="<%= script('common/ergazomenoiAnenerghToggle') %>"></script>