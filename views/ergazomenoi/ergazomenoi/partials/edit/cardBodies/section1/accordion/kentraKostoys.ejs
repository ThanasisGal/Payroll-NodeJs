          </label>
        </div>
        <div class="col-1">
          <input type="number" name="pososto_apasxolhshs_kk1" id="pososto_apasxolhshs_kk1" class="form-control input-contents percentTotal right-align" value="<%= parseFloat(ergazomenoiData.pososto_apasxolhshs_kk1).toFixed(2) %>" min="0" max="100" step="0.05" />
        </div>
