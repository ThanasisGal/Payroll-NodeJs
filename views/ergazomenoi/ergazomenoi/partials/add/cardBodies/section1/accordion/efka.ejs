<div class="accordion-item">
    <h2 class="accordion-header">
        <button class="accordion-button collapsed bg-accordion font-size-vw-1 font-weight-700  caccordion" type="button" data-bs-toggle="collapse" data-bs-target="#panelsStayOpen-collapseFour" aria-expanded="true" aria-controls="panelsStayOpen-collapseFour" 
        tabindex="-1">
        Ε.Φ.Κ.Α.
        </button>
    </h2>
  
    <div id="panelsStayOpen-collapseFour" class="accordion-collapse collapse show">

        <% const safe = (k) => (rec && rec[k]) || ''; %>

        <div class="accordion-body bg-white margin-bottom--0_5rem">
            <div class="row form-group g-3 align-items-center margin-left--1rem margin-right--1rem margin-top--4rem">
                <div class="col-2 left-align">
                    <label for="kad_efka" class="col-form-label label-font-size field-required">
                    Κ.Α.Δ. ΕΦΚΑ
                    </label>
                </div>

                <div class="col-9-74">
                    <input
                        type="hidden"
                        name="kad_efka_stathera"
                        id="kad_efka_stathera"
                        class="form-control input-contents"
                        value="<%= safe("kad_efka_stathera") %>"
                    />

                    <select
                        id="kad_efka"
                        name="kad_efka"
                        class="tom-dropdown selectpicker-dropdown-normal left-align w-100"
                        aria-label="Κ.Α.Δ. ΕΦΚΑ"
                        data-api="/api/dropdown/ergazomenoi/kad_efka"
                        single
                        data-target-input=<%= `kad_efka_stathera` %>
                        data-preselect=<%= `kad_efka_stathera` %>
                        data-preload-all="true"
                        data-pad-length="4"
                        data-xrhsh-related="false"
                        data-team-related="false"
                        data-company-related="false"
                        data-mhnas-related="false"
                        placeholder="Αναζήτηση Κ.Α.Δ. ΕΦΚΑ">
                    </select>
                </div>
            </div>

            <div class="height-vh-0_3"></div>

            <div class="row form-group g-3 align-items-center margin-left--1rem margin-right--1rem">
                <div class="col-2 left-align">
                    <label for="eidikothta_efka" class="col-form-label label-font-size field-required">
                    Ειδικότητα ΕΦΚΑ
                    </label>
                </div>

                <div class="col-9-74">
                    <input
                        type="hidden"
                        name="eidikothta_efka_stathera"
                        id="eidikothta_efka_stathera"
                        class="form-control input-contents"
                        value="<%= safe("eidikothta_efka_stathera") %>"
                    />

                    <select
                        id="eidikothta_efka"
                        name="eidikothta_efka"
                        class="tom-dropdown selectpicker-dropdown-normal left-align w-100"
                        aria-label="Ειδικότητες ΕΦΚΑ"
                        data-api="/api/dropdown/ergazomenoi/eidikothta_efka"
                        single
                        data-target-input=<%= `eidikothta_efka_stathera` %>
                        data-preselect=<%= `eidikothta_efka_stathera` %>
                        data-preload-all="false"
                        data-skip-autoload="true"
                        data-pad-length="6"
                        data-xrhsh-related="false"
                        data-team-related="false"
                        data-company-related="false"
                        data-mhnas-related="false"
                        placeholder="Αναζήτηση Ειδικοτήτων ΕΦΚΑ">
                    </select>
                </div>
            </div>

            <div class="height-vh-0_3"></div>

            <div class="row form-group g-3 align-items-center margin-left--1rem margin-right--1rem">
                <div class="col-2 left-align">
                    <label for="kpk_efka" class="col-form-label label-font-size field-required">
                    Κ.Π.Κ. ΕΦΚΑ
                    </label>
                </div>

                <div class="col-9-74">
                    <input
                        type="hidden"
                        name="kpk_efka_stathera"
                        id="kpk_efka_stathera"
                        class="form-control input-contents"
                        value="<%= safe("kpk_efka_stathera") %>"
                    />

                    <input 
                        type="hidden" 
                        name="tmp_kpk_efka_stathera"
                        id="tmp_kpk_efka_stathera" 
                        class="form-control input-contents" 
                        value=""
                    />

                    <select
                        id="kpk_efka"
                        name="kpk_efka"
                        class="tom-dropdown selectpicker-dropdown-normal left-align w-100"
                        aria-label="Κ.Π.Κ. ΕΦΚΑ"
                        data-api="/api/dropdown/ergazomenoi/kpk_efka"
                        single
                        data-target-input=<%= `kpk_efka_stathera` %>
                        data-preselect=<%= `kpk_efka_stathera` %>
                        data-preload-all="false"
                        data-skip-autoload="true"
                        data-pad-length="4"
                        data-xrhsh-related="false"
                        data-team-related="false"
                        data-company-related="false"
                        data-mhnas-related="false"
                        placeholder="Αναζήτηση Κ.Π.Κ. ΕΦΚΑ">
                    </select>
                </div>
            </div>

            <div class="height-vh-0_3"></div>

            <div class="row form-group g-3 align-items-center margin-left--1rem margin-right--1rem">
                <div class="col-2 left-align">
                    <label for="epa_efka" class="col-form-label label-font-size field-required">
                    Ειδική Περίπτωση ΕΦΚΑ
                    </label>
                </div>

                <div class="col-9-74">
                    <input
                        type="hidden"
                        name="epa_efka_stathera"
                        id="epa_efka_stathera"
                        class="form-control input-contents"
                        value="<%= safe("epa_efka_stathera") %>"
                    />

                    <input
                        type="hidden"
                        name="tmp_epa_efka_stathera"
                        id="tmp_epa_efka_stathera"
                        class="form-control input-contents"
                        value=""
                    />

                    <select
                        id="epa_efka"
                        name="epa_efka"
                        class="tom-dropdown selectpicker-dropdown-normal left-align w-100"
                        aria-label="Ειδική Περίπτωση ΕΦΚΑ"
                        data-api="/api/dropdown/ergazomenoi/epa_efka"
                        single
                        data-target-input=<%= `epa_efka_stathera` %>
                        data-preselect=<%= `epa_efka_stathera` %>
                        data-preload-all="false"
                        data-skip-autoload="true"
                        data-xrhsh-related="false"
                        data-team-related="false"
                        data-company-related="false"
                        data-mhnas-related="false"
                        placeholder="Αναζήτηση Ειδικών Περιπτώσεων ΕΦΚΑ">
                    </select>
                </div>
            </div>

            <div class="row form-group g-3 align-items-center margin-left--1rem margin-right--1rem">
                <div class="col-2 left-align">
                    <label for="meiosh_eisforon_ergazomenon" class="col-form-label label-font-size">
                    Μείωση Εργατικής Εισφοράς
                    </label>
                </div>
                <div class="col-1 left-align checkbox-flex-center">
                    <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="meiosh_eisforon_ergazomenon" name="meiosh_eisforon_ergazomenon" value="" />
                    <label for="meiosh_eisforon_ergazomenon" id="label-meiosh_eisforon_ergazomenon" class="margin-left-0_75rem  font-size-vw-0_875">
                    ΟΧΙ
                    </label>
                </div>

                <div class="col-3"></div>

                <div class="col-2 left-align">
                    <label for="epidothsh_eisforon_ergodoth" class="col-form-label label-font-size">
                    Επιδ/ση Εργοδ/κής Εισφοράς
                    </label>
                </div>
                <div class="col-1 left-align checkbox-flex-center">
                    <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="epidothsh_eisforon_ergodoth" name="epidothsh_eisforon_ergodoth" value="" />
                    <label for="epidothsh_eisforon_ergodoth" id="label-epidothsh_eisforon_ergodoth" class="margin-left-0_75rem  font-size-vw-0_875">
                    ΟΧΙ
                    </label>
                </div>
            </div>

            <hr class="hr-style" />

            <div class="row form-group g-3 align-items-center margin-left--1rem margin-right--1rem">
                <div class="col-2 left-align">
                    <label for="palios_neos" class="col-form-label label-font-size field-required">
                    Παλιός/Νέος Ασφαλισμένος
                    </label>
                </div>
                <div class="col-1 left-align checkbox-flex-center">
                    <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="palios_neos" name="palios_neos" value="" />
                    <label for="palios_neos" id="label-palios_neos" class="margin-left-0_75rem  font-size-vw-0_875">
                    ΠΑΛΙΟΣ
                    </label>
                </div>

                <div class="col-3"></div>

                <div class="col-2 left-align">
                    <label for="amoibetai_me_sse" class="col-form-label label-font-size">
                    Αμοίβεται με οικεία ΣΣΕ και ασφαλίζεται με Τεκμαρτά
                    </label>
                </div>
                <div class="col-1 left-align checkbox-flex-center">
                    <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="amoibetai_me_sse" name="amoibetai_me_sse" value="" />
                    <label for="amoibetai_me_sse" id="label-amoibetai_me_sse" class="margin-left-0_75rem  font-size-vw-0_875">
                    ΟΧΙ
                </label>
            </div>
        </div>

    </div>
  </div>
</div>
