<script nonce="<%= nonce %>" type="module">
    import { bindCheckboxControlsSelect } from 'dependent-select-toggle';

	// Συγγένεια
    bindCheckboxControlsSelect({
        checkboxId: 'syggeneia',
        selectId  : 'syggenikh_sxesh',
        hiddenId  : 'syggenikh_sxesh_stathera',

		labelIds: [
			'syggenikh_sxesh_label'
		],

		clearOnDisable: true,
	});

    // Αφορά δανεισμό εργαζομένου
    bindCheckboxControlsSelect({
        checkboxId: 'afora_daneismo_ergazomenoy',
        selectId  : 'typos_daneismoy',
        hiddenId  : 'typos_daneismoy_stathera',
        
		extraFieldIds: [
            'hmnia_enarxhs_daneismoy',
            'hmnia_lhxhs_daneismoy'
        ],

		labelIds: [
			'typos_daneismoy_label',
			'hmnia_enarxhs_daneismoy_label',
			'hmnia_lhxhs_daneismoy_label'
		],

		clearOnDisable: true,
    });

    // Ασφαλιστική κλάση
    bindCheckboxControlsSelect({
        checkboxId: 'asfalish_me_tekmarta',
        selectId  : 'asfalistikh_klash',
        hiddenId  : 'asfalistikh_klash_stathera',

		labelIds: [
			'asfalistikh_klash_label'
		],
		
		clearOnDisable: true,
    });

	// Μείωση Εργατικής Εισφοράς
    bindCheckboxControlsSelect({
        checkboxId: 'meiosh_eisforon_ergazomenon',
        selectId  : 'meiosh_ergatikhs_eisforas',
        hiddenId  : 'kodikos_meioshs_stathera'
    });

	// Επιδότηση Εργοδοτικής Εισφοράς
    bindCheckboxControlsSelect({
        checkboxId: 'epidothsh_eisforon_ergodoth',
        selectId  : 'epidothsh_ergodotikhs_eisforas',
        hiddenId  : 'kodikos_epidothshs_stathera'
    });

	// Μείωση Εισφορών Μητέρων
    bindCheckboxControlsSelect({
        checkboxId: 'mhteres',
        selectId  : 'meiosh_eisforas_mhteron',
        hiddenId  : 'kodikos_meioshs_eisforon_mhteron_stathera'
    });


    // Λήψη επιδόματος ανεργίας
    bindCheckboxControlsSelect({
        checkboxId: 'epidoma_anergias',
        selectId  : 'dypa',
        hiddenId  : 'dypa_stathera',

		
		labelIds: [
			'dypa_label'
		],
		
		clearOnDisable: true,

    });

    // Τοποθέτηση με Πρόγραμμα
    bindCheckboxControlsSelect({
        checkboxId: 'topothethsh_me_programma',
        selectId  : 'programma_dypa',
        hiddenId  : 'programma_dypa_stathera',
        
		extraFieldIds: [
            'ypoxreotikh_ek_toy_nomoy_katartish',
            'egkritikh_apofash_dypa',
            'hmeromhnia_enarxhs_programmatos',
            'hmeromhnia_lhxhs_programmatos'
        ],

		labelIds: [
			'ypoxreotikh_ek_toy_nomoy_katartish_label',
			'programma_dypa_label',
			'egkritikh_apofash_dypa_label',
			'hmeromhnia_enarxhs_programmatos_label',
			'hmeromhnia_lhxhs_programmatos_label',
			'gotoProgrammaDypa'
		],


		clearOnDisable: true,
    });

    // Αδεια Διαμονής με Άμεση Πρόσβαση για Εργασία
    bindCheckboxControlsSelect({
        checkboxId: 'adeia_diamonhs_me_amesh_prosbash_gia_ergasia',
        selectId  : 'eidos_adeias_diamonhs_me_amesh_prosbash_gia_ergasia',
        hiddenId  : 'eidos_adeias_diamonhs_me_amesh_prosbash_gia_ergasia_stathera',

        extraFieldIds: [
            'arithmos_adeias_diamonhs_me_amesh_prosbash_gia_ergasia',
            'hmeromhnia_lhxhs_adeias_diamonhs_me_amesh_prosbash_gia_ergasia'
        ],
	    
		clearOnDisable: true,
    });

    // Αδεια Διαμονής χωρίς Άμεση Πρόσβαση για Εργασία
    bindCheckboxControlsSelect({
        checkboxId: 'adeia_diamonhs_xwris_amesh_prosbash_gia_ergasia',
        selectId  : 'eidos_adeias_diamonhs_xwris_amesh_prosbash_gia_ergasia',
        hiddenId  : 'eidos_adeias_diamonhs_xwris_amesh_prosbash_gia_ergasia_stathera',

        extraFieldIds: [
            'arithmos_adeias_diamonhs_xwris_amesh_prosbash_gia_ergasia',
            'hmeromhnia_lhxhs_adeias_diamonhs_xwris_amesh_prosbash_gia_ergasia'
        ],
    	
		clearOnDisable: true,
    });

    // Θεματικό Πεδίο Επαγγελματικής Κατάρτισης
    bindCheckboxControlsSelect({
        checkboxId: 'epaggelmatikh_katartish',
        selectId  : 'thematiko_pedio',
        hiddenId  : 'thematiko_pedio_stathera',

        // ✅ ΝΕΟ:  Cascading selects που θα enable/disable μαζί
        cascadingSelectIds: [
            'thematikh_enothta',
            'foreas_katartishs'
        ],
        
        clearOnDisable: true,
    });

</script>

