<br> <br> <br>                
<form class="formRadius" id="transferForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    
    <div class="card d-flex flex-column z-depth-5 w-60 margin-left-percent-20 overflow-hidden">

        <div class="card-header p-0 height-rem-3_5">
            <label class="headers-content">
                Υπολογισμός Απασχολήσεων Από Κάρτες Εργασίας ΕΡΓΑΝΗ ΙΙ
            </label>
        </div>

       
        <div class="card-body overflow-auto flex-grow-1 height-vh-33 bg-white">
            <%
                const safe = (k) => (rec && rec[k]) || '';

                const toDateInputValue = (value) => {
                    if (!value) return '';

                    if (typeof value === 'string') {
                        const trimmed = value.trim();

                        // HTML input[type=date] θέλει YYYY-MM-DD
                        if (/^\d{4}-\d{2}-\d{2}/.test(trimmed)) {
                            return trimmed.slice(0, 10);
                        }

                        // Αν έρθει σε μορφή DD/MM/YYYY
                        if (/^\d{2}\/\d{2}\/\d{4}$/.test(trimmed)) {
                            const [d, m, y] = trimmed.split('/');
                            return `${y}-${m}-${d}`;
                        }
                    }

                    const dt = new Date(value);
                    if (Number.isNaN(dt.getTime())) return '';

                    const y = dt.getFullYear();
                    const m = String(dt.getMonth() + 1).padStart(2, '0');
                    const d = String(dt.getDate()).padStart(2, '0');
                    return `${y}-${m}-${d}`;
                };

                // Το periodRec πρέπει να έρχεται από τον controller:
                // PeriodsModel.findOne({ xrhsh: req.session.yearInUse, kodikos: req.session.periodInUse }).lean()
                const currentPeriod = periodRec || period || null;
                const apoHmeromhniaValue = toDateInputValue(currentPeriod && currentPeriod.apo);
                const eosHmeromhniaValue = toDateInputValue(currentPeriod && currentPeriod.eos);

                const xronosProetoimasiasValue = safe('xronosProetoimasias_stathera') || '00';
                const proorhApoxorhshValue = safe('proorhApoxorhsh_stathera') || '10';
            %>

            <input type="hidden" name="team" id="team" class="form-control input-contents" value="<%= sessionTeam %>" />
            <input type="hidden" name="company_kod" id="company_kod" class="form-control input-contents" value="<%= companyId %>" />
            <input type="hidden" name="ypokatasthmaHidden" id="ypokatasthmaHidden" class="form-control input-contents" value="" />
            <input type="hidden" name="xronos_epitrepomenhs_proorhs_apoxorhshs_se_lepta" id="xronos_epitrepomenhs_proorhs_apoxorhshs_se_lepta" class="form-control input-contents" value="<%= xronos_epitrepomenhs_proorhs_apoxorhshs_se_lepta %>" />

            </br>
            <div class="row form-group g-3 align-items-center mb-3">
                <div class="col-2 left-align">
                    <label for="ypokatasthmata" class="col-form-label label-font-size-smaller field-required">
                        Παράρτημα
                    </label>
                </div>

                <input
                    type="hidden"
                    name="ypokatasthmata_stathera"
                    id="ypokatasthmata_stathera"
                    class="form-control input-contents"
                    value="<%= safe('ypokatasthmata_stathera') %>"
                    readonly
                />

                <div class="col-9-5 mt-2">
                    <select
                        id="ypokatasthmata"
                        name="ypokatasthmata"
                        class="tom-dropdown selectpicker-dropdown-normal left-align"
                        aria-label="Υποκατάστημα"
                        data-api="/api/dropdown/erganh/ypokatasthmata?company=<%= companyInUse || '' %>"
                        single
                        data-target-input="ypokatasthmata_stathera"
                        data-preselect="ypokatasthmata_stathera"
                        data-preload-all="true"
                        data-pad-length="4"
                        data-xrhsh-related="false"
                        data-team-related="false"
                        data-company-related="false"
                        data-mhnas-related="false"
                        placeholder="Αναζήτηση Υποκαταστήματος">
                    </select>
                </div>
            </div>

            <div class="row form-group g-3 align-items-center mb-4"></div>

            <div class="row form-group g-3 align-items-center mb-3">
                <div class="col-2 left-align">
                    <label for="apo_hmeromhnia" class="col-form-label label-font-size-smaller">
                        Από Ημερομηνία
                    </label>
                </div>
                <div class="col-2-5">
                    <input type="date" name="apo_hmeromhnia" id="apo_hmeromhnia" class="date-control" value="<%= apoHmeromhniaValue %>" required />
                </div>
            </div>

            <div class="row form-group g-3 align-items-center mb-4"></div>

            <div class="row form-group g-3 align-items-center mb-3">
                <div class="col-2 left-align">
                    <label for="eos_hmeromhnia" class="col-form-label label-font-size-smaller">
                        Έως Ημερομηνία
                    </label>
                </div>
                <div class="col-2-5">
                    <input type="date" name="eos_hmeromhnia" id="eos_hmeromhnia" class="date-control" value="<%= eosHmeromhniaValue %>" required />
                </div>
            </div>

            <div class="row form-group g-3 align-items-center mb-4"></div>

            <div class="row form-group g-3 align-items-center mb-3">
                <div class="col-2 left-align mt-n-0-15 margin-top-0_5rem">
                    <label for="xronosProetoimasias" class="col-form-label label-font-size-smaller">
                        Πρόωρη Προσέλευση
                    </label>
                </div>

                <input
                    type="hidden"
                    name="xronosProetoimasias_stathera"
                    id="xronosProetoimasias_stathera"
                    class="form-control input-contents"
                    value="<%= xronosProetoimasiasValue %>"
                    readonly
                />

                <div class="col-3-15 mt-2">
                    <select
                        id="xronosProetoimasias"
                        name="xronosProetoimasias"
                        class="tom-dropdown selectpicker-dropdown-normal left-align"
                        aria-label="Υποκατάστημα"
                        data-api="/api/dropdown/erganh/xronosProetoimasias"
                        single
                        data-target-input="xronosProetoimasias_stathera"
                        data-preselect="xronosProetoimasias_stathera"
                        data-preload-all="true"
                        data-pad-length="2"
                        placeholder="">
                    </select>
                </div>

                <div class="col-3-2 left-align mt-n-0-15 text-end margin-top-0_5rem">
                    <label for="proorhApoxorhsh" class="col-form-label label-font-size-smaller">
                        Πρόωρη Αποχώρηση (απουσίες)
                    </label>
                </div>

                <input
                    type="hidden"
                    name="proorhApoxorhsh_stathera"
                    id="proorhApoxorhsh_stathera"
                    class="form-control input-contents"
                    value="<%= proorhApoxorhshValue %>"
                    readonly
                />

                <div class="col-3-15 mt-2">
                    <select
                        id="proorhApoxorhsh"
                        name="proorhApoxorhsh"
                        class="tom-dropdown selectpicker-dropdown-normal left-align"
                        aria-label="Υποκατάστημα"
                        data-api="/api/dropdown/erganh/proorhApoxorhsh"
                        single
                        data-target-input="proorhApoxorhsh_stathera"
                        data-preselect="proorhApoxorhsh_stathera"
                        data-preload-all="true"
                        data-pad-length="2"
                        placeholder="">
                    </select>
                </div>

            </div>
        </div>

        <div class="card-footer">
            <div class="d-inline-block d-flex cardFooter01">
                <button 
                    type="button" 
                    class="btn btn-brown rounded-4 mt-2 w-20 buttons-content <% if (!userPrivileges.admin && !userPrivileges.update && !userPrivileges.create) { %>disabled-link<% } %>" 
                    name="calcApasxolhseonButton" 
                    id="calcApasxolhseonButton">
                    <i class="bi bi-person-gear"></i> Υπολογισμός
                </button>
                        
                <a class="btn btn-brown buttons-content rounded-4 mt-2 w-20" href="/mainapp">
                    <i class="bi bi-chevron-double-left"></i> Επιστροφή
                </a>
                <button type="button" class="btn btn-toTop scroll-to-top">
                    <i class="bi bi-chevron-double-up"></i>
                </button>
            </div>
        </div>
    </div>
</form>

<% const isProduction = NODE_ENV === 'production'; %>
<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>

<script nonce="<%= nonce %>">
    document.addEventListener('DOMContentLoaded', function () {
        const companyToleranceInput = document.getElementById(
            'xronos_epitrepomenhs_proorhs_apoxorhshs_se_lepta'
        );

        const selectedToleranceInput = document.getElementById('proorhApoxorhsh_stathera');

        const checkProorhApoxorhshTolerance = () => {
            const companyTolerance = Number(companyToleranceInput?.value || 0);
            const selectedTolerance = Number(selectedToleranceInput?.value || 0);

            if (companyTolerance !== selectedTolerance) {
                Swal.fire({
                    backdrop: false,
                    allowOutsideClick: false,
                    icon: 'warning',
                    title: 'ΠΡΟΣΟΧΗ!',
                    text: `Ο ανεκτός χρόνος πρόωρης αποχώρησης που δεν λογίσεται σαν απουσία έχει δηλωθεί για την εταιρεία σε ${companyTolerance} λεπτά`,
                    showConfirmButton: true,
                    confirmButtonText: 'Εντάξει',
                    customClass: {
                        confirmButton: 'class-warning custom-confirm-button custom-swal-button',
                        title: 'custom-title',
                        popup: 'custom-swal-popup'
                    }
                });
            }
        };

        setTimeout(checkProorhApoxorhshTolerance, 500);

        if (selectedToleranceInput) {
            selectedToleranceInput.addEventListener('change', checkProorhApoxorhshTolerance);
            selectedToleranceInput.addEventListener('input', checkProorhApoxorhshTolerance);
        }
    });
</script>

