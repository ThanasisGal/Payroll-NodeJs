<%
    const dateInputValue = (v) => {
        if (!v) return '';
        const d = new Date(v);
        if (isNaN(d.getTime())) return '';
        return d.toISOString().slice(0, 10);
    };
    const normalizedUserRole = String(userRole || '').trim().toUpperCase();
    const canRecordRepoTransferDecision = ['A', 'S', 'HR'].includes(normalizedUserRole);
    const canApplyRepoTransferDecision = ['A', 'S'].includes(normalizedUserRole);
    const canUseAdvancedEmploymentReview = ['A', 'S'].includes(normalizedUserRole);
    const companyInUse = companyId || '';
%>

<div class="container-fluid mt-3 employment-review-page-shell">
    <meta name="csrf-token" content="<%= csrfToken %>" />

    <% if (canRecordRepoTransferDecision) { %>
    <section id="hrReviewWorkspace" class="hr-review-workspace">
        <div class="card shadow-sm rounded-4 hr-review-card employment-review-card z-depth-5">
            <div class="card-header text-center">
                <h3 class="mb-0">Έλεγχος Απασχολήσεων</h3>
            </div>
            <div class="card-body">
                <div class="hr-review-filters employment-review-filter-grid">
                    <div class="employment-review-date-filter">
                        <label for="hr_apo_hmeromhnia" class="form-label">Από ημερομηνία</label>
                        <input
                            type="date"
                            id="hr_apo_hmeromhnia"
                            class="form-control"
                            value="<%= dateInputValue(periodRec?.apo) %>"
                        />
                    </div>
                    <div class="employment-review-date-filter">
                        <label for="hr_eos_hmeromhnia" class="form-label">Έως ημερομηνία</label>
                        <input
                            type="date"
                            id="hr_eos_hmeromhnia"
                            class="form-control"
                            value="<%= dateInputValue(periodRec?.eos) %>"
                        />
                    </div>
                    <div class="employment-review-branch-control">
                        <label for="ypokatasthmata" class="form-label">Παράρτημα</label>
                        <input
                            type="hidden"
                            name="ypokatasthmata_stathera"
                            id="ypokatasthmata_stathera"
                            value=""
                            readonly
                        />
                        <select
                            id="ypokatasthmata"
                            name="ypokatasthmata"
                            class="tom-dropdown selectpicker-dropdown-normal left-align"
                            aria-label="Παράρτημα"
                            data-api="/api/dropdown/erganh/ypokatasthmata?company=<%= companyInUse || '' %>"
                            single
                            data-target-input="ypokatasthmata_stathera"
                            data-preselect="ypokatasthmata_stathera"
                            data-dropdown-direction="down"
                            data-preload-all="true"
                            data-pad-length="4"
                            data-xrhsh-related="false"
                            data-team-related="false"
                            data-company-related="false"
                            data-mhnas-related="false"
                            placeholder="Επιλέξτε παράρτημα">
                        </select>
                    </div>
                    <div class="employment-review-start-action d-grid">
                        <button type="button" class="btn rounded-4 employment-review-action-btn employment-review-action-secondary" id="hrReviewStartBtn">
                            Έναρξη ελέγχου
                        </button>
                    </div>
                </div>

                <div class="employment-review-scroll-container employment-review-scroll-container--minimal">
                    <div id="hrReviewStatus" class="hr-review-status mt-3" aria-live="polite">
                        Επιλέξτε παράρτημα και πατήστε «Έναρξη ελέγχου».
                    </div>
                    <div id="hrReviewProgress" class="hr-review-progress d-none" aria-live="polite"></div>
                    <div id="hrReviewPendingContainer" class="hr-review-pending-container"></div>
                    <div id="hrReviewCompletedContainer" class="hr-review-completed-container"></div>

                    <% if (canUseAdvancedEmploymentReview) { %>
                        <div class="hr-review-workspace-switch mt-4">
                            <button type="button" class="btn employment-review-action-btn employment-review-action-secondary" id="showAdvancedReviewBtn">
                                Αναλυτική προβολή
                            </button>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </section>
    <% } else { %>
        <div class="alert alert-warning text-center" role="alert">
            Δεν έχετε δικαίωμα χρήσης του ελέγχου απασχολήσεων.
        </div>
    <% } %>

    <% if (canUseAdvancedEmploymentReview) { %>
    <section id="advancedReviewWorkspace" class="d-none">
    <div class="card shadow-sm rounded-4 employment-review-card z-depth-5">
        <div class="card-header text-center">
            <h3 class="mb-0">Έλεγχος Απασχολήσεων Από Κάρτες Εργασίας ΕΡΓΑΝΗ ΙΙ</h3>
        </div>

        <div class="card-body review-card-body">
            <div class="review-filters-sticky">
                <div class="row g-1 mb-2" id="reviewFiltersEnterScope">
                    <div class="col-md-2">
                        <label class="form-label">Από Ημερομηνία</label>
                        <input
                            type="date"
                            id="apo_hmeromhnia"
                            class="form-control date-tall move-by-enter"
                            value="<%= dateInputValue(periodRec?.apo) %>"
                        />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Έως Ημερομηνία</label>
                        <input
                            type="date"
                            id="eos_hmeromhnia"
                            class="form-control date-tall move-by-enter"
                            value="<%= dateInputValue(periodRec?.eos) %>"
                        />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Παράρτημα</label>
                        <input
                            type="text"
                            id="ypokatasthma"
                            class="form-control date-tall move-by-enter"
                            placeholder="0000"
                        />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Κωδικός</label>
                        <input
                            type="text"
                            id="kodikos"
                            class="form-control date-tall move-by-enter"
                        />
                    </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-4">
                    <div class="col-auto d-flex align-items-center gap-2">
                        <label for="only_apologistiko" class="col-form-label label-font-size mb-0">
                            Μόνο Απολογιστικό
                        </label>
                        <input
                            type="checkbox"
                            class="form-check-input custom-checkbox checkbox-class mt-0"
                            id="only_apologistiko"
                            name="only_apologistiko"
                            value=""
                        />
                    </div>

                    <div class="col-auto d-flex align-items-center gap-2">
                        <label for="only_nyxta" class="col-form-label label-font-size mb-0">
                            Μόνο Νύχτα
                        </label>
                        <input
                            type="checkbox"
                            class="form-check-input custom-checkbox checkbox-class mt-0"
                            id="only_nyxta"
                            name="only_nyxta"
                            value=""
                        />
                    </div>

                    <div class="col-auto d-flex align-items-center gap-2">
                        <label for="only_argia" class="col-form-label label-font-size mb-0">
                            Μόνο Αργία
                        </label>
                        <input
                            type="checkbox"
                            class="form-check-input custom-checkbox checkbox-class mt-0"
                            id="only_argia"
                            name="only_argia"
                            value=""
                        />
                    </div>

                    <div class="col-auto d-flex align-items-center gap-2">
                        <label for="only_yperergasia" class="col-form-label label-font-size mb-0">
                            Μόνο Υπερεργασία
                        </label>
                        <input
                            type="checkbox"
                            class="form-check-input custom-checkbox checkbox-class mt-0"
                            id="only_yperergasia"
                            name="only_yperergasia"
                            value=""
                        />
                    </div>
                </div>

                <div class="mb-4">
                    <button type="button" class="btn rounded-4 me-2 employment-review-action-btn employment-review-action-secondary" id="showMinimalReviewBtn">
                        Επιστροφή στον απλό έλεγχο
                    </button>
                    <button type="button" class="btn btn-brown rounded-4" id="searchBtn">
                        <i class="bi bi-search"></i>
                        Αναζήτηση
                    </button>

                    <button type="button" class="btn btn-brown rounded-4 ms-2" id="exportExcelBtn">
                        <i class="bi bi-file-earmark-excel"></i>
                        Export Excel
                    </button>

                    <button type="button" class="btn btn-brown rounded-4 ms-2" id="exportPdfBtn">
                        <i class="bi bi-file-earmark-pdf"></i>
                        Export PDF
                    </button>
                </div>
            </div>

            <div class="employment-review-scroll-container employment-review-scroll-container--advanced">
                <div id="policyPreviewGroupsContainer" class="mb-3"></div>

                <div class="table-responsive results-table-wrapper">
                    <table class="table table-bordered table-hover align-middle" id="resultsTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Ημ/νία</th>
                            <th>Παράρτημα</th>
                            <th>Κωδικός</th>
                            <!-- <th>Εργαζόμενος</th> -->
                            <th>Προδηλωμένο</th>
                            <th>Κάρτες</th>
                            <th>Απολογιστικό</th>
                            <th>Ώρες</th>
                            <th>Νύχτα</th>
                            <th>Αργία</th>
                            <th>Πρόσθ.</th>
                            <th>Υπερεργ.</th>
                            <th>Υπερωρ.</th>
                        </tr>
                    </thead>

                    <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card-footer">
            <a class="btn btn-brown rounded-4" href="/mainapp">
                <i class="bi bi-chevron-double-left"></i>
                Επιστροφή
            </a>
        </div>
    </div>

    <div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="d-flex align-items-center gap-2">
                        <h5 class="modal-title mb-0">Λεπτομέρειες Απασχόλησης</h5>
                        <span id="detailsLockBadge" class="review-lock-badge d-none">
                            🔒 LOCKED
                        </span>
                    </div>

                    <button
                        type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close"
                    ></button>
                </div>

                <div class="modal-body">
                    <div id="detailsContainer"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Κλείσιμο
                    </button>
                </div>
            </div>
        </div>
    </div>



    <div class="modal fade" id="pdfPreviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Προεπισκόπηση PDF</h5>
                    <div class="d-flex gap-2">

                        <button
                            type="button"
                            class="btn btn-brown rounded-4"
                            id="reviewPdfDownloadBtn"
                            data-no-loader="true">
                            <i class="bi bi-download"></i>
                            Αποθήκευση τοπικά
                        </button>

                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                </div>
                <div class="modal-body p-0">
                    <iframe id="reviewPdfFrame" title="Προεπισκόπηση PDF" style="width:100%;height:calc(100vh - 70px);border:0;"></iframe>
                </div>
            </div>
        </div>
    </div>
    </section>
    <% } %>
    <input
        type="hidden"
        id="canReviewEdit"
        value="<%= userRole === 'A' || userRole === 'S' ? '1' : '0' %>"
    />
    <input
        type="hidden"
        id="canRecordRepoTransferDecision"
        value="<%= canRecordRepoTransferDecision ? '1' : '0' %>"
    />
    <input
        type="hidden"
        id="canApplyRepoTransferDecision"
        value="<%= canApplyRepoTransferDecision ? '1' : '0' %>"
    />
    <input
        type="hidden"
        id="canUseAdvancedEmploymentReview"
        value="<%= canUseAdvancedEmploymentReview ? '1' : '0' %>"
    />

    <% if (canRecordRepoTransferDecision) { %>
        <script type="module" src="<%= script('ergazomenoi/programmata/initYpokatasthmataDropdowns.js') %>"></script>
    <% } %>
    <script src="<%= script('ergazomenoi/programmata/elegxosApasxolhseonPeriodoy') %>"></script>
</div>
