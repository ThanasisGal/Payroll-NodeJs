    </br>
</div>

<div class="container w-30">
	<form action="/dates/changeYear" method="POST">
    
		<%- include('../partials/_csrfField') %>

		<div class="card z-depth-5 mt-10">
			<div class="card-header">
				<label class="w-100 text-center"><h4>Αλλαγή έτους Χρήσης</h4></label>
			</div>
			<div class="card-body">
				<div class="row form-group g-3 align-items-center mt-2 mb-5">
