<%# ============================================================================
    Usage Report Page - CSP/CSRF Safe + Dashboard
    ============================================================================ %>

<style nonce="<%= nonce %>">
    .usage-page-wrap { max-width: 100%; }
    .usage-team-card { border-radius: 12px; overflow: hidden; }
    .usage-team-header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); }
    .usage-month-input { width: 10rem; }

    .usage-dashboard-swal {
        width: min(92vw, 1520px) !important;
        max-width: min(92vw, 1520px) !important;
        padding: 0 !important;
        margin: 0 auto !important;
        border-radius: 16px !important;
        overflow: hidden !important;
    }

    .usage-dashboard-title { font-size: 1.22rem; font-weight: 800; }
    .usage-dashboard-html { padding: 0 !important; margin: 0 !important; }

    .usage-dashboard-shell {
        background: #f4f6fb;
        max-height: 82vh;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 0.85rem;
    }

    .usage-dashboard-grid-kpi {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 0.65rem;
        margin-bottom: 0.75rem;
    }

    .usage-kpi-card {
        min-height: 4.05rem;
        transition: transform 180ms ease, box-shadow 180ms ease;
        border-radius: 14px;
        padding: 0.55rem 0.65rem;
        background: #ffffff;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        display: flex;
        align-items: center;
        gap: 0.55rem;
        min-width: 0;
    }

    .usage-kpi-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        flex: 0 0 auto;
        font-size: 1rem;
    }

    .usage-kpi-blue { background: linear-gradient(135deg, #2563eb, #06b6d4); }
    .usage-kpi-purple { background: linear-gradient(135deg, #7c3aed, #ec4899); }
    .usage-kpi-orange { background: linear-gradient(135deg, #f97316, #facc15); }
    .usage-kpi-green { background: linear-gradient(135deg, #059669, #84cc16); }
    .usage-kpi-red { background: linear-gradient(135deg, #dc2626, #fb7185); }
    .usage-kpi-dark { background: linear-gradient(135deg, #111827, #64748b); }



    .usage-kpi-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.14);
    }

    .usage-kpi-text { min-width: 0; }
    .usage-kpi-label {
        color: #64748b;
        font-size: 0.64rem;
        font-weight: 800;
        line-height: 1.05;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .usage-kpi-value {
        color: #0f172a;
        font-size: 0.95rem;
        font-weight: 900;
        line-height: 1.1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .usage-kpi-sub {
        color: #64748b;
        font-size: 0.66rem;
        font-weight: 700;
        line-height: 1.05;
        margin-top: 0.08rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .usage-dashboard-grid-main {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 0.8rem;
    }

    .usage-chart-card {
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        padding: 0.85rem;
    }

    .usage-chart-card-wide { grid-column: 1 / -1; }

    .usage-chart-title {
        color: #0f172a;
        font-size: 0.86rem;
        font-weight: 900;
        margin-bottom: 0.55rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .usage-bars { display: flex; flex-direction: column; gap: 0.48rem; }

    .usage-bar-row {
        display: grid;
        grid-template-columns: minmax(9rem, 16rem) minmax(0, 1fr) minmax(4.5rem, 6rem);
        align-items: center;
        gap: 0.65rem;
    }

    .usage-bar-label {
        color: #1f2937;
        font-size: 0.76rem;
        font-weight: 850;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .usage-bar-track {
        height: 0.82rem;
        background: #e5e7eb;
        border-radius: 999px;
        overflow: hidden;
    }

    .usage-bar-fill { height: 100%; border-radius: 999px; width: 0%; transition: width 850ms cubic-bezier(0.22, 1, 0.36, 1); }
    .usage-bar-blue { background: linear-gradient(90deg, #2563eb, #06b6d4); }
    .usage-bar-green { background: linear-gradient(90deg, #059669, #84cc16); }
    .usage-bar-purple { background: linear-gradient(90deg, #7c3aed, #ec4899); }
    .usage-bar-orange { background: linear-gradient(90deg, #f97316, #facc15); }
    .usage-bar-red { background: linear-gradient(90deg, #dc2626, #fb7185); }

    .usage-bar-value {
        color: #334155;
        font-size: 0.73rem;
        font-weight: 850;
        text-align: right;
        white-space: nowrap;
    }

    .usage-donut-wrap {
        display: grid;
        grid-template-columns: minmax(18rem, 22rem) minmax(0, 1fr);
        align-items: center;
        gap: 1.15rem;
        min-height: 20rem;
    }

    .usage-donut-svg { width: 19rem; height: 19rem; }
    .usage-donut-bg { fill: none; stroke: #e5e7eb; stroke-width: 16; }
    .usage-donut-segment { fill: none; stroke-width: 16; stroke-linecap: butt; transform: rotate(-90deg); transform-origin: 50% 50%; }
    .usage-donut-hole { fill: #ffffff; }
    .usage-donut-center-main { font-size: 1.25rem; font-weight: 900; fill: #0f172a; text-anchor: middle; dominant-baseline: middle; }
    .usage-donut-center-sub { font-size: 0.62rem; font-weight: 800; fill: #64748b; text-anchor: middle; dominant-baseline: middle; }

    .usage-team-insights {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.45rem;
        margin-top: 0.75rem;
    }

    .usage-insight-pill {
        border-radius: 12px;
        padding: 0.55rem 0.65rem;
        background: #f8fafc;
        color: #334155;
        font-size: 0.72rem;
        font-weight: 800;
    }

    .usage-insight-pill strong { color: #0f172a; }

    .usage-legend { display: flex; flex-direction: column; gap: 0.45rem; }

    .usage-legend-row {
        display: grid;
        grid-template-columns: 0.8rem minmax(0, 1fr) auto;
        gap: 0.45rem;
        align-items: center;
        color: #334155;
        font-size: 0.78rem;
        font-weight: 750;
    }

    .usage-legend-dot { width: 0.7rem; height: 0.7rem; border-radius: 50%; }
    .usage-legend-color-0 { background: #2563eb; }
    .usage-legend-color-1 { background: #7c3aed; }
    .usage-legend-color-2 { background: #f97316; }
    .usage-legend-color-3 { background: #059669; }
    .usage-legend-color-4 { background: #dc2626; }
    .usage-legend-color-5 { background: #06b6d4; }
    .usage-legend-color-6 { background: #facc15; }
    .usage-legend-color-7 { background: #ec4899; }



    .usage-line-chart-wrap {
        width: 100%;
        min-height: 13.5rem;
    }

    .usage-line-svg {
        width: 100%;
        height: 13.5rem;
        display: block;
        overflow: visible;
    }

    .usage-line-grid { stroke: #e5e7eb; stroke-width: 1; }
    .usage-line-axis { stroke: #cbd5e1; stroke-width: 1; }
    .usage-line-blue { fill: none; stroke: #2563eb; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    .usage-line-green { fill: none; stroke: #059669; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    .usage-area-blue { fill: #2563eb; opacity: 0.09; }
    .usage-area-green { fill: #059669; opacity: 0.09; }
    .usage-line-dot-blue { fill: #2563eb; stroke: #ffffff; stroke-width: 2; }
    .usage-line-dot-green { fill: #059669; stroke: #ffffff; stroke-width: 2; }
    .usage-line-label { fill: #334155; font-size: 0.64rem; font-weight: 800; }
    .usage-line-xlabel { fill: #64748b; font-size: 0.58rem; font-weight: 700; }
    .usage-line-ylabel { fill: #94a3b8; font-size: 0.56rem; font-weight: 700; }

    .usage-analytics-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 0.8rem;
    }

    .usage-compact-bars {
        display: flex;
        flex-direction: column;
        gap: 0.42rem;
    }

    .usage-compact-row {
        display: grid;
        grid-template-columns: minmax(4.2rem, 5.8rem) minmax(0, 1fr) minmax(3.5rem, 5rem);
        gap: 0.55rem;
        align-items: center;
    }

    .usage-compact-label {
        color: #334155;
        font-size: 0.68rem;
        font-weight: 850;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .usage-compact-value {
        color: #475569;
        font-size: 0.66rem;
        font-weight: 850;
        text-align: right;
        white-space: nowrap;
    }

    .usage-heatmap {
        display: grid;
        grid-template-columns: repeat(31, minmax(0.35rem, 1fr));
        gap: 0.16rem;
        align-items: end;
    }

    .usage-heat-cell {
        height: 1.05rem;
        border-radius: 4px;
        background: #e5e7eb;
        border: 0;
        padding: 0;
        appearance: none;
        -webkit-appearance: none;
    }

    .usage-heat-0 { background: #e5e7eb; }
    .usage-heat-1 { background: #bfdbfe; }
    .usage-heat-2 { background: #60a5fa; }
    .usage-heat-3 { background: #2563eb; }
    .usage-heat-4 { background: #1d4ed8; }
    .usage-heat-5 { background: #1e40af; }

