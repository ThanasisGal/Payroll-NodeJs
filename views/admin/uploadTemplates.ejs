<%# ============================================================================ Upload Templates
Page Content only - no wrapper divs
============================================================================ %>

<h1>📤 Upload Text Templates</h1>

<div class="upload-card">
    <div class="info-box">
        <h4>ℹ️ Οδηγίες</h4>
        <div class="info-columns">
            <ul>
                <li><strong>Group / Team & Εταιρεία:</strong> Προσυμπληρωμένα</li>
                <li><strong>Φάκελος:</strong> symbash, anhlikoi, allodapoi κλπ</li>
                <li><strong>Ειδική Κατηγορία Prefix:</strong> ΞΕΝΟΔΟΧΟΫΠΑΛΛΗΛΟΙ κλπ</li>
            </ul>
            <ul>
                <li><strong>Αρχεία:</strong> .txt αρχεία, UTF-8, max 1MB</li>
                <li><strong>Αποθήκευση:</strong> txt/team/company/category/prefix/</li>
            </ul>
        </div>
    </div>

    <div id="alertContainer" class="alert-container-fixed"></div>

    <form id="uploadForm" data-no-loader>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="form-row">
            <div class="form-group">
                <label for="team">Team *</label>
                <input
                    type="text"
                    id="team"
                    name="team"
                    class="form-control"
                    value="<%= sessionTeam %>"
                    readonly
                    required
                />
            </div>

            <div class="form-group">
                <label for="companyDisplay">Company *</label>

                <input type="hidden" id="company" name="company" value="<%= companyId %>" />

                <input type="hidden" id="companyKod" name="companyKod" value="<%= companyKod %>" />

                <input
                    type="hidden"
                    id="companyName"
                    name="companyName"
                    value="<%= companyName %>"
                />

                <input
                    type="text"
                    id="companyDisplay"
                    class="form-control"
                    value="<%= companyKod %> - <%= companyName %>"
                    readonly
                    title="Company: <%= companyName %>"
                />

                <small class="helper-text">
                    📁 Upload to: txt/<%= sessionTeam %>/<%= companyKod %>_<%= companyName %>/<span
                        id="categoryPreview"
                        >category</span
                    >/<span id="prefixPathPreview">prefix</span>/
                </small>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="category">Φάκελος *</label>
                <select id="category" name="category" class="form-control" required>
                    <option value="">-- Επίλεξε Κατηγορία / Φάκελο --</option>
                    <option value="symbash">Συμβάσεις (symbash)</option>
                    <option value="anhlikoi">Ανήλικοι (anhlikoi)</option>
                    <option value="allodapoi">Αλλοδαποί (allodapoi)</option>
                    <option value="prosopikoReqsUpdate">Προσωπικά (prosopikoReqsUpdate)</option>
                    <option value="apolysh">Απόλυση (apolysh)</option>
                </select>
            </div>

            <div class="form-group">
                <label for="prefix">Ειδική Κατηγορία (Prefix) *</label>
                <select id="prefix" name="prefix" class="form-control" required>
                    <option value="">-- Επίλεξε Prefix --</option>
                    <option value="_GENIKOI_OROI_">ΓΕΝΙΚΟΙ ΟΡΟΙ</option>
                    <option value="_FRONTISTHRIA_">ΦΡΟΝΤΙΣΤΗΡΙΑ</option>
                    <option value="_IDIOTIKA_SXOLEIA_">ΙΔΙΩΤΙΚΑ ΣΧΟΛΕΙΑ</option>
                    <option value="_DIANOMEIS_">ΔΙΑΝΟΜΕΙΣ</option>
                    <option value="_ODHGOI_FORTHGON_">ΟΔΗΓΟΙ ΦΟΡΤΗΓΩΝ</option>
                    <option value="_ODHGOI_TOYRISTIKON_">ΟΔΗΓΟΙ ΤΟΥΡΙΣΤΙΚΩΝ</option>
                    <option value="_ODHGOI_TAXI_">ΟΔΗΓΟΙ ΤΑΞΙ</option>
                    <option value="_XENAGOI_">ΞΕΝΑΓΟΙ</option>
                    <option value="_NAYTIKOI_">ΝΑΥΤΙΚΟΙ</option>
                    <option value="_HOTEL_">ΞΕΝΟΔΟΧΟΫΠΑΛΛΗΛΟΙ</option>
                    <option value="_OIKODOMOI_">ΟΙΚΟΔΟΜΟΙ</option>
                    <option value="_OIKIAKO_PROSOPIKO_">ΟΙΚΙΑΚΟ ΠΡΟΣΩΠΙΚΟ</option>
                    <option value="_ANHLIKOI_">ΑΝΗΛΙΚΟΙ</option>
                    <option value="_THEAMA_AKROAMA_">ΘΕΑΜΑ & ΑΚΡΟΑΜΑ</option>
                    <option value="_SYNTAXIOYXOI_">ΣΥΝΤΑΞΙΟΥΧΟΙ</option>
                    <option value="_IATROI_ME_SYMBASH_">ΙΑΤΡΟΙ ΜΕ ΣΥΜΒΑΣΗ</option>
                    <option value="_IATROI_APY_">ΙΑΤΡΟΙ ΜΕ ΑΠΥ</option>
                    <option value="_ERGAZOMENOI_MONO_TH_NYXTA_">ΝΥΧΤΕΡΙΝΕΣ ΩΡΕΣ</option>
                    <option value="_HOTEL_EGSSE_">ΞΕΝΟΔΟΧΟΫΠΑΛΛΗΛΟΙ με Ε.Γ.Σ.Σ.Ε.</option>
                </select>

                <small class="helper-text">
                    Preview: <strong id="filenamePreview">PREFIX_0001.txt</strong>
                </small>
            </div>
        </div>

        <div class="form-group">
            <label>
                Επιλογή Αρχείων *
                <span class="file-count-badge" id="fileCountBadge" style="display: none"
                    >0 files</span
                >
            </label>

            <div class="file-input-wrapper">
                <button type="button" class="file-input-button" id="fileSelectBtn">
                    📁 Επιλέξτε τα .txt Αρχεία
                </button>

                <input type="file" id="fileInput" name="files" accept=".txt" multiple />
            </div>

            <small class="helper-text">
                Επιλέξτε πολλαπλά αρχεία (Ctrl/Cmd + Click). Μέγιστο μέγεθος: 1MB ανά αρχείο.
            </small>
        </div>

        <div id="fileList" class="file-list">
            <div class="empty-state">Δεν έχουν επιλεγεί αρχεία</div>
        </div>

        <div class="progress-container-fixed">
            <div class="progress-bar" id="progressBar">
                <div class="progress-fill" id="progressFill">0%</div>
            </div>
        </div>

        <div style="display: flex; gap: 10px; margin-top: 15px">
            <button type="submit" class="btn btn-upload" id="uploadBtn" disabled>
                🚀 Upload Templates
            </button>

            <button type="button" class="btn btn-secondary" id="closeBtn">❌ Κλείσιμο</button>
        </div>
    </form>
</div>

<script nonce="<%= nonce %>">
    (function () {
        'use strict';

        const fileInput = document.getElementById('fileInput');
        const fileSelectBtn = document.getElementById('fileSelectBtn');
        const fileList = document.getElementById('fileList');
        const uploadBtn = document.getElementById('uploadBtn');
        const uploadForm = document.getElementById('uploadForm');
        const progressBar = document.getElementById('progressBar');
        const progressFill = document.getElementById('progressFill');
        const alertContainer = document.getElementById('alertContainer');
        const fileCountBadge = document.getElementById('fileCountBadge');

        const categorySelect = document.getElementById('category');
        const prefixSelect = document.getElementById('prefix');
        const categoryPreview = document.getElementById('categoryPreview');
        const prefixPathPreview = document.getElementById('prefixPathPreview');
        const filenamePreview = document.getElementById('filenamePreview');

        let selectedFiles = [];

        const closeBtn = document.getElementById('closeBtn');
        if (closeBtn) {
            closeBtn.addEventListener('click', function () {
                window.location.href = '/mainapp';
            });
        }

        if (fileSelectBtn) {
            fileSelectBtn.addEventListener('click', function () {
                fileInput.click();
            });
        }

        categorySelect.addEventListener('change', updatePreviews);
        prefixSelect.addEventListener('change', updatePreviews);

        function updatePreviews() {
            const category = categorySelect.value || 'category';
            const prefix = prefixSelect.value || 'prefix';

            categoryPreview.textContent = category;
            prefixPathPreview.textContent = prefix;
            filenamePreview.textContent = prefixSelect.value
                ? prefixSelect.value + '0001.txt'
                : 'PREFIX_0001.txt';
        }

        fileInput.addEventListener('change', function (e) {
            const files = Array.from(e.target.files);

            files.forEach(function (file) {
                if (!file.name.endsWith('.txt')) {
                    showAlert('Μόνο .txt αρχεία επιτρέπονται!', 'error');
                    return;
                }

                if (file.size > 1024 * 1024) {
                    showAlert('Το αρχείο ' + file.name + ' είναι πολύ μεγάλο (max 1MB)', 'error');
                    return;
                }

                if (!file.name.match(/^_[A-Z0-9_]+_\d{4}\.txt$/)) {
                    showAlert(
                        'Λάθος format: ' + file.name + '. Αναμενόμενο: _PREFIX_XXXX.txt',
                        'error'
                    );
                    return;
                }

                const exists = selectedFiles.some(function (f) {
                    return f.name === file.name;
                });

                if (!exists) {
                    selectedFiles.push(file);
                }
            });

            renderFileList();
            updateUploadButton();
        });

        function renderFileList() {
            if (selectedFiles.length === 0) {
                fileList.innerHTML = '<div class="empty-state">Δεν έχουν επιλεγεί αρχεία</div>';

                if (fileCountBadge) {
                    fileCountBadge.style.display = 'none';
                    fileCountBadge.textContent = '0 files';
                }

                return;
            }

            if (fileCountBadge) {
                fileCountBadge.style.display = 'inline-block';
                fileCountBadge.textContent = selectedFiles.length + ' files';
            }

            const html = selectedFiles
                .map(function (file, index) {
                    const sizeKB = (file.size / 1024).toFixed(2);

                    return `
                <div class="file-item" data-index="${index}">
                    <div class="file-info">
                        <div class="file-name">📄 ${escapeHtml(file.name)}</div>
                        <div class="file-meta">${sizeKB} KB</div>
                    </div>
                    <div class="file-actions">
                        <button type="button"
                            class="btn btn-preview"
                            data-action="preview"
                            data-index="${index}">
                            👁️ Preview
                        </button>
                        <button type="button"
                            class="btn btn-remove"
                            data-action="remove"
                            data-index="${index}">
                            ❌ Remove
                        </button>
                    </div>
                </div>
            `;
                })
                .join('');

            fileList.innerHTML = html;

            fileList.querySelectorAll('[data-action]').forEach(function (btn) {
                btn.addEventListener('click', handleFileAction);
            });
        }

        function handleFileAction(e) {
            const action = e.currentTarget.getAttribute('data-action');
            const index = parseInt(e.currentTarget.getAttribute('data-index'), 10);

            if (action === 'preview') {
                previewFile(index);
            } else if (action === 'remove') {
                removeFile(index);
            }
        }

        function previewFile(index) {
            const file = selectedFiles[index];
            const reader = new FileReader();

            reader.onload = function (e) {
                const text = e.target.result;
                const preview = text.length > 500 ? text.substring(0, 500) + '...' : text;
                alert('Preview: ' + file.name + '\n\n' + preview);
            };

            reader.onerror = function () {
                showAlert('Σφάλμα κατά την ανάγνωση του αρχείου', 'error');
            };

            reader.readAsText(file);
        }

        function removeFile(index) {
            selectedFiles.splice(index, 1);
            renderFileList();
            updateUploadButton();
        }

        function updateUploadButton() {
            uploadBtn.disabled = selectedFiles.length === 0;
        }

        function showAlert(message, type) {
            type = type || 'success';

            const alertClass = type === 'success' ? 'alert-success' : 'alert-error';

            alertContainer.innerHTML =
                '<div class="alert ' + alertClass + '">' + escapeHtml(message) + '</div>';

            setTimeout(function () {
                alertContainer.innerHTML = '';
            }, 5000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        uploadForm.addEventListener('submit', async function (e) {
            e.preventDefault();

            if (selectedFiles.length === 0) {
                showAlert('Παρακαλώ επίλεξε αρχεία', 'error');
                return;
            }

            const team = document.getElementById('team').value;
            const company = document.getElementById('company').value;
            const companyKod = document.getElementById('companyKod').value;
            const companyName = document.getElementById('companyName').value;
            const category = document.getElementById('category').value;
            const prefix = document.getElementById('prefix').value;
            const csrfToken = document.querySelector('input[name="_csrf"]').value;

            if (!category) {
                showAlert('Παρακαλώ επίλεξε κατηγορία', 'error');
                return;
            }

            if (!prefix) {
                showAlert('Παρακαλώ επίλεξε prefix', 'error');
                return;
            }

            progressBar.classList.add('active');
            uploadBtn.disabled = true;

            try {
                const formData = new FormData();

                selectedFiles.forEach(function (file) {
                    formData.append('files', file);
                });

                formData.append('team', team);
                formData.append('company', company);
                formData.append('companyKod', companyKod);
                formData.append('companyName', companyName);
                formData.append('category', category);
                formData.append('prefix', prefix);

                progressFill.style.width = '50%';
                progressFill.textContent = '50% - Uploading...';

                const response = await fetch('/api/admin/templates/upload', {
                    method: 'POST',
                    headers: {
                        'csrf-token': csrfToken
                    },
                    body: formData
                });

                const result = await response.json();

                progressFill.style.width = '100%';
                progressFill.textContent = '100% - Complete!';

                setTimeout(function () {
                    progressBar.classList.remove('active');
                    progressFill.style.width = '0';
                    uploadBtn.disabled = false;

                    if (result.success) {
                        showAlert(`✅ Successfully uploaded ${result.uploaded} files!`, 'success');

                        selectedFiles = [];
                        renderFileList();
                        updateUploadButton();
                        fileInput.value = '';
                    } else {
                        const errors = Array.isArray(result.errors) ? result.errors : [];
                        const errorMsg =
                            `⚠️ Uploaded ${result.uploaded || 0} files, ${result.failed || 0} failed:\n` +
                            errors.map((e) => e.filename + ': ' + e.error).join('\n');

                        showAlert(errorMsg, 'error');
                    }
                }, 1000);
            } catch (error) {
                console.error('❌ Upload error:', error);

                progressBar.classList.remove('active');
                progressFill.style.width = '0';
                uploadBtn.disabled = false;

                showAlert('❌ Upload failed: ' + error.message, 'error');
            }
        });

        updatePreviews();
    })();
</script>
