<%# ============================================================================
    Upload Templates Page
    Content only - no wrapper divs
    ============================================================================ %>

<h1>📤 Upload Text Templates</h1>

<div class="upload-card">
    <div class="info-box">
        <h4>ℹ️ Οδηγίες</h4>
        <div class="info-columns">
            <ul>
                <li><strong>Group / Team & Εταιρεία:</strong> Προσυμπληρωμένα</li>
                <li><strong>Φάκελος:</strong> symbash, anhlikoi, allodapoi κλπ</li>
                <li><strong>Ειδική Κατηγορία (Prefix):</strong> ΞΕΝΟΔΟΧΟΫΠΑΛΛΗΛΟΙ ΚΛΠ</li>
            </ul>
            <ul>
                <li><strong>Αρχεία:</strong> .txt αρχεία, UTF-8, max 1MB</li>
                <li><strong>Μετονομασία:</strong> PREFIX_0001.txt, ...</li>
            </ul>
        </div>
    </div>
    
    <!-- ✅ Fixed Alert Container -->
    <div id="alertContainer" class="alert-container-fixed">
        <!-- Alerts will appear here -->
    </div>
    
    <form id="uploadForm" data-no-loader>
        <%# CSRF Token %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <%# Row 1: Team & Company %>
        <div class="form-row">
            <div class="form-group">
                <label for="team">Team *</label>
                <input type="text" 
                    id="team" 
                    name="team" 
                    class="form-control" 
                    value="<%= sessionTeam %>" 
                    readonly 
                    required>
            </div>
            
            <div class="form-group">
                <label for="companyDisplay">Company *</label>
                
                <%# ✅ FIXED: Hidden field με id για JavaScript %>
                <input type="hidden" 
                    id="company"
                    name="company" 
                    value="<%= companyId %>">
                
                <%# Display field %>
                <input type="text" 
                    id="companyDisplay" 
                    class="form-control" 
                    value="<%= companyKod %> - <%= companyName %>" 
                    readonly 
                    title="Company: <%= companyName %>">
                
                <small class="helper-text">
                    📁 Upload to: txt/<%= sessionTeam %>/<%= companyKod %>_<company_name>/<category>/
                </small>
            </div>
        </div>        

        <%# Row 2: Category & Prefix %>
        <div class="form-row">
            <div class="form-group">
                <label for="category">Φάκελος *</label>
                <select id="category" name="category" class="form-control" required>
                    <option value="">-- Επίλεξε Κατηγορία / Φάκελο --</option>
                    <option value="symbash">Συμβάσεις (symbash)</option>
                    <option value="anhlikoi">Ανήλικοι (anhlikoi)</option>
                    <option value="allodapoi">Αλλοδαποί (allodapoi)</option>
                    <option value="prosopikoReqsUpdate">Προσωπικά (prosopikoReqsUpdate)</option>
                    <option value="apolysh">Απόλυση (apolysh)</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="prefix">Ειδική Κατηγορία (Prefix) *</label>
                <select id="prefix" name="prefix" class="form-control" required>
                    <option value="">-- Επίλεξε Prefix --</option>
                    <option value="_GENIKOI_OROI_">ΓΕΝΙΚΟΙ ΟΡΟΙ</option>
                    <option value="_FRONTISTHRIA_">ΦΡΟΝΤΙΣΤΗΡΙΑ</option>
                    <option value="_IDIOTIKA_SXOLEIA_">ΙΔΙΩΤΙΚΑ ΣΧΟΛΕΙΑ</option>
                    <option value="_DIANOMEIS_">ΔΙΑΝΟΜΕΙΣ</option>
                    <option value="_ODHGOI_FORTHGON_">ΟΔΗΓΟΙ ΦΟΡΤΗΓΩΝ</option>
                    <option value="_ODHGOI_TOYRISTIKON_">ΟΔΗΓΟΙ ΤΟΥΡΙΣΤΙΚΩΝ</option>
                    <option value="_ODHGOI_TAXI_">ΟΔΗΓΟΙ ΤΑΞΙ</option>
                    <option value="_XENAGOI_">ΞΕΝΑΓΟΙ</option>
                    <option value="_NAYTIKOI_">ΝΑΥΤΙΚΟΙ</option>
                    <option value="_HOTEL_">ΞΕΝΟΔΟΧΟΫΠΑΛΛΗΛΟΙ</option>
                    <option value="_OIKODOMOI_">ΟΙΚΟΔΟΜΟΙ</option>
                    <option value="_OIKIAKO_PROSOPIKO_">ΟΙΚΙΑΚΟ ΠΡΟΣΩΠΙΚΟ</option>
                    <option value="_ANHLIKOI_">ΑΝΗΛΙΚΟΙ</option>
                    <option value="_THEAMA_AKROAMA_">ΘΕΑΜΑ & ΑΚΡΟΑΜΑ</option>
                    <option value="_SYNTAXIOYXOI_">ΣΥΝΤΑΞΙΟΥΧΟΙ</option>
                    <option value="_IATROI_ME_SYMBASH_">ΙΑΤΡΟΙ ΜΕ ΣΥΜΒΑΣΗ</option>
                    <option value="_IATROI_APY_">ΙΑΤΡΟΙ ΜΕ ΑΠΥ</option>
                    <option value="_ERGAZOMENOI_MONO_TH_NYXTA_">ΝΥΧΤΕΡΙΝΕΣ ΩΡΕΣ</option>
                </select>
                <small class="helper-text">
                    Preview: <strong id="filenamePreview">PREFIX_0001.txt</strong>
                </small>
            </div>
        </div>
        
        <%# Row 3: File Selection %>
        <div class="form-group">
            <label>
                Επιλογή Αρχείων * 
                <span class="file-count-badge" id="fileCountBadge" style="display:none;">0 files</span>
            </label>
            <div class="file-input-wrapper">
                <button type="button" class="file-input-button" id="fileSelectBtn">
                    📁 Επιλέξτε τα .txt Αρχεία
                </button>
                <input type="file" 
                       id="fileInput" 
                       name="files" 
                       accept=".txt" 
                       multiple>
            </div>
            <small class="helper-text">
                Επιλέξτε πολλαπλά αρχεία (Ctrl/Cmd + Click). Μέγιστο μέγεθος: 1MB ανά αρχείο.
            </small>
        </div>
        
        <%# File List %>
        <div id="fileList" class="file-list">
            <div class="empty-state">Δεν έχουν επιλεγεί αρχεία</div>
        </div>
        
        <%# Fixed Progress Bar Container %>
        <div class="progress-container-fixed">
            <div class="progress-bar" id="progressBar">
                <div class="progress-fill" id="progressFill">0%</div>
            </div>
        </div>
        
        <%# Submit Buttons %>
        <div style="display: flex; gap: 10px; margin-top: 15px;">
            <button type="submit" 
                    class="btn btn-upload" 
                    id="uploadBtn" 
                    disabled>
                🚀 Upload Templates
            </button>
            
            <button type="button" 
                    class="btn btn-secondary" 
                    id="closeBtn">
                ❌ Κλείσιμο
            </button>
        </div>
    </form>
</div>

<%# JavaScript %>
<script nonce="<%= nonce %>">
(function() {
    'use strict';
        // ✅ DOM Elements
        const fileInput = document.getElementById('fileInput');
        const fileList = document.getElementById('fileList');
        const uploadBtn = document.getElementById('uploadBtn');
        const uploadForm = document.getElementById('uploadForm');
        const progressBar = document.getElementById('progressBar');
        const progressFill = document.getElementById('progressFill');
        const alertContainer = document.getElementById('alertContainer');
        
        let selectedFiles = [];
        
        // ============================================================================
        // Close Button Handler
        // ============================================================================
        const closeBtn = document.getElementById('closeBtn');
        if (closeBtn) {
            closeBtn.addEventListener('click', function() {
                window.location.href = '/mainapp';
            });
        }
        
        // ============================================================================
        // File Selection Handler
        // ============================================================================
        fileInput.addEventListener('change', function(e) {
            const files = Array.from(e.target.files);
            
            files.forEach(function(file) {
                // Validation: .txt only
                if (!file.name.endsWith('.txt')) {
                    showAlert('Μόνο .txt αρχεία επιτρέπονται!', 'error');
                    return;
                }
                
                // Validation: Max 1MB
                if (file.size > 1024 * 1024) {
                    showAlert('Το αρχείο ' + file.name + ' είναι πολύ μεγάλο (max 1MB)', 'error');
                    return;
                }
                
                // Validation: Filename format
                if (!file.name.match(/^_[A-Z0-9_]+_\d{4}\.txt$/)) {
                    showAlert('Λάθος format: ' + file.name + '. Αναμενόμενο: _PREFIX_XXXX.txt', 'error');
                    return;
                }
                
                // Add to list if not duplicate
                const exists = selectedFiles.some(function(f) {
                    return f.name === file.name;
                });
                
                if (!exists) {
                    selectedFiles.push(file);
                }
            });
            
            renderFileList();
            updateUploadButton();
        });
        
        // ============================================================================
        // Render File List
        // ============================================================================
        function renderFileList() {
            if (selectedFiles.length === 0) {
                fileList.innerHTML = '<div class="empty-state">Δεν έχουν επιλεγεί αρχεία</div>';
                return;
            }
            
            const html = selectedFiles.map(function(file, index) {
                const sizeKB = (file.size / 1024).toFixed(2);
                return `
                    <div class="file-item" data-index="${index}">
                        <div class="file-info">
                            <div class="file-name">📄 ${escapeHtml(file.name)}</div>
                            <div class="file-meta">${sizeKB} KB</div>
                        </div>
                        <div class="file-actions">
                            <button type="button" 
                                    class="btn btn-preview" 
                                    data-action="preview"
                                    data-index="${index}">
                                👁️ Preview
                            </button>
                            <button type="button" 
                                    class="btn btn-remove" 
                                    data-action="remove"
                                    data-index="${index}">
                                ❌ Remove
                            </button>
                        </div>
                    </div>
                `;
            }).join('');
            
            fileList.innerHTML = html;
            
            // ✅ Event delegation για buttons (CSP-safe)
            fileList.querySelectorAll('[data-action]').forEach(function(btn) {
                btn.addEventListener('click', handleFileAction);
            });
        }
        
        // ============================================================================
        // Handle File Actions (Preview / Remove)
        // ============================================================================
        function handleFileAction(e) {
            const action = e.currentTarget.getAttribute('data-action');
            const index = parseInt(e.currentTarget.getAttribute('data-index'), 10);
            
            if (action === 'preview') {
                previewFile(index);
            } else if (action === 'remove') {
                removeFile(index);
            }
        }
        
        // ============================================================================
        // Preview File
        // ============================================================================
        function previewFile(index) {
            const file = selectedFiles[index];
            const reader = new FileReader();
            
            reader.onload = function(e) {
                const text = e.target.result;
                const preview = text.length > 500 ? text.substring(0, 500) + '...' : text;
                alert('Preview: ' + file.name + '\n\n' + preview);
            };
            
            reader.onerror = function() {
                showAlert('Σφάλμα κατά την ανάγνωση του αρχείου', 'error');
            };
            
            reader.readAsText(file);
        }
        
        // ============================================================================
        // Remove File
        // ============================================================================
        function removeFile(index) {
            selectedFiles.splice(index, 1);
            renderFileList();
            updateUploadButton();
        }
        
        // ============================================================================
        // Update Upload Button State
        // ============================================================================
        function updateUploadButton() {
            uploadBtn.disabled = selectedFiles.length === 0;
        }
        
        // ============================================================================
        // Show Alert
        // ============================================================================
        function showAlert(message, type) {
            type = type || 'success';
            const alertClass = type === 'success' ? 'alert-success' : 'alert-error';
            
            alertContainer.innerHTML = '<div class="alert ' + alertClass + '">' + 
                                      escapeHtml(message) + 
                                      '</div>';
            
            setTimeout(function() {
                alertContainer.innerHTML = '';
            }, 5000);
        }
        
        // ============================================================================
        // Escape HTML (XSS Protection)
        // ============================================================================
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // ============================================================================
        // Form Submission
        // ============================================================================
        uploadForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            if (selectedFiles.length === 0) {
                showAlert('Παρακαλώ επίλεξε αρχεία', 'error');
                return;
            }
            
            const team = document.getElementById('team').value;
            const company = document.querySelector('input[name="company"]').value;
            const category = document.getElementById('category').value;
            const csrfToken = document.querySelector('input[name="_csrf"]').value;
            
            if (!category) {
                showAlert('Παρακαλώ επίλεξε κατηγορία', 'error');
                return;
            }
            
            // Show progress
            progressBar.classList.add('active');
            uploadBtn.disabled = true;
            
            try {
                const formData = new FormData();
                
                // ✅ Append ALL files at once
                selectedFiles.forEach(function(file) {
                    formData.append('files', file);
                });
                
                // ✅ Append metadata once
                formData.append('team', team);
                formData.append('company', company);
                formData.append('category', category);
                
                // Show progress
                progressFill.style.width = '50%';
                progressFill.textContent = '50% - Uploading...';
                
                // ✅ Single fetch request
                const response = await fetch('/api/admin/templates/upload', {
                    method: 'POST',
                    headers: {
                        'csrf-token': csrfToken
                    },
                    body: formData
                });
                
                const result = await response.json();
                
                // Update progress to 100%
                progressFill.style.width = '100%';
                progressFill.textContent = '100% - Complete!';
                
                setTimeout(function() {
                    progressBar.classList.remove('active');
                    progressFill.style.width = '0';
                    uploadBtn.disabled = false;
                    
                    if (result.success) {
                        showAlert(`✅ Successfully uploaded ${result.uploaded} files!`, 'success');
                        selectedFiles = [];
                        renderFileList();
                        updateUploadButton();
                        fileInput.value = '';
                    } else {
                        const errorMsg = `⚠️ Uploaded ${result.uploaded} files, ${result.failed} failed:\n` + 
                                    result.errors.map(e => e.filename + ': ' + e.error).join('\n');
                        showAlert(errorMsg, 'error');
                    }
                }, 1000);
                
            } catch (error) {
                console.error('❌ Upload error:', error);
                progressBar.classList.remove('active');
                progressFill.style.width = '0';
                uploadBtn.disabled = false;
                showAlert('❌ Upload failed: ' + error.message, 'error');
            }
        });
        
    })();
</script>