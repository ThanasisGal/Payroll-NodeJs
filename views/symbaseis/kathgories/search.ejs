<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-5  mb-3 border-bottom bg-hero-cdn">
    <form
        class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0">

        <%- include('../../partials/_csrfField') %>
    </form>
</div>

<div class="card d-flex flex-column z-depth-5 w-92 margin-left-percent-4 overflow-hidden">
	<% 
		const symbCode = (typeof symbash_stathera !== 'undefined' ? symbash_stathera : '');
		const symbDesc = (typeof symbash !== 'undefined' && symbash && (symbash.perigrafh)) || '';
	%>	

	<div class="card-header p-0 height-rem-3_5">
        <label class="text-center w-100 headers-content mt-2"> 
            <% if (sTerm && sTerm.length > 0) { %>
                Εμφάνιση Κατηγοριών Συμβάσεων ( με κριτήριο αναζήτησης "<%= sTerm %>" )
            <% } else { %>
                Εμφάνιση Κατηγοριών Συμβάσεων
            <% } %>
        </label>
	</div>
	<div class="row form-group g-3 align-items-center">
		<div>
			<% if (symbCode || symbDesc) { %>
				<div class="px-3 pb-2 pt-1 d-flex align-items-center gap-2">
					<span class="badge bg-secondary">Σύμβαση</span>
					<span class="fw-semibold"><%= symbCode %></span>
					<% if (symbDesc) { %>
						<span class="text-muted">— <%= symbDesc %></span>
					<% } %>
				</div>
			<% } %>
	    </div>
	</div>

	<div class="card-body p-0 overflow-auto flex-grow-1 bg-white height-vh-58">
		<table class="table table-striped table-bordered table-sm table-hover" id="kathgories">
			<thead class="backgroundColor-brown font-size-rem-1_1 center-align">
				<tr class="color-brown">
				<th scope="col" class="col-1">Κωδ.</th>
				<th scope="col" class="col-11">Περιγραφή</th>
				</tr>
			</thead>

			<tbody>
				<% if (kathgoriesSymbaseonFilteredRecs && kathgoriesSymbaseonFilteredRecs.length) { %>
					<% kathgoriesSymbaseonFilteredRecs.forEach(el => { %>
						<tr class="input-content-regular" data-id="<%= el._id %>">
						<td class="col-1 padding-left-rem-0_5"><%- el.kodikos %></td>
						<td class="col-11"><%- el.perigrafh %></td>
						</tr>
					<% }) %>
				<% } else { %>
					<tr>
						<td colspan="2" class="text-center text-muted py-4">
						Δεν βρέθηκαν Κατηγορίες Συμβάσεων για το κριτήριο "<%= sTerm %>"
						</td>
					</tr>
				<% } %>
			</tbody>
		</table>
	</div>

    <div class="card-footer cardFooter">
        <div class="d-inline-block d-flex cardFooter01">
            <div class="d-flex cardFooter02">
                <a
                    id="edit-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip" title="Εμφάνιση - Διόρθωση των στοιχείων της επιλεγμένης Κατηγορίας Σύμβασης"
                    data-bs-placement="bottom"
                    data-tooltip-max-width="15vw"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-3 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.update) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.update) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
                </a>

                <a
                    id="delete-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip" title="Διαγραφή της επιλεγμένης Κατηγορίας Σύμβασης"
                    data-bs-placement="bottom"
                    data-tooltip-max-width="15vw"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-3 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.delete) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.delete) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-trash"></i> Διαγραφή
                </a>

                <a
                    href="/symbaseis/kathgories"
                    role="button"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                    data-tooltip-max-width="15vw"
                    title="Επιστροφή στην Αρχική Σελίδα των Κατηγοριών των Συμβάσεων"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-3">
                    <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
                </a>
            </div>

            <div class="d-flex width-percent-15"></div>

            <% if (kathgoriesSymbaseonFilteredRecs) { %>

                <%
                    const s = (typeof sTerm === 'string') ? sTerm : '';
                    const symbCode = (typeof symbash_stathera !== 'undefined' && symbash_stathera) ? symbash_stathera : '';

                    const qsParts = [];
                    if (symbCode) qsParts.push('symbash_stathera=' + encodeURIComponent(symbCode));
                    if (s)        qsParts.push('sTerm=' + encodeURIComponent(s));
                    const qsTail = qsParts.length ? '&' + qsParts.join('&') : '';
                %>

                <nav class="col-2" aria-label="Dashboard Pagination">
                    <ul class="pagination pagination-sm justify-content-end mt-2">
                        <% if (Number(current) === 1) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/symbaseis/kathgories/search?page=1<%= qsTail %>" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item">
                                <a href="/symbaseis/kathgories/search?page=<%= Number(current) - 1 %><%= qsTail %>" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a>
                            </li>
                        <% } %>

                        <% var i = Number(current) > 2 ? Number(current) - 1 : 1; %>

                        <% if (i !== 1) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link font-size-vw-0_5">...</a>
                            </li>
                        <% } %>

                        <% for (; i <= (Number(current) + 1) && i <= pages; i++) { %>
                            <% if (i === Number(current)) { %>
                                <li class="page-item is-current" aria-current="page">
                                    <span class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></span>
                                </li>
                            <% } else { %>
                                <li class="page-item fsvw-0_7">
                                    <a href="/symbaseis/kathgories/search?page=<%= i %><%= qsTail %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"> <%= i %></a>
                                </li>
                            <% } %>

                            <% if (i === Number(current) + 1 && i < pages) { %>
                                <% if (pages > 3) { %>
                                    <li class="page-item disabled">
                                        <a href="#" class="page-link font-size-vw-0_5">...</a>
                                    </li>
                                <% } %>
                                <li class="page-item">
                                    <a href="/symbaseis/kathgories/search?page=<%= pages %><%= qsTail %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= pages %></a>
                                </li>
                            <% } %>
                        <% } %>

                        <% if (Number(current) === Number(pages)) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/symbaseis/kathgories/search?page=<%= Number(current) + 1 %><%= qsTail %>" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item fsvw-0_7">
                                <a href="/symbaseis/kathgories/search?page=<%= pages %><%= qsTail %>" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </div>
  	</div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>

<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>

<script src="<%= script('common/blockInvalidClick') %>"></script>
<script src="<%= script('symbaseis/kathgories/selectRowInTable') %>"></script>
<script src="<%= script('common/sectionsVisible') %>"></script>
<script src="<%= script('common/sortTable') %>"></script>
<script src="<%= script('common/hideTooltips') %>"></script>
