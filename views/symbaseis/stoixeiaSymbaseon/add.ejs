<div class="margin-top-1rem">
	<div class="container-fluid height-vh-100 padding-0">

		<% const safe = (k) => (rec && rec[k]) || ''; %>

		<div class="sections margin-top-1rem">
			<section class="sel_1_section visible" data-section="">
				<div>
					<form class="formRadius">

						<%- include('../../partials/_csrfField') %>
						</br> </br> </br>

						<div class="card d-flex flex-column z-depth-5 w-80 margin-left-percent-10 overflow-hidden">

							<div class="card-header p-2 height-rem-3_5">
								<label class="text-center w-100 headers-content">
									Εισαγωγή Νέου Στοιχείου Σύμβασης
								</label>
							</div>

                            <%
								const kodikosStr = String(kathgoria?.[0]?.kodikos ?? '').padEnd(10, '\u00A0');
								const perigrafhStr = String(kathgoria?.[0]?.perigrafh ?? '');
								const kodikosStrEid = String(eidikothta?.[0]?.kodikos ?? '').padEnd(10, '\u00A0');
								const perigrafhStrEid = String(eidikothta?.[0]?.perigrafh ?? '');
								const labelDescr = kodikosStr + perigrafhStr + kodikosStrEid + perigrafhStrEid;

								const len = labelDescr.length;
								const heightClass = len <= 90 
                                    ? 'height-vh-42'
                                    : len <= 200 ? 'height-vh-45'
                                    : 'height-vh-48';
                            %>
    
                            <div class="card-body overflow-auto flex-grow-1 w-100 bg-white <%= heightClass %>" id="cardBody">
								<input type="hidden" id="aa_kodikos" name="aa_kodikos" value="<%= aa_kodikos.toString().padStart(4, '0') %>" />

                            	<input type="hidden" name="afora_thn_symbash_kathgoria_eidikothta" id="afora_thn_symbash_kathgoria_eidikothta" value="<%= kathgoria[0].afora_thn_symbash.toString().padStart(4, '0') %><%= kathgoria[0].kodikos.toString().padStart(4, '0') %><%= eidikothta[0].kodikos.toString().padStart(4, '0') %>" />

                                <div class="row form-group g-3 align-items-center">
                                    <div>
                                        <div class="px-3 pb-2 pt-1 d-flex align-items-center gap-2">
                                            <span class="badge bg-secondary">Σύμβαση</span>
                                            <span>— </span>
                                            <span class="fw-semibold font-size-vw-0_875"><%= symbash[0].kodikos.padEnd(10, '\u00A0') %> </span>
                                            <span class="text-muted font-size-vw-0_875"> <%= symbash[0].perigrafh %></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center">
                                    <div class="indent-1_5">
                                        <div class="px-3 pb-2 pt-1 d-flex align-items-center gap-2">
                                            <span class="badge bg-secondary">Κατηγορία</span>
                                            <span>— </span>
                                            <span class="fw-semibold font-size-vw-0_875"><%= kathgoria[0].kodikos.padEnd(10, '\u00A0') %></span>
                                            <span class="text-muted font-size-vw-0_875 left-align"> <%= kathgoria[0].perigrafh %></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center">
                                    <div class="indent-3">
                                        <div class="px-3 pb-2 pt-1 d-flex align-items-center gap-2">
                                            <span class="badge bg-secondary">Ειδικότητα</span>
                                            <span>— </span>
                                            <span class="fw-semibold font-size-vw-0_875"><%= eidikothta[0].kodikos.padEnd(10, '\u00A0') %></span>
                                            <span class="text-muted font-size-vw-0_875 left-align"> <%= eidikothta[0].perigrafh %></span>
                                        </div>
                                    </div>
                                </div>

                                <hr class="hr-style mb-4" />
                
								<div class="row form-group g-3 align-items-center mb-1">
									<div class="col-1-5 left-align">
										<label
										for="kodikos"
										class="col-form-label label-font-size">
										Κωδικός
										</label>
									</div>
									<div class="col-1-5">
										<input type="text" name="kodikos" id="kodikos" class="form-control input-contents" value="<%= aa_kodikos.toString().padStart(4, '0') %>" readonly />
									</div>
								</div>
                
								<div class="row form-group g-3 align-items-center mb-1">
									<div class="col-1-5 left-align">
										<label
										for="perigrafh"
										class="col-form-label label-font-size field-required">
											Περιγραφή
										</label>
									</div>
									<div class="col-10-5">
										<input type="text" name="perigrafh" id="perigrafh" class="form-control input-contents" autocomplete="off" value="" />
									</div>
								</div>

								<div class="row form-group g-3 align-items-center mb-2 bg-white">
									<div class="col-1-5 left-align">
										<label for="poso_pososto" class="col-form-label label-font-size left-align field-required">
										Ποσό ή Ποσοστό
										</label>
									</div>
									<div class="col-1-5 left-align checkbox-flex-center">
										<input type="checkbox" id="poso_pososto" name="poso_pososto" class="form-check-input custom-checkbox checkbox-class margin-top--0_02rem" value="" />
										<label for="poso_pososto" id="label-poso_pososto" class="margin-left-0_75rem font-size-vw-0_875">
										ΠΟΣΟΣΤΟ
										</label>
									</div>
                  
									<div class="col-2-5"></div>

									<div class="col-1-5 left-align">
										<label for="poso" class="col-form-label label-font-size">
										Ποσό
										</label>
									</div>

									<div class="col-2">
										<input type="number" name="poso" id="poso" class="form-control input-contents text-right" autocomplete="off" value="0" step="0.10" disabled />
									</div>
									
									<div class="col-0-5"></div>

									<div class="col-1 left-align">
										<label for="pososto" class="col-form-label label-font-size">
										Ποσοστό
										</label>
									</div>

									<div class="col-1-5">
										<input type="number" name="pososto" id="pososto" class="form-control input-contents text-right" autocomplete="off" value="0" min="-100" max="100" step="0.05" />
									</div>
				                </div>

								<div class="row form-group g-3 align-items-center mb-2 bg-white">
									<div class="col-1-5 left-align">
										<label for="arithmos_klimakion" class="col-form-label label-font-size left-align field-required">
										Αριθμός Κλιμακίων
										</label>
									</div>

									<div class="col-1">
										<input type="number" name="arithmos_klimakion" id="arithmos_klimakion" class="form-control input-contents text-right" min="1" max="50" autocomplete="off" value="35" />
									</div>
									
									<div class="col-3"></div>

									<div class="col-1-5 left-align">
										<label for="ypologismos_apo_klimakio" class="col-form-label label-font-size-smaller">
										Ξεκινά απ'το Κλιμάκιο
										</label>
									</div>

									<div class="col-1">
										<input type="number" name="ypologismos_apo_klimakio" id="ypologismos_apo_klimakio" class="form-control input-contents text-right" min="1" max="35" autocomplete="off" value="1" />
									</div>

									<div class="col-1-5"></div>

									<div class="col-1-5 left-align">
										<label for="bhma_ypologismoy" class="col-form-label label-font-size">
										Βήμα Υπολογισμού
										</label>
									</div>

									<div class="col-1">
										<input type="number" name="bhma_ypologismoy" id="bhma_ypologismoy" class="form-control input-contents text-right" min="1" max="35" autocomplete="off" value="1" />
									</div>
				                </div>
                
								<div class="row form-group g-3 align-items-center mb-1">
									<div class="col-1-5 left-align">
										<label 
										for="typos_ypologismoy"
										class="col-form-label label-font-size field-required">
											Τύπος Υπολογισμού
										</label>
									</div>
									<div class="col-10-5">
										<input type="text" name="typos_ypologismoy" id="typos_ypologismoy" class="form-control input-contents" autocomplete="off" value="" />
									</div>
								</div>
			              	</div>

                            <div class="card-footer mt-auto cardFooter">
                                <div class="d-inline-block d-flex cardFooter01">
                                    <button
                                        type="button"
                                        class="btn btn-brown rounded-4 mt-2 w-20 buttons-content submitButton">
                                        <i class="bi bi-floppy"></i> Αποθήκευση
                                    </button>
                                    <a
                                        class="btn btn-brown buttons-content rounded-4 mt-2 w-20 backButton"
                                        href="/symbaseis/stoixeiaSymbaseon">
                                        <i class="bi bi-chevron-double-left"></i> 
                                        Επιστροφή
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>

<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>
              
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getCompanyDescription<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getXrhsh<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getPeriod<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getUser<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/blockInvalidClick<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/symbaseis/stoixeiaSymbaseon/getFieldValues<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/sectionsVisible<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/formatNumbers_2dec<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/moveByEnter<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/clearableInputs<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/toggleLabelSymbaseis<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
