<!-- Έλεγχος submit και σύνθεση 12-ψηφιου στον path -->
<script nonce="<%= nonce %>">
  document.addEventListener('DOMContentLoaded', function () {
    const form       = document.querySelector('form[name="StoixeiaSymbaseon"]');

    const symSelect  = document.getElementById('symbash');
    const symHidden  = document.getElementById('symbash_stathera');

    const katSelect  = document.getElementById('kathgoria_symbashs');
    const katHidden  = document.getElementById('kathgoria_symbashs_stathera');

    const eidSelect  = document.getElementById('eidikothta_symbashs');
    const eidHidden  = document.getElementById('eidikothta_symbashs_stathera');

    const combo3Hidden = document.getElementById('kodikosSymbashs_Kathgorias_Eidikothtas');

    const to4 = (v) => {
      const d = String(v ?? '').replace(/\D/g, '');
      if (!d) return '';
      const n = parseInt(d, 10);
      return Number.isFinite(n) ? String(n).padStart(4, '0') : d.slice(-4).padStart(4, '0');
    };

    form.addEventListener('submit', function (e) {
      const sym = (symHidden?.value || symSelect?.value || '').trim();
      if (!sym) {
        e.preventDefault();
        Swal.fire({
          backdrop: false,
          allowOutsideClick: false,
          icon: 'info',
          title: 'Δεν έχει επιλεγεί σύμβαση',
          text: 'Παρακαλώ επιλέξτε σύμβαση πριν την αναζήτηση.',
          showConfirmButton: true,
          confirmButtonText: 'Κλείσιμο',
          customClass: {
            confirmButton: 'class-info custom-confirm-button custom-swal-button',
            title: 'custom-title',
            popup: 'custom-swal-popup',
          },
        }).then(() => { try { symSelect?.focus(); } catch (_) {} });
        return false;
      }

      const kat = (katHidden?.value || katSelect?.value || '').trim();
      if (!kat) {
        e.preventDefault();
        Swal.fire({
          backdrop: false,
          allowOutsideClick: false,
          icon: 'info',
          title: 'Δεν έχει επιλεγεί κατηγορία',
          text: 'Παρακαλώ επιλέξτε κατηγορία σύμβασης πριν την αναζήτηση.',
          showConfirmButton: true,
          confirmButtonText: 'Κλείσιμο',
          customClass: {
            confirmButton: 'class-info custom-confirm-button custom-swal-button',
            title: 'custom-title',
            popup: 'custom-swal-popup',
          },
        }).then(() => { try { katSelect?.focus(); } catch (_) {} });
        return false;
      }

      const eid = (eidHidden?.value || eidSelect?.value || '').trim();
      if (!eid) {
        e.preventDefault();
        Swal.fire({
          backdrop: false,
          allowOutsideClick: false,
          icon: 'info',
          title: 'Δεν έχει επιλεγεί ειδικότητα',
          text: 'Παρακαλώ επιλέξτε ειδικότητα σύμβασης πριν την αναζήτηση.',
          showConfirmButton: true,
          confirmButtonText: 'Κλείσιμο',
          customClass: {
            confirmButton: 'class-info custom-confirm-button custom-swal-button',
            title: 'custom-title',
            popup: 'custom-swal-popup',
          },
        }).then(() => { try { eidSelect?.focus(); } catch (_) {} });
        return false;
      }

      // populate hidden & compose composite key
      if (symHidden) symHidden.value = sym;
      if (katHidden) katHidden.value = kat;
      if (eidHidden) eidHidden.value = eid;

      const combo = `${to4(sym)}${to4(kat)}${to4(eid)}`;
      if (combo3Hidden) combo3Hidden.value = combo;

      // path με το 12-ψηφιο
      this.action = `/symbaseis/stoixeiaSymbaseon/search/${encodeURIComponent(combo)}`;
    });
  });
</script>




