<% var maxEntriesPerPage = entries; %>
<% var cardbodyHeight = totalRecs <= maxEntriesPerPage ? (totalRecs * 4) : (maxEntriesPerPage * 4); %> 

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-4 mb-4 mt-2 border-bottom" sstyle="background-image: url('https://cdn.webpayrollsolutions.com/assets/img/wps1.png'); background-repeat: no-repeat; background-position: 0% 50%;">
</div>

<div class="card d-flex flex-column z-depth-5" style="width: 80%; margin-left: 10%">
  <div class="card-header p-0" style="height: 3.5rem !important;">
    <label class="text-center w-100 headers-content mt-2">
      <% if (sTerm && sTerm.length > 0) { %>
        Εμφάνιση Ειδικοτήτων Συμβάσεων (με κριτήριο αναζήτησης "<%= sTerm %>") 
      <% } else { %> 
        Εμφάνιση Ειδικοτήτων Συμβάσεων 
      <% } %> 
    </label>
  </div>
  <div>
    <table class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
      <thead style="font-size: 0.9vw;">
        <tr>
          <th scope="col" onclick="sortTable(0, this)" class="color-brown col-1" style="background-color: #8ca38c83 !important;"> Κωδικός <i class="sort-icon bi" style="margin-left: 0.6rem; color: #002e00; font-size: 0.875vw; font-weight: 700;"></i>
          </th>
          <th scope="col" onclick="sortTable(1, this)" class="color-brown col-11"> Περιγραφή Ειδικότητας Σύμβασης <i class="sort-icon bi" style="margin-left: 0.6rem; color: #002e00; font-size: 0.875vw; font-weight: 700;"></i>
          </th>
        </tr>
      </thead>
    </table>
  </div>
  
  <div class="card-body p-0 overflow-auto flex-grow-1" style="height: <%= cardbodyHeight %>vh; background-color: #ffffff">
    <% if (eidikothtesSymbaseonFilteredRecs && eidikothtesSymbaseonFilteredRecs.length > 0) { %> 
      <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
        <tbody>
          <% eidikothtesSymbaseonFilteredRecs.forEach(element => { %> 
            <tr data-id="<%= element._id %>">
              <td class="col-1"><%- element.kodikos %></td>
              <td class="col-11"><%- element.perigrafh %></td>
            </tr>
          <% }); %> 
          
          <% if (eidikothtesSymbaseonFilteredRecs.length === 0) { %> 
            <tr>
              <td colspan="2" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
            </tr>
          <% } %> 
        </tbody>
      </table>
    <% } else { %> 
      <p class="records-not-found" style="height: 10vh;">
        Δεν βρέθηκαν Ειδικότητες Συμβάσεων που να πληρούν το κριτήριο αναζήτησης "<%= sTerm %>"
      </p>
    <% } %> 
  </div>

  <div class="card-footer mt-auto">
    <div class="d-flex" style="margin: -0.5rem 0.625rem 2rem;">
  
      <!-- Κουμπιά ενεργειών -->
      <div class="d-flex" style="width: 60%; justify-content: space-around;">
        <a 
          id="add-btn"
          href="/symbaseis/eidikothtes/add/<%= selectedSymbash_Kathgoria %>" 
          role="button" 
          data-bs-toggle="tooltip" title="Προσθήκη νέας ειδικότητας σύμβασης" data-bs-placement="bottom" style="font-size: 0.8vw;"
          class="btn btn-brown rounded-4 mb-3 mt-2 mr-2 col-2-5 <% if (!userPrivileges.privileges.admin && !userPrivileges.privileges.create) { %>disabled-link<% } %>"
          <% if (!userPrivileges.privileges.admin && !userPrivileges.privileges.create) { %>onclick="event.preventDefault();" <% } %>>
          <i class="bi bi-plus-circle"></i> Προσθήκη
        </a>
        
        <a 
          id="edit-btn"
          href="#" 
          role="button" style="font-size: 0.8vw;"
          data-bs-toggle="tooltip" title="Εμφάνιση - Διόρθωση της επιλεγμένης ειδικοτήτας συμβάσης" data-bs-placement="bottom" 
          class="btn btn-brown rounded-4 mb-3 mt-2 mr-2 col-2-5 <% if (!userPrivileges.privileges.admin && !userPrivileges.privileges.update) { %>disabled-link<% } %>"
          <% if (!userPrivileges.privileges.admin && !userPrivileges.privileges.update) { %> onclick="event.preventDefault();" <% } %>>
          <i class="bi bi-pencil-square"></i> Συντήρηση
        </a>
        
        <a 
          id="delete-btn"
          href="#"
          role="button"
          data-bs-toggle="tooltip" title="Διαγραφή της επιλεγμένης ειδικότητας σύμβασης" data-bs-placement="bottom"  style="font-size: 0.8vw;" 
          class="btn btn-brown rounded-4 mb-3 mt-2 mr-2 col-2-5 <% if (!userPrivileges.privileges.admin && !userPrivileges.privileges.delete) { %>disabled-link<% } %>"
          <% if (!userPrivileges.privileges.admin && !userPrivileges.privileges.delete) { %> onclick="event.preventDefault();" <% } %>>
          <i class="bi bi-trash"></i> Διαγραφή
        </a>
  
        <a 
          href="/symbaseis/eidikothtes"
          role="button"
          class="btn btn-brown rounded-4 mb-3 mt-2 col-2-5" style="font-size: 0.8vw;">
          <i class="bi bi-chevron-double-left"></i> Επιστροφή
        </a>
      </div>

      <div class="d-flex" style="width: 15%;"></div>

      <!-- Pagination -->
      <div class="ms-auto" style="flex-grow: 1; max-width: 25%; font_size: 0.8vw !important">
        <nav aria-label="Page navigation">
          <ul class="pagination justify-content-end">
            <% if (Number(current) > 1) { %>
              <li class="page-item">
                <a class="page-link" href="/symbaseis/eidikothtes/search?page=1" aria-label="First">
                  <i class="bi bi-chevron-bar-left"></i>
                </a>
              </li>
              <li class="page-item">
                <a class="page-link" href="/symbaseis/eidikothtes/search?page=<%= Number(current) - 1 %>" aria-label="Previous">
                  <i class="bi bi-chevron-left"></i>
                </a>
              </li>
            <% } %>
  
            <!-- Number(current) Page -->
            <li class="page-item active"><a class="page-link" href="#"><%= Number(current) %></a></li>
  
            <!-- Dynamic "next pages" and "..." logic -->
            <% if (Number(current) < pages) { %>
              <% let upTo = Math.min(Number(current) + 2, pages); %>
              <% for(let i = Number(current) + 1; i <= upTo; i++) { %>
                <li class="page-item"><a class="page-link" href="/symbaseis/eidikothtes/search?page=<%= i %>"><%= i %></a></li>
              <% } %>
              <% if (i < pages) { %>
                <li class="page-item disabled"><span class="page-link">...</span></li>
                <li class="page-item"><a class="page-link" href="/symbaseis/eidikothtes/search?page=<%= pages %>"><%= pages %></a></li>
              <% } %>
            <% } %>
            <% if (Number(current) < pages) { %>
              <li class="page-item">
                <a class="page-link" href="/symbaseis/eidikothtes/search?page=<%= Number(current) + 1 %>" aria-label="Next">
                  <i class="bi bi-chevron-right"></i>
                </a>
              </li>
              <li class="page-item">
                <a class="page-link" href="/symbaseis/eidikothtes/search?page=<%= pages %>" aria-label="Last">
                  <i class="bi bi-chevron-bar-right"></i>
                </a>
              </li>
            <% } else { %>
              <li class="page-item disabled"><span class="page-link">
                <i class="bi bi-chevron-right"></i></span></li>
              <li class="page-item disabled"><span class="page-link">
                <i class="bi bi-chevron-bar-right"></i></span></li>
            <% } %>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</div>

<script src="/js/common/getCompanyDescription.js"></script>
<script src="/js/common/getXrhsh.js"></script>
<script src="/js/common/getPeriod.js"></script>
<script src="/js/common/getUser.js"></script>
<script src="/js/symbaseis/eidikothtes/selectRowInTable.js"></script>
<script src="/js/common/sortTable.js"></script>
<script src="/js/common/tooltipsForButtons.js"></script>
<!-- <script src="/js/common/changeUrl.js"></script> -->
