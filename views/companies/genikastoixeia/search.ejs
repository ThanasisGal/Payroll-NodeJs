<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-5  mb-3 border-bottom bg-hero-cdn">
    <form
        class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0">

        <%- include('../../partials/_csrfField') %>
    </form>
</div>

<div class="card d-flex flex-column z-depth-5 w-92 margin-left-percent-1 overflow-hidden">
    <div class="card-header p-0 height-rem-3_5">
        <label class="text-center w-100 headers-content mt-2"> 
            Εμφάνιση Εταιρειών ( με κριτήριο αναζήτησης "<%= sTerm %>" ) 
        </label>
    </div>

    <div>
        <table class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
            <thead class="backgroundColor-brown font-size-rem-1_1 center-align">
                <tr class="color-brown">
                    <th scope="col" class="col-1">Κωδ.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-3-25">Επώνυμο/μία<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-2">Όνομα<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-1-75">Πατρώνυμο<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-3">Δραστηριότητα<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-1">ΑΦΜ<i class="sort-icon bi"></i></th>
                </tr>
            </thead>
        </table>
    </div>

    <div class="card-body p-0 overflow-auto flex-grow-1 height-vh-58 bg-white">
        <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
            <tbody>
                <% if (companyFilteredRecs && companyFilteredRecs.length > 0) { %>
                    <% companyFilteredRecs.forEach(element => { %>
                        <tr class="input-content-regular" data-id="<%- element._id %>" id="myTableRow">
                            <td class="col-1 padding-left-rem-0_5"><%- element.kod %></td>
                            <td class="col-3-25"><%- element.eponymia %></td>
                            <td class="col-2"><%- element.firstname %></td>
                            <td class="col-1-75"><%- element.fathername %></td>
                            <td class="col-3"><%- element.activity %></td>
                            <td class="col-1"><%- element.afm %></td>
                        </tr>
                    <% }) %>
                <% } else { %>  
                    <tr>
                        <td colspan="5" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="card-footer cardFooter">
        <div class="d-inline-block d-flex cardFooter01">
            <div class="d-flex cardFooter02">
                <a
                    id="select-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip" data-bs-title="Επιλέξτε την εταιρεία..."
                    data-bs-placement="top"
                    data-tooltip-max-width="15vw"
                    class="btn btn-success rounded-4 buttons-content mb-3 mt-2 col-3 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.read) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.read) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-check2-circle"></i> Επιλογή Εταιρείας
                </a>

                <a
                    id="edit-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip" data-bs-title="Εμφάνιση - Διόρθωση..."
                    data-bs-placement="top"
                    data-tooltip-max-width="15vw"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.update) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.update) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
                </a>

                <a
                    id="delete-btn"
                    href="#"
                    role="button"
                    data-bs-toggle="tooltip" data-bs-title="Διαγραφή της επιλεγμένης εταιρείας."
                    data-bs-placement="top"
                    data-tooltip-max-width="15vw"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2 <%= (!userPrivileges.privileges?.admin && !userPrivileges.privileges?.delete) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.privileges?.admin || userPrivileges.privileges?.delete) ? '1' : '0' %>">
                    <i class="buttons-content bi bi-trash"></i> Διαγραφή
                </a>

                <a
                    href="/companies/genikastoixeia"
                    role="button"
                    data-bs-toggle="tooltip"
                    data-bs-placement="top"
                    data-tooltip-max-width="15vw"
                    data-bs-title="Επιστροφή στην Αρχική Σελίδα της εφαρμογής"
                    class="btn btn-brown rounded-4 buttons-content mb-3 mt-2  col-2">
                    <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
                </a>
            </div>

            <div class="d-flex width-percent-15"></div>

            <% if (companyFilteredRecs) { %>
                <!-- Pagination -->
                <nav class="col-2" aria-label="Dashboard Pagination">
                    <ul class="pagination pagination-sm justify-content-end mt-2">
                        <% if (Number(current) === 1) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/companies/genikastoixeia/search/?page=1" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item">
                                <a href="/companies/genikastoixeia/search/?page=<%= Number(current) - 1 %>" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a>
                            </li>
                        <% } %>

                        <% var i = Number(current) > 2 ? Number(current) - 1 : 1; %>

                        <% if (i !== 1) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link font-size-vw-0_5">...</a>
                            </li>
                        <% } %>

                        <% for (; i <= (Number(current) + 1) && i <= pages; i++) { %>
                            <% if (i === Number(current)) { %>
                                <li class="page-item is-current" aria-current="page">
                                    <span class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></span>
                                </li>
                            <% } else { %>
                                <li class="page-item fsvw-0_7">
                                    <a href="/companies/genikastoixeia/search/?page=<%= i %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></a>
                                </li>
                            <% } %>

                            <% if (i === Number(current) + 1 && i < pages) { %>
                                <li class="page-item disabled">
                                    <a href="#" class="page-link font-size-vw-0_5">...</a>
                                </li>
                                <li class="page-item">
                                    <a href="/companies/genikastoixeia/search/?page=<%= pages %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= pages %></a>
                                </li>
                            <% } %>
                        <% } %>

                        <% if (Number(current) === Number(pages)) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/companies/genikastoixeia/search/?page=<%= Number(current) + 1 %>" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a>
                            </li>
                            <li class="page-item fsvw-0_7">
                                <a href="/companies/genikastoixeia/search/?page=<%= pages %>" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>
<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>

<script src="<%= script('common/blockInvalidClick') %>"></script>
<script src="<%= script('common/sortTable') %>"></script>
<script src="<%= script('companies/genikastoixeia/selectRowInTable') %>"></script>
