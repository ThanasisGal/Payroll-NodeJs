      <section class="sel_2_section visible" data-section="Δραστηριότητες">
        <div class="container">
          <form action="/companies/genikastoixeia/add" method="POST" class="formRadius"enctype="multipart/form-data">
            <div class="card z-depth-5">
              <label
                class="card-header bg-header text-center headers-content"
                >Εισαγωγή Νέας Εταιρείας - Δραστηριότητες
              </label>
              <div class="card-body">
                <% for (let index = 1; index <= 6; index++) { %>
                  <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-1-5 right-align">
                      <label
                        <% if (index === 1) { %>
                          for=<%= `koddrast${index}` %>
                          class="col-form-label label-font-size"
                          >Κύρια Δραστηριότητα</label>
                        <% } else if (index === 6) { %>
                          for=<%= `koddrast${index}` %>
                          class="col-form-label label-font-size"
                          >ΚΑΔ Παραρτήματος</label>
                        <% } else { %>
                          for=<%= `koddrast${index}` %>
                          class="col-form-label label-font-size"
                          >Δευτ/σα Δραστ/τα #<%= index %></label>
                        <% } %>
                    </div>
                
                    <div class="col-1">
                      <input
                        type="text"
                        name=<%= `koddrast${index}` %>
                        id=<%= `koddrast${index}` %>
                        class="form-control input-contents"
                        value=""
                        placeholder="Αναζήτηση"
                      />
                    </div>
                
                    <div class="col-8-5">
                      <select
                        class="form-select selectpicker-dropdown-small"
                        name=<%= `kad${index}` %>
                        id=<%= `select_kad${index}` %>
                      ></select>
                    </div>
                    <i
                      id=<%= `tooltipIcon_${index}` %>
                      class="bi bi-info-circle-fill col-0-5"
                      style="
                        cursor: pointer;
                        font-size: 20px;
                        color: rgb(128, 187, 253);">
                    </i>
                  </div>
                <% } %>

                <div class="card-footer" style="margin-left: -1rem !important; margin-right: -1rem !important;
                margin-bottom: -1rem !important;">
                  <div
                    class="d-inline-block d-flex"
                    style="
                      margin-top: -0.5rem !important;
                      margin-bottom: -1rem !important;
                      margin-left: 10px !important;
                      margin-right: 10px !important;
                      justify-content: space-around;
                    "
                  >
                    <button
                      type="button"
                      class="btn btn-brown rounded-4 buttons-contents mt-2 w-20 submitButton"
                      style="font-size: 0.8vw"
                    >
                      <i class="bi bi-floppy"></i> Αποθήκευση
                    </button>
                    <a
                      class="btn btn-brown rounded-4 buttons-contents mt-2 w-20"
                      style="font-size: 0.8vw"
                      style="vertical-align: middle"
                      href="/companies/genikastoixeia"
                    >
                      <i class="bi bi-chevron-double-left"></i> Επιστροφή</a
                    >
                  </div>
                </div>
              </div>
            </div>
          </form>
        </div>
      </section>

