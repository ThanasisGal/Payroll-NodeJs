<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom bg-hero-cdn">
    <form
        name="Companies"
        class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0"
        role="search"
        method="POST"
        action="/companies/genikastoixeia/search" >

        <%- include('../../partials/_csrfField') %>

        <div class="input-group">
            <span><i class="bi bi-search bi-search-swing fsvw-1_3 fw600 cgreen"></i>&nbsp;</span>
            <input
                type="search"
                name="searchTerm"
                id="searchInput"
                class="form-control rounded-end-2 ms-auto fsvw-1_1 border-radius-10"
                placeholder="Αναζήτηση... ( πατείστε Enter )"
                aria-label="Search" />
        </div>
    </form>
</div>

<div class="card d-flex flex-column z-depth-5 w-92 mlperc overflow-hidden">

    <div class="card-header p-0 height-rem-3_5">
        <label class="text-center w-100 headers-content mt-2"> Διαχείριση Εταιρειών </label>
    </div>
    
    <div>
        <table class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
            <thead class="backgroundColor-brown fsrem-1_1 center-align">
                <tr class="color-brown">
                    <th scope="col" class="col-1">Κωδ.<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-3-25">Επώνυμο/μία<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-2">Όνομα<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-1-75">Πατρώνυμο<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-3">Δραστηριότητα<i class="sort-icon bi"></i></th>
                    <th scope="col" class="col-1">ΑΦΜ<i class="sort-icon bi"></i></th>
                </tr>
            </thead>
        </table>
    </div>

    <div class="card-body p-0 overflow-auto flex-grow-1 height-vh-58 bg-white">
        <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
            <tbody>
                <% if (company) { %>
                    <% company.forEach(element => { %>
                        <tr class="input-content-regular" data-id="<%= element._id %>" id="myTableRow">
                            <td class="col-1"><%= element.kod %></td>
                            <td class="col-3-25"><%= element.eponymia %></td>
                            <td class="col-2"><%= element.firstname %></td>
                            <td class="col-1-75"><%= element.fathername %></td>
                            <td class="col-3"><%= element.activity %></td>
                            <td class="col-1"><%= element.afm %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="card-footer cardFooter">
        <div
            class="d-inline-block d-flex cardFooter01">
            <a 
                id="add-btn"
                href="/companies/genikastoixeia/add"
                role="button"
                data-bs-toggle="tooltip" title="Προσθήκη νέας εταιρείας."
                data-bs-placement="top"
                data-tooltip-max-width="15vw"
                class="btn btn-brown rounded-4 mb-3 buttons-content mt-2 col-1-3 <%= (!userPrivileges.admin && !userPrivileges.create) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.create) ? '1' : '0' %>">
                <i class="buttons-content bi bi-plus-circle"></i> Νέα Εταιρεία
            </a>

            <a 
                id="edit-btn"
                href="#"
                role="button"
                data-bs-toggle="tooltip" title="Εμφάνιση - Διόρθωση..."
                data-bs-placement="top"
                data-tooltip-max-width="15vw"
                class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-1-3 <%= (!userPrivileges.admin && !userPrivileges.update) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.update) ? '1' : '0' %>">
                <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
            </a>

            <a 
                id="select-btn"
                href="#"
                role="button"
                data-bs-toggle="tooltip" title="Επιλέξτε την εταιρεία..."
                data-bs-placement="top"
                data-tooltip-max-width="15vw"
                class="btn btn-success rounded-4 buttons-content mb-3 mt-2 col-3-5 <%= (!userPrivileges.admin && !userPrivileges.read) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.read) ? '1' : '0' %>">
                <i class="buttons-content bi bi-check2-circle"></i> Επιλογή Εταιρείας
            </a>

            <a 
                id="delete-btn"
                href="#"
                role="button"
                data-bs-toggle="tooltip" title="Διαγραφή της επιλεγμένης εταιρείας."
                data-bs-placement="top"
                data-tooltip-max-width="15vw"
                class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-1-3 <%= (!userPrivileges.admin && !userPrivileges.delete) ? 'disabled-link' : '' %>"
                data-allowed="<%= (userPrivileges.admin || userPrivileges.delete) ? '1' : '0' %>">
                <i class="buttons-content bi bi-trash"></i> Διαγραφή
            </a>

            <a 
                href="/mainapp"
                role="button"
                data-bs-toggle="tooltip"
                data-bs-placement="top"
                data-tooltip-max-width="15vw"
                title="Επιστροφή στην Αρχική Σελίδα της εφαρμογής"

                class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-1-3">
                <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
            </a>

            <% if (company) { %>
                <nav class="col-2" aria-label="Dashboard Pagination">
                    <ul class="pagination pagination-sm justify-content-end mt-2">
                        <% if (current == 1) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-bar-left fsvw-0_5"></i></a>
                            </li>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-left fsvw-0_5"></i></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/companies/genikastoixeia/?page=1" class="page-link"><i class="bi bi-chevron-bar-left fsvw-0_5"></i></a>
                            </li>
                            <li class="page-item">
                                <a href="/companies/genikastoixeia/?page=<%= Number(current) - 1 %>" class="page-link"><i class="bi bi-chevron-left fsvw-0_5"></i></a>
                            </li>
                        <% } %> 
                        <% var i = Number(current) > 2 ? Number(current) -1 : 1 %> 
                        
                        <% if (i !== 1) { %>
                            <li class="page-item disabled"><a href="#" class="page-link fsvw-0_5">...</a></li>
                        <% } %> 
                        
                        <% for( ; i <= (Number(current) + 2) && i <= pages; i++) { %> 
                            <% if (i == current) { %>
                                <li class="page-item">
                                    <a href="#" class="page-link pageItem fsvw-0_5 padptop-8 fw500"><%= i %></a>
                                </li>
                            <% } else { %>
                                <li class="page-item fsvw-0_7">
                                    <a href="/companies/genikastoixeia/?page=<%= i %>" class="page-link fsvw-0_5 padptop-8 fw500"><%= i %></a>
                                </li>
                            <% } %> 
                    
                            <% if (i == Number(current) + 2 && i < pages) { %>
                                <li class="page-item disabled"><a href="#" class="page-link fsvw-0_5">...</a></li>
                                <li class="page-item">
                                    <a href="/companies/genikastoixeia/?page=<%= pages %>" class="page-link fsvw-0_5 padptop-8 fw500"><%= pages %></a>
                                </li>
                            <% } %> 
                        <% } %> 
                        
                        <% if (current == pages) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-right fsvw-0_5"></i></a>
                            </li>
                            <li class="page-item disabled">
                                <a href="#" class="page-link"><i class="bi bi-chevron-bar-right fsvw-0_5"></i></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/companies/genikastoixeia/?page=<%= Number(current) + 1 %>" class="page-link"><i class="bi bi-chevron-right fsvw-0_5"></i></a>
                            </li>
                            <li class="page-item fsvw-0_7">
                                <a href="/companies/genikastoixeia/?page=<%= pages %>" class="page-link"><i class="bi bi-chevron-bar-right fsvw-0_5"></i
                                ></a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>

<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>
            
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/blockInvalidClick<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/companies/genikastoixeia/selectRowInTable<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/sortTable<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
