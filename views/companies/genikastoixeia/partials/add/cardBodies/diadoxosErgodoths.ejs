<% const safe = (k) => (rec && rec[k]) || ''; %>

<div class="card-body overflow-auto flex-grow-1 w-100 height-vh-48 bg-white" id="cardBody8">
    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="kod_diad_erg" class="col-form-label label-font-size">Κωδικός</label>
        </div>
        <div class="col-1">
            <input
                type="text"
                name="kod_diad_erg"
                id="kod_diad_erg"
                class="form-control input-contents"
                value=""
                disabled
            />
        </div>
    </div>

    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="afm_diad_erg" class="col-form-label label-font-size field-required">Α.Φ.Μ</label>
        </div>
        <div class="col-2">
            <input
                type="text"
                name="afm_diad_erg"
                id="afm_diad_erg"
                class="form-control input-contents"
                value=""
                maxlength="9"
                pattern="[0-9]{1,}"
            />
        </div>
    </div>

    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="eponymo_diad_erg" class="col-form-label label-font-size field-required">Επώνυμο/μία</label>
        </div>
        <div class="col-5">
            <input
                type="text"
                name="eponymo_diad_erg"
                id="eponymo_diad_erg"
                class="form-control input-contents"
                value=""
                required
            />
        </div>

        <div class="col-1-5 right-align">
            <label for="onoma_diad_erg" class="col-form-label label-font-size">Όνομα</label>
        </div>
        <div class="col-3">
            <input
                type="text"
                name="onoma_diad_erg"
                id="onoma_diad_erg"
                class="form-control input-contents"
                value=""
            />
        </div>
    </div>

    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="titlos_diad_erg" class="col-form-label label-font-size">Διακριτικός Τίτλος</label>
        </div>
        <div class="col-5">
            <input
                type="text"
                name="titlos_diad_erg"
                id="titlos_diad_erg"
                class="form-control input-contents"
                value=""
                required
            />
        </div>

        <div class="col-1-5 right-align">
            <label for="nomikh_morfh_diad_erg" class="col-form-label label-font-size" >Νομική Μορφή</label>
        </div>

        <input
            type="hidden"
            name="nomikhmorfh_diadoxosErgodoths"
            id="nomikhmorfh_diadoxosErgodoths"
            class="form-control input-contents"
            value="<%= safe("nomikhmorfh_diadoxosErgodoths") %>"
            readonly
        />

        <div class="col-3-75">
            <select
                id="nomikh_morfh_diad_erg"
                name="nomikh_morfh_diad_erg"
                class="tom-dropdown selectpicker-dropdown-normal left-align"
                aria-label="Νομική Μορφή"
                data-api="/api/dropdown/diadoxosErgodoths"
                single
                data-target-input=<%= `nomikhmorfh_diadoxosErgodoths` %>
                data-preselect=<%= `nomikhmorfh_diadoxosErgodoths` %>
                data-preload-all="true"
                data-pad-length="3"
                data-xrhsh-related="false"
                data-team-related="false"
                data-company-related="false"
                data-mhnas-related="false"
                placeholder="Αναζήτηση Νομικής Μορφής">
            </select>
        </div>
    </div>

    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="drasthriothta_diad_erg" class="col-form-label label-font-size">Αντικ. Δραστ/τητας</label>
        </div>
        <div class="col-10-5">
            <input
                type="text"
                name="drasthriothta_diad_erg"
