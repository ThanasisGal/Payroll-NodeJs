            />
        </div>
    </div>

    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="dieythynsh_diad_erg" class="col-form-label label-font-size">Διεύθυνση</label>
        </div>
        <div class="col-5">
            <input
                type="text"
                name="dieythynsh_diad_erg"
                id="dieythynsh_diad_erg"
                class="form-control input-contents"
                value=""
                required
            />
        </div>

        <div class="col-1-5 right-align">
            <label for="thlefono_diad_erg" class="col-form-label label-font-size">Τηλέφωνο</label>
        </div>
        <div class="col-3">
            <input
                type="text"
                name="thlefono_diad_erg"
                id="thlefono_diad_erg"
                class="form-control input-contents"
                value=""
            />
        </div>
    </div>

    <div class="row form-group g-3 align-items-center mb-3">
        <div class="col-1-5 right-align">
            <label for="email_diad_erg" class="col-form-label label-font-size">eMail</label>
        </div>
        <div class="col-5">
            <input
                type="mail"
                class="form-control input-contents"
                name="email_diad_erg"
                id="email_diad_erg"
                value=""
            />
        </div>
    </div>
</div>

