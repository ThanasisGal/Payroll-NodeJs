                  </div>
                  <div class="col-10-5">
                    <input
                      type="text"
                      name="activity"
                      id="activity"
                      class="form-control input-content"
                      value="<%= company.activity %>"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label
