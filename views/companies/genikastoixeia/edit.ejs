                      data-live-search="true"
                      name="dhmos"
                      id="dhmos"
                      style="font-size: 1vw"
                    ></select>
                  </div>

                  <div class="col-1"></div>

                  <div class="col-1-5 right-align">
                    <label for="polh" class="col-form-label label-font-size"
                      >Δημοτ.Διαμέρισμα</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="polh"
                      id="polh"
                      style="font-size: 1vw"
                    ></select>
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="thlefono" class="col-form-label label-font-size"
