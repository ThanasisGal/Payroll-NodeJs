                  <div class="col-1 right-align">
                    <label for="tk" class="col-form-label label-font-size"
                      >Τ.Κ.</label
                    >
                  </div>
                  <div class="col-1">
                    <input
                      type="text"
                      name="tk"
                      id="tk"
                      class="form-control input-content"
                      value="<%= company.tk %>"
                      maxlength="5"
                      pattern="[0-9]{1,}"
                    />
