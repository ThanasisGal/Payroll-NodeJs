                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label
                      for="perifereies"
                      class="col-form-label label-font-size"
                      >Περιφέρεια</label
                    >
                  </div>

                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="perifereies"
                      id="perifereies">
                      <% perifereies.forEach(function(perifereia) { %>
                          <option value="<%= perifereia.kodikos %>" <% if(perifereia.kodikos == company.perifereia) { %>selected<% } %>><%= perifereia.perigrafh %></option>
                      <% }); %>
                    </select>
                  </div>

                  <div class="col-1"></div>

                  <div class="col-1-5 right-align">
                    <label for="nomos" class="col-form-label label-font-size"
                      >Περιφ. Ενότητα</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="nomos"
                      id="nomos"
                      style="font-size: 1vw">
                    </select>
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="dhmos" class="col-form-label label-font-size"
