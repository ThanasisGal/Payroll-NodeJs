                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="thlefono"
                      id="thlefono"
                      class="form-control input-content"
                      value="<%= company.thlefono %>"
                      maxlength="10"
                      pattern="[0-9]{1,}"
                    />
                  </div>

                  <div class="col-3"></div>

                  <div class="col-1-5 right-align">
                    <label for="fax" class="col-form-label label-font-size"
                      >Fax</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="fax"
                      id="fax"
                      class="form-control input-content"
                      value="<%= company.fax %>"
                      maxlength="10"
                      pattern="[0-9]{1,}"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="anenergh" class="col-form-label label-font-size"
                      >Ανενεργή</label
                    >
                  </div>
                  <div class="col-1 left-align checkbox-flex-center">
                    <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="anenergh" name="anenergh" <%= company.anenergh ? 'checked' : '' %> value="" /> 
                    <label for="anenergh" id="label-anenergh" class="input-content" style="margin-left: .75rem; font-weight: 600;">ΟΧΙ</label>
                  </div>

                  <div class="col-4"></div>

                  <div class="col-1-5 right-align">
                    <label for="email" class="col-form-label label-font-size"
                      >e-Mail</label
                    >
                  </div>
                  <div class="col-4">
                    <input
                      type="email"
                      name="email"
                      id="email"
                      class="form-control input-content"
                      value="<%= company.email %>"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label
                      for="nomikhmorfh"
                      class="col-form-label label-font-size"
                      >Νομική Μορφή</label
                    >
                  </div>
                  <div class="col-5">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="nomikhmorfh"
                      id="nomikhmorfh"
                      data-selected="<%= company.nomikh_morfh %>">
                  </select>
                  </div>

                  <div class="col-1-5 right-align">
                    <label
                      for="pararthmaefka"
                      class="col-form-label label-font-size"
                      >Παράρτημα ΕΦΚΑ</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="pararthmaefka"
                      id="pararthmaefka"
                      data-selected="<%= company.pararthma_efka %>">
                    </select>
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="doy" class="col-form-label label-font-size">Δ.Ο.Υ.</label>
                  </div>
                  <div class="col-5">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="doy"
                      id="doy"
                      data-selected="<%= company.doy_company %>">
                    </select>
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="tameio1" class="col-form-label label-font-size"
                      >Ταμείο #1 (τ.ΙΚΑ)</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="tameio1"
                      id="tameio1">
                    </select>
                  </div>

                  <div class="col-1"></div>

                  <div class="col-1-5 right-align">
                    <label for="ame1" class="col-form-label label-font-size"
                      >Α.Μ.Ε. #1</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="ame1"
                      id="ame1"
                      class="form-control input-content"
                      value="<%= company.ame1 %>"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="tameio2" class="col-form-label label-font-size"
                      >Ταμείο #2</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="tameio2"
                      id="tameio2">
                    </select>
                  </div>

                  <div class="col-1"></div>

                  <div class="col-1-5 right-align">
                    <label for="ame2" class="col-form-label label-font-size"
                      >Α.Μ.Ε. #2</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="ame2"
                      id="ame2"
                      class="form-control input-content"
                      value="<%= company.ame2 %>"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="tameio3" class="col-form-label label-font-size"
                      >Ταμείο #3</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="tameio3"
                      id="tameio3">
                    </select>
                  </div>

                  <div class="col-1"></div>

                  <div class="col-1-5 right-align">
                    <label for="ame3" class="col-form-label label-font-size"
                      >Α.Μ.Ε. #3</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="ame3"
                      id="ame3"
                      class="form-control input-content"
                      value="<%= company.ame3 %>"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-2">
                  <div class="col-1-5 right-align">
                    <label for="tameio4" class="col-form-label label-font-size"
                      >Ταμείο #4</label
                    >
                  </div>
                  <div class="col-4">
                    <select
                      class="form-select selectpicker-dropdown-normal"
                      data-live-search="true"
                      name="tameio4"
                      id="tameio4">
                    </select>
                  </div>

                  <div class="col-1"></div>

                  <div class="col-1-5 right-align">
                    <label for="ame4" class="col-form-label label-font-size"
                      >Α.Μ.Ε. #4</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="ame4"
                      id="ame4"
                      class="form-control input-content"
                      value="<%= company.ame4 %>"
                    />
                  </div>
                </div>

                <div class="card-footer" style="margin-left: -1rem !important; margin-right: -1rem !important;
                margin-bottom: -1rem !important;">
                  <div
                    class="d-inline-block d-flex"
                    style="
                      margin-top: -0.5rem !important;
                      margin-bottom: -1rem !important;
                      margin-left: 10px !important;
                      margin-right: 10px !important;
                      justify-content: space-around;
                    "
                  >
                    <button
                      type="button" class="btn btn-brown rounded-4 buttons-content mt-2 w-20 submitButton" id="">
                      <i class="buttons-content bi bi-floppy"></i> Αποθήκευση
                    </button>
                    <a
                      class="btn btn-brown rounded-4 buttons-content mt-2 w-20"
                      href="/companies/genikastoixeia/">
                      <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή</a>
                  </div>
                </div>
              </div>
            </div>
          </form>
        </div>
      </section>

      <section class="sel_2_section visible" data-section="Δραστηριότητες">
        <div class="container">
          <form class="formRadius"enctype="multipart/form-data">
            <div class="card z-depth-5">
              <label
                class="card-header bg-header text-center headers-content"
                >Συντήρηση Στοιχείων Εταιρείας - Δραστηριότητες</label
              >
              <div class="card-body">
                <% for (let index = 1; index <= 6; index++) { %>
                  <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-1-5 right-align">
                      <label
                        <% if (index === 1) { %>
                          for=<%= `koddrast${index}` %>
                          class="col-form-label label-font-size"
                          >Κύρια Δραστηριότητα</label>
                        <% } else if (index === 6) { %>
                          for=<%= `koddrast${index}` %>
                          class="col-form-label label-font-size"
                          >ΚΑΔ Παραρτήματος</label>
                        <% } else { %>
                          for=<%= `koddrast${index}` %>
                          class="col-form-label label-font-size"
                          >Δευτ/σα Δραστ/τα #<%= index %></label>
                        <% } %>
                    </div>
                
                    <div class="col-1">
                      <input
                        type="text"
                        name=<%= `koddrast${index}` %>
                        id=<%= `koddrast${index}` %>
                        class="form-control input-content"
                        value=""
                        placeholder="Αναζήτηση"
                      />
                    </div>
                
                    <div class="col-8-5">
                      <select
                        class="form-select selectpicker-dropdown-small"
                        name=<%= `kad${index}` %>
                        id=<%= `select_kad${index}` %>
                      ></select>
                    </div>
                    <i
                      id=<%= `tooltipIcon_${index}` %>
                      class="bi bi-info-circle-fill col-0-5"
                      style="
                        cursor: pointer;
                        font-size: 20px;
                        color: rgb(128, 187, 253);">
                    </i>
                  </div>
                <% } %>

                <div class="card-footer" style="margin-left: -1rem !important; margin-right: -1rem !important;
                margin-bottom: -1rem !important;">
                  <div
                    class="d-inline-block d-flex"
                    style="
                      margin-top: -0.5rem !important;
                      margin-bottom: -1rem !important;
                      margin-left: 10px !important;
                      margin-right: 10px !important;
                      justify-content: space-around;
                    "
                  >
                    <button
                      type="button"
                      class="btn btn-brown rounded-4 mt-2 w-20 submitButton"
                      style="font-size: 0.8vw"
                    >
                      <i class="bi bi-floppy"></i> Αποθήκευση
                    </button>
                    <a
                      class="btn btn-brown rounded-4 mt-2 w-20"
                      style="font-size: 0.8vw"
                      style="vertical-align: middle"
                      href="/companies/genikastoixeia/"
                    >
                      <i class="bi bi-chevron-double-left"></i> Επιστροφή</a
                    >
                  </div>
                </div>
              </div>
            </div>
          </form>
        </div>
      </section>

      <section class="sel_3_section visible" data-section="Τεχνικός Ασφαλείας">
        <div class="container">
          <form class="formRadius"enctype="multipart/form-data">
            <div class="card z-depth-5">
              <label
                class="card-header bg-header text-center headers-content"
