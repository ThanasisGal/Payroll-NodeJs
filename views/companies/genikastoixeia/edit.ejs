                      maxlength="9"
                      pattern="[0-9]{1,}"
                    />
                  </div>

                  <div class="col-3"></div>

                  <div class="col-1-5 right-align">
                    <label for="adt" class="col-form-label label-font-size"
                      >Α.Δ.Τ.</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="adt"
                      id="adt"
                      class="form-control input-content"
                      value="<%= company.adt %>"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-0-5">
                  <div class="col-1-5 right-align">
                    <label for="odos" class="col-form-label label-font-size"
                      >Οδός</label
                    >
                  </div>
                  <div class="col-5">
                    <input
                      type="text"
                      name="odos"
                      id="odos"
                      class="form-control input-content"
                      value="<%= company.odos %>"
                    />
                  </div>

                  <div class="col-1-5 right-align">
                    <label for="arithmos" class="col-form-label label-font-size"
                      >Αριθμός</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="arithmos"
                      id="arithmos"
                      class="form-control input-content"
                      value="<%= company.arithmos %>"
                    />
