                      value="<%= company.texnikos_asfaleias %>"
                      disabled
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-3">
                  <div class="col-1-5 right-align">
                    <label
                      for="afm_ta"
                      class="col-form-label label-font-size field-required"
                      >Α.Φ.Μ</label
                    >
                  </div>
                  <div class="col-2">
                    <input
                      type="text"
                      name="afm_ta"
                      id="afm_ta"
                      class="form-control input-content"
                      value=""
                      maxlength="9"
                      pattern="[0-9]{1,}"
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-3">
                  <div class="col-1-5 right-align">
                    <label
                      for="eponymo_ta"
                      class="col-form-label label-font-size field-required"
                      >Επώνυμο/μία</label
                    >
                  </div>
                  <div class="col-5">
                    <input
                      type="text"
                      name="eponymo_ta"
                      id="eponymo_ta"
                      class="form-control input-content"
                      value=""
                      required
                    />
                  </div>

                  <div class="col-1-5 right-align">
                    <label for="onoma_ta" class="col-form-label label-font-size"
                      >Όνομα</label
                    >
                  </div>
                  <div class="col-3">
                    <input
                      type="text"
                      name="onoma_ta"
                      id="onoma_ta"
                      class="form-control input-content"
                      value=""
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-3">
