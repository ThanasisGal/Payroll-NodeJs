<div class="tadded-container">
  <div class="container-fluid">
    <div class="menu_Links">
      <ul>
        <li class="active">Σταθερά Στοιχεία</li>
        <li>Δραστηριότητες</li>
        <li>Τεχνικός Ασφαλείας</li>
        <li>Ιατρός Εργασίας</li>
        <li>Λογιστής</li>
        <li>Διάφορα</li>
        <li>Έμμεσος Εργοδότης</li>
        <li>Διάδοχος Εργοδότης</li>
      </ul>
    </div>
    <hr style="margin-top: -2rem" />
    
    <div class="sections">    
      <input type="hidden" name="companyId" id="companyId" class="form-control" value="<%= company._id %>" />
      <input type="hidden" name="companyTeam" id="companyTeam" class="form-control" value="<%= company.team %>" />
      <input type="hidden" name="companyNomos" id="companyNomos" class="form-control" value="<%= company.nomos %>" />
      <input type="hidden" name="companyDhmos" id="companyDhmos" class="form-control" value="<%= company.dhmos %>" />
      <input type="hidden" name="companyPolh" id="companyPolh" class="form-control" value="<%= company.polh %>" />
      <input type="hidden" name="companyLogisths" id="companyLogisths" class="form-control" value="<%= company.logisths ? company.logisths : '' %>" />
      <input type="hidden" name="companyTexnikos" id="companyTexnikos" class="form-control" value="<%= company.texnikos_asfaleias ? company.texnikos_asfaleias : '' %>" />
      <input type="hidden" name="companyIatros" id="companyIatros" class="form-control" value="<%= company.iatros_ergasias ? company.iatros_ergasias : '' %>" />
      <input type="hidden" name="currentImage" id="currentImage" class="form-control" value="<%= company.sfragida ? company.sfragida : '' %>" />
      <input type="hidden" name="imagePath" id="imagePath" class="form-control" value="<%= company.imagePath ? company.imagePath : '' %>" />
      <input type="hidden" name="companyEmmesosErgodoths" id="companyEmmesosErgodoths" class="form-control" value="<%= company.emmesos_ergodoths ? company.emmesos_ergodoths : '' %>" />
      <input type="hidden" name="companyDiadoxosErgodoths" id="companyDiadoxosErgodoths" class="form-control" value="<%= company.diadoxos_ergodoths ? company.diadoxos_ergodoths : '' %>" />

      <section class="sel_1_section visible" data-section="Σταθερά Στοιχεία">
        <div class="container">
          <form class="formRadius"enctype="multipart/form-data">
            <div class="card z-depth-5">
              <label
