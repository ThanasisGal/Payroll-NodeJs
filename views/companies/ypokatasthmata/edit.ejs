<div class="tadded-container">
    <div class="container-fluid" style="height: 100vh !important; padding: 0;">
        <div class="menu_Links">
            <ul>
                <li class="active" style="margin-left: 1.5rem; margin-right: .5rem;">Σταθερά Στοιχεία</li>
                <li>Οικοδομικά Έργα</li>
            </ul>
        </div>
        <hr style="margin-top: -2rem" />

        <div class="sections">
            <section class="sel_1_section visible" data-section="Σταθερά Στοιχεία">
                <div>
                    <form class="formRadius">
                        <div class="card d-flex flex-column z-depth-5" style="width: 97%; margin-left: 1.5%; overflow: hidden;">

                            <div class="card-header p-2" style="height: 3.5rem !important;">

                                <label class="text-center w-100 headers-content">
                                    Συντήρηση Στοιχείων Υποκαταστήματος (ΣΤΑΘΕΡΑ ΣΤΟΙΧΕΙΑ)
                                </label>
                            </div>
                    
                            <div class="card-body overflow-auto flex-grow-1 w-100" id="cardBody" style="background-color: #ffffff;">
                            
                                <input type="hidden" name="companyId" id="companyId"    class="form-control" value="<%= company._id %>" />
                                <input type="hidden" name="companyKodikos" id="companyKodikos" class="form-control" value="<%= company.kod %>" />
                                <input type="hidden" name="companyTeam" id="companyTeam" class="form-control" value="<%= company.team %>" />
                                <input type="hidden" name="ypokatasthmaId" id="ypokatasthmaId" class="form-control" value="<%= ypokatasthma._id %>" />
                                <input type="hidden" name="ypokatasthmataNomos" id="ypokatasthmataNomos" class="form-control" value="<%= ypokatasthma.nomos %>" />
                                <input type="hidden" name="ypokatasthmataDhmos" id="ypokatasthmataDhmos" class="form-control" value="<%= ypokatasthma.dhmos %>" />
                                <input type="hidden" name="ypokatasthmataPolh" id="ypokatasthmataPolh" class="form-control" value="<%= ypokatasthma.polh %>" />
                                <input type="hidden" name="ypokatasthmataEfka" id="ypokatasthmataEfka" class="form-control" value="<%= ypokatasthma.efka %>" />
            
                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size">
                                            Επιλεγμένη Εταιρεία
                                        </label>
                                    </div>

                                    <div class="col-8 left-align" style="font-size: 1rem; color: #1f6d00">
                                        <label class="col-form-label field-required" style="font-size: 1.2rem; color: #1f6d00">

                                            <% if (company && company.kod && company.kod.length > 0) { %>
                                                <%- company.kod + "&nbsp;&nbsp;&nbsp; " + company.eponymia + " &nbsp;&nbsp;" + company.firstname %>
                                            <% } %>
                                        </label>
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size"
                                            >Κωδικός Υποκ/τος
                                        </label>
                                    </div>

                                    <div class="col-1">
                                        <input
                                            type="text"
                                            name="kodikos"
                                            id="kodikos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.kodikos %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <hr class="division"></hr>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="perigrafh"
                                            class="col-form-label label-font-size field-required">
                                                Περιγραφή
                                        </label>
                                    </div>
                                    <div class="col-10-5">
                                        <input
                                            type="text"
                                            name="perigrafh"
                                            id="perigrafh"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.perigrafh %>"
                                            required
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="odos" class="col-form-label label-font-size">
                                            Οδός
                                        </label>
                                    </div>
                                    <div class="col-5">
                                        <input
                                            type="text"
                                            name="odos"
                                            id="odos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.odos %>"
                                        />
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label for="arithmos" class="col-form-label label-font-size">
                                            Αριθμός
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="arithmos"
                                            id="arithmos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.arithmos %>"
                                        />
                                    </div>

                                    <div class="col-1 right-align">
                                        <label for="tk" class="col-form-label label-font-size">
                                            Τ.Κ.
                                        </label>
                                    </div>
                                    <div class="col-1">
                                        <input
                                            type="text"
                                            name="tk"
                                            id="tk"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.tk %>"
                                            maxlength="5"
                                            pattern="[0-9]{1,}"
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center field-required mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="perifereies"
                                            class="col-form-label label-font-size">
                                                Περιφέρεια
                                        </label>
                                    </div>

                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="perifereies"
                                            id="perifereies">
                                            <% perifereies.forEach(function(perifereia) { %> 
                                                <option value="<%= perifereia.kodikos %>"
                                                    <% if(perifereia.kodikos == ypokatasthma.perifereia) { %>
                                                        selected
                                                    <% } %> >
                                                    <%= perifereia.perigrafh %>
                                                </option>
                                            <% }); %>
                                        ></select>
                                    </div>

                                    <div class="col-1"></div>

                                    <div class="col-1-5 right-align">
                                        <label for="nomos" class="col-form-label label-font-size field-required">
                                            Περιφ. Ενότητα
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="nomos"
                                            id="nomos"
                                            style="font-size: 1vw"
                                            required>
                                        </select>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="dhmos" class="col-form-label label-font-size field-required">
                                            Δημοτ. Ενότητα
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="dhmos"
                                            id="dhmos"
                                            style="font-size: 1vw"
                                            required>
                                        </select>
                                    </div>

                                    <div class="col-1"></div>

                                    <div class="col-1-5 right-align">
                                        <label for="polh" class="col-form-label label-font-size field-required">
                                            Δημοτ.Διαμέρισμα
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="polh"
                                            id="polh"
                                            style="font-size: 1vw"
                                            required>
                                        </select>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                        for="drasthriothta"
                                        class="col-form-label label-font-size">
                                            Δραστηριότητα
                                        </label>
                                    </div>
                                    <div class="col-5">
                                        <input
                                            type="text"
                                            name="drasthriothta"
                                            id="drasthriothta"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.drasthriothta %>"
                                        />
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="pararthma_efka"
                                            class="col-form-label label-font-size">
                                                Παράρτημα ΕΦΚΑ
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="pararthma_efka"
                                            id="pararthma_efka"
                                            data-selected="<%= ypokatasthma.pararthma_efka %>">
                                        </select>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="thlefono" class="col-form-label label-font-size">
                                            Τηλέφωνο
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="thlefono"
                                            id="thlefono"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.thlefono %>"
                                            maxlength="10"
                                            pattern="[0-9]{1,}"
                                        />
                                    </div>

                                    <div class="col-1 right-align">
                                        <label for="fax" class="col-form-label label-font-size">
                                            Fax
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="fax"
                                            id="fax"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.fax %>"
                                            maxlength="10"
                                            pattern="[0-9]{1,}"
                                        />
                                    </div>
                                    <div class="col-1-5 right-align">
                                        <label for="email" class="col-form-label label-font-size">
                                            e-Mail
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <input
                                            type="email"
                                            name="email"
                                            id="email"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.email %>"
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="epoxikothta" class="col-form-label label-font-size">
                                            Εποχ/τητα εργοδότη
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center mb-1">
                                        <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" d="epoxikothta" name="epoxikothta" <%= ypokatasthma.epoxikothta ? 'checked' : '' %> value="" /> 
                                        <label for="epoxikothta"  id="label-epoxikothta"  style="margin-left: .75rem; font-weight:  600;">
                                            ΟΧΙ
                                        </label>
                                    </div>

                                    <div class="col-4"></div>

                                    <div class="col-1-5 right-align">
                                        <label for="apasxolhsh5hmeron" class="col-form-label label-font-size">
                                            5ήμερη Απασχόληση
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center">
                                        <input 
                                            type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="apasxolhsh5hmeron" name="apasxolhsh5hmeron" <%= ypokatasthma.apasxolhsh5hmeron ? 'checked' : '' %> value="" /> 
                                        <label for="apasxolhsh5hmeron" 
                                            id="lab  el-apasxolhsh5hmeron"    style="margin-left: .75rem; font-weight: 600;">
                                            ΟΧΙ
                                        </label>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="ap_pinaka"
                                            class="col-form-label label-font-size">
                                                Α.Π. Κατάθεσης
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="ap_pinaka"
                                            id="ap_pinaka"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.ap_pinaka %>"
                                        />
                                    </div>

                                    <div class="col-3"></div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="hmnia_katatheshs"
                                            class="col-form-label label-font-size">
                                            Ημ/νία Κατάθεσης
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="date"
                                            name="hmnia_katatheshs"
                                            id="hmnia_katatheshs"
                                            class="date-control"
                                            value="<%= ypokatasthma.hmnia_katatheshs %>"
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-4">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="sepe"
                                            class="col-form-label label-font-size">
                                            Παράρτημα ΣΕΠΕ
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="sepe"
                                            id="sepe"
                                            data-selected="<%= ypokatasthma.sepe_ergoy %>">
                                        </select>
                                    </div>

                                    <div class="col-1"></div>
                                    
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="dypa"
                                            class="col-form-label label-font-size">
                                                Παράρτημα ΔΥΠΑ
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="dypa"
                                            id="dypa"
                                            data-selected="<%= ypokatasthma.dypa_ergoy %>">
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer" 
                                style="
                                    margin-top: -1.5rem !important;
                                    margin-left: -1rem !important; 
                                    margin-right: -1rem !important;">
                                <div 
                                    class="d-inline-block d-flex"
                                    style="
                                        margin-top: -0.5rem !important;
                                        margin-bottom: -1rem !important;
                                        margin-left: 10px !important;
                                        margin-right: 10px !important;
                                        justify-content: space-around;">
                        
                                    <button type="button" class="btn btn-brown rounded-4 buttons-contents mt-2 w-20 submitButton"><i class="bi bi-floppy"></i> Αποθήκευση </button>
                                    <a class="btn btn-brown rounded-4 buttons-contents mt-2 w-20" href="/companies/ypokatasthmata"><i class="bi bi-chevron-double-left"></i> Επιστροφή </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </section>

            <section class="sel_2_section visible" data-section="Οικοδομικά Έργα">
                <div>
                    <form class="formRadius">
                        <div class="card z-depth-5" style="width: 97%; margin-left: 1.5%; overflow: hidden;">

                            <div class="card-header p-2" style="height: 3.5rem !important;">
                                <label class="text-center w-100 headers-content">
                                    Συντήρηση Στοιχείων Υποκαταστήματος (ΟΙΚΟΔΟΜΙΚΑ ΕΡΓΑ)
                                </label>
                            </div>

                            <div class="card-body overflow-auto flex-grow-1 w-100" id="cardBody" style="background-color: #ffffff;">
                                <div class="row form-group g-3 align-items-center">
                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size">
                                            Επιλεγμένη Εταιρεία
                                        </label>
                                    </div>

                                    <div class="col-8 left-align">
                                        <label class="col-form-label field-required" style="font-size: 1.2rem; color: #1f6d00">
                                            <% if (company && company.kod && company.kod.length > 0) { %>
                                                <%- company.kod + "&nbsp;&nbsp;&nbsp; " + company.eponymia + " &nbsp;&nbsp;" +
                                                company.firstname %>
                                            <% } %>
                                        </label>
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size">
                                            Κωδικός Υποκ/τος
                                        </label>
                                    </div>

                                    <div class="col-1">
                                        <input
                                            type="text"
                                            name="kodikos"
                                            id="kodikos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.kodikos %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <hr class="division" style="margin-bottom: -0.3rem;"></hr>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="oikodomika_erga" class="col-form-label label-font-size">
                                            Οικοδομικά Έργα
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center">
                                        <input 
                                            type="checkbox" 
                                            class="form-check-input custom-checkbox checkbox-class" 
                                            id="oikodomika_erga" 
                                            name="oikodomika_erga" 
                                            <%= ypokatasthma.oikodomika_erga ? 'checked' : '' %>
                                            value="" /> 
                                        <label for="oikodomika_erga" id="label-oikodomika_erga" style="margin-left: .75rem; font-weight: 600;">ΟΧΙ</label>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="amoe"
                                            class="col-form-label label-font-size">
                                            Α.Μ.Ο.Ε.
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="amoe"
                                            id="amoe"
                                            class="form-control input-contents"
                                            data-toggle="amoe"
                                            value="<%= ypokatasthma.amoe %>"
                                            disabled
                                        />
                                    </div>

                                    <div class="col-3"></div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="eidos_ergoy"
                                            class="col-form-label label-font-size">
                                            Περιγραφή Έργου
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <input
                                            type="text"
                                            name="eidos_ergoy"
                                            id="eidos_ergoy"
                                            class="form-control input-contents"
                                            data-toggle="eidos_ergoy"
                                            value="<%= ypokatasthma.eidos_ergoy %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="username_ergoy"
                                            class="col-form-label label-font-size field-required">
                                            Username Οικ.Έργου
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="username_ergoy"
                                            id="username_ergoy"
                                            class="form-control input-contents"
                                            data-toggle="username_ergoy"
                                            value="<%= ypokatasthma.username_ergoy %>"
                                            disabled
                                        />
                                    </div>

                                    <div class="col-3"></div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="password_ergoy"
                                            class="col-form-label label-font-size field-required">
                                            Password Οικ.Έργου
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="password_ergoy"
                                            id="password_ergoy"
                                            class="form-control input-contents"
                                            data-toggle="password_ergoy"
                                            value="<%= ypokatasthma.password_ergoy %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label 
                                            for="ypergolabia" 
                                            class="col-form-label label-font-size">Υπεργολαβία
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center">
                                        <input 
                                            type="checkbox" 
                                            class="form-check-input custom-checkbox checkbox-class" 
                                            data-toggle="ypergolabia" 
                                            id="ypergolabia" 
                                            name="ypergolabia"
                                            <%= ypokatasthma.ypergolabia ? 'checked' : '' %>
                                            value="" disabled 
                                        /> 
                                        <label 
                                            for="ypergolabia" 
                                            id="label-ypergolabia"
                                            style="margin-left: .75rem; font-weight: 600;">
                                            ΟΧΙ
                                        </label>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="ame_ergolaboy"
                                            class="col-form-label label-font-size field-required">
                                            Α.Μ.Ε. Εργολάβου
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="ame_ergolaboy"
                                            id="ame_ergolaboy"
                                            class="form-control input-contents"
                                            data-toggle-additional="ypergolabia"
                                            data-toggle="ame_ergolaboy"
                                            value="<%= ypokatasthma.ame_ergolaboy %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="eponymo_ergolaboy"
                                            class="col-form-label label-font-size">
                                            Επώνυμο Εργολάβου
                                        </label>
                                    </div>
                                    <div class="col-5">
                                        <input
                                            type="text"
                                            name="eponymo_ergolaboy"
                                            id="eponymo_ergolaboy"
                                            class="form-control input-contents"
                                            data-toggle-additional="ypergolabia"
                                            data-toggle="eponymo_ergolaboy"
                                            value="<%= ypokatasthma.eponymo_ergolaboy %>"
                                            disabled
                                        />
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="onoma_ergolaboy"
                                            class="col-form-label label-font-size">
                                            Όνομα Εργολάβου
                                        </label>
                                    </div>
                                    <div class="col-3">
                                        <input
