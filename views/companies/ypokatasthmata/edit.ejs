<div class="tadded-container">
    <body data-mode="<%= mode %>" data-context="<%= context %>"></body>

    <div class="container-fluid height-vh-100 padding-0">
        <div class="menu_Links">
            <ul>
                <li class="active margin-left-1_5rem margin-right--0_5rem">Σταθερά Στοιχεία</li>
                <li>Οικοδομικά Έργα</li>
            </ul>
        </div>
        <hr class="margin-top--2rem" />

        <% const safe = (k) => (rec && rec[k]) || ''; %>

        <div class="sections">
            <section class="sel_1_section visible" data-section="Σταθερά Στοιχεία">
                <div>
                    <form class="formRadius">

                        <%- include('../../partials/_csrfField') %>
                        
                        <div class="card d-flex flex-column z-depth-5 width-percent-97 margin-left-percent-1_5 overflow-hidden">

                            <div class="card-header p-2 height-rem-3_5">
                                <label class="text-center w-100 headers-content sectionTitle"> </label>
                            </div>
                    
                            <div class="card-body overflow-auto flex-grow-1 w-100 bg-white" id="cardBody1">
                                <input type="hidden" name="companyId" id="companyId"    class="form-control" value="<%= company._id %>" />
                                <input type="hidden" name="companyKodikos" id="companyKodikos" class="form-control" value="<%= company.kod %>" />
                                <input type="hidden" name="companyTeam" id="companyTeam" class="form-control" value="<%= company.team %>" />
                                <input type="hidden" name="ypokatasthmaId" id="ypokatasthmaId" class="form-control" value="<%= ypokatasthma._id %>" />
                                <input type="hidden" name="ypokatasthmataNomos" id="ypokatasthmataNomos" class="form-control" value="<%= ypokatasthma.nomos %>" />
                                <input type="hidden" name="ypokatasthmataDhmos" id="ypokatasthmataDhmos" class="form-control" value="<%= ypokatasthma.dhmos %>" />
                                <input type="hidden" name="ypokatasthmataPolh" id="ypokatasthmataPolh" class="form-control" value="<%= ypokatasthma.polh %>" />
                                <input type="hidden" name="ypokatasthmataEfka" id="ypokatasthmataEfka" class="form-control" value="<%= ypokatasthma.pararthma_efka %>" />
                                <input type="hidden" name="ypokatasthmataEfkaErgolaboy" id="ypokatasthmataEfkaErgolaboy" class="form-control" value="<%= ypokatasthma.pararthma_efka_ergolaboy %>" />
                                <input type="hidden" name="ypokatasthmataSepe" id="ypokatasthmataSepe" class="form-control" value="<%= ypokatasthma.sepe_ergoy %>" />
                                <input type="hidden" name="ypokatasthmataDypa" id="ypokatasthmataDypa" class="form-control" value="<%= ypokatasthma.dypa_ergoy %>" />
            
                                <div class="row form-group g-3 align-items-center">
                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size">
                                            Επιλεγμένη Εταιρεία
                                        </label>
                                    </div>
                                    <div class="col-8 left-align font-size-rem-1_1 cgreen">
                                        <label>
                                            <% if (company && company.kod && company.kod.length > 0) { %>
                                                <%- company.kod + "&nbsp;&nbsp;&nbsp; " + company.eponymia + " &nbsp;&nbsp;" + company.firstname %>
                                            <% } %>
                                        </label>
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size"
                                            >Κωδικός Υποκ/τος
                                        </label>
                                    </div>

                                    <div class="col-1">
                                        <input
                                            type="text"
                                            name="kodikos"
                                            id="kodikos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.kodikos %>"
                                            readonly
                                        />
                                    </div>
                                </div>

                                <hr class="division"></hr>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="perigrafh"
                                            class="col-form-label label-font-size field-required">
                                                Περιγραφή
                                        </label>
                                    </div>
                                    <div class="col-10-5">
                                        <input
                                            type="text"
                                            name="perigrafh"
                                            id="perigrafh"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.perigrafh %>"
                                            required
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="odos" class="col-form-label label-font-size">
                                            Οδός
                                        </label>
                                    </div>
                                    <div class="col-5">
                                        <input
                                            type="text"
                                            name="odos"
                                            id="odos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.odos %>"
                                        />
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label for="arithmos" class="col-form-label label-font-size">
                                            Αριθμός
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="arithmos"
                                            id="arithmos"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.arithmos %>"
                                        />
                                    </div>

                                    <div class="col-1 right-align">
                                        <label for="tk" class="col-form-label label-font-size">
                                            Τ.Κ.
                                        </label>
                                    </div>
                                    <div class="col-1">
                                        <input
                                            type="text"
                                            name="tk"
                                            id="tk"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.tk %>"
                                            maxlength="5"
                                            pattern="[0-9]{1,}"
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center field-required mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="perifereies"
                                            class="col-form-label label-font-size">
                                                Περιφέρεια
                                        </label>
                                    </div>

                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="perifereies"
                                            id="perifereies">
                                            <% perifereies.forEach(function(perifereia) { %> 
                                                <option value="<%= perifereia.kodikos %>"
                                                    <% if(perifereia.kodikos == ypokatasthma.perifereia) { %>
                                                        selected
                                                    <% } %> >
                                                    <%= perifereia.perigrafh %>
                                                </option>
                                            <% }); %>
                                        ></select>
                                    </div>

                                    <div class="col-1"></div>

                                    <div class="col-1-5 right-align">
                                        <label for="nomos" class="col-form-label label-font-size field-required">
                                            Περιφ. Ενότητα
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal ont-size-vw-1"
                                            data-live-search="true"
                                            name="nomos"
                                            id="nomos"
                                            required>
                                        </select>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="dhmos" class="col-form-label label-font-size field-required">
                                            Δημοτ. Ενότητα
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal"
                                            data-live-search="true"
                                            name="dhmos"
                                            id="dhmos"
                                            style="font-size: 1vw"
                                            required>
                                        </select>
                                    </div>

                                    <div class="col-1"></div>

                                    <div class="col-1-5 right-align">
                                        <label for="polh" class="col-form-label label-font-size field-required">
                                            Δημοτ.Διαμέρισμα
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <select
                                            class="form-select selectpicker-dropdown-normal ont-size-vw-1"
                                            data-live-search="true"
                                            name="polh"
                                            id="polh"
                                            required>
                                        </select>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                        for="drasthriothta"
                                        class="col-form-label label-font-size">
                                            Δραστηριότητα
                                        </label>
                                    </div>
                                    <div class="col-5">
                                        <input
                                            type="text"
                                            name="drasthriothta"
                                            id="drasthriothta"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.drasthriothta %>"
                                        />
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="pararthma_efka"
                                            class="col-form-label label-font-size">
                                                Παράρτημα ΕΦΚΑ
                                        </label>
                                    </div>

                                    <input
                                        type="hidden"
                                        name="pararthma_efka_stathera"
                                        id="pararthma_efka_stathera"
                                        class="form-control input-contents"
                                        value="<%= (ypokatasthma && ypokatasthma.pararthma_efka)
                                            ? String(ypokatasthma.pararthma_efka)
                                            : String(safe('pararthma_efka_stathera')) %>"
                                        readonly
                                    />

                                    <div class="col-3-75">
                                        <select
                                            id="pararthma_efka"
                                            name="pararthma_efka"
                                            class="tom-dropdown selectpicker-dropdown-normal left-align"
                                            aria-label="Παράρτημα ΕΦΚΑ"
                                            data-api="/api/dropdown/pararthmataEfka"
                                            single
                                            data-target-input=<%= `pararthma_efka_stathera` %>
                                            data-preselect=<%= `pararthma_efka_stathera` %>
                                            data-preload-all="true"
                                            data-pad-length="3"
                                            data-xrhsh-related="false"
                                            data-team-related="false"
                                            data-company-related="false"
                                            data-mhnas-related="false"
                                            placeholder="Αναζήτηση Παραρτήματος ΕΦΚΑ">
                                        </select>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="thlefono" class="col-form-label label-font-size">
                                            Τηλέφωνο
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="thlefono"
                                            id="thlefono"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.thlefono %>"
                                            maxlength="10"
                                            pattern="[0-9]{1,}"
                                        />
                                    </div>

                                    <div class="col-1 right-align">
                                        <label for="fax" class="col-form-label label-font-size">
                                            Fax
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="fax"
                                            id="fax"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.fax %>"
                                            maxlength="10"
                                            pattern="[0-9]{1,}"
                                        />
                                    </div>
                                    <div class="col-1-5 right-align">
                                        <label for="email" class="col-form-label label-font-size">
                                            e-Mail
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <input
                                            type="email"
                                            name="email"
                                            id="email"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.email %>"
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="epoxikothta" class="col-form-label label-font-size">
                                            Εποχ/τητα εργοδότη
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center mb-1">
                                        <input type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="epoxikothta" name="epoxikothta" <%= ypokatasthma.epoxikothta ? 'checked' : '' %> value="" /> 
                                        <label for="epoxikothta"  id="label-epoxikothta"  class="margin-left-0_75rem fw600">
                                            ΟΧΙ
                                        </label>
                                    </div>

                                    <div class="col-4"></div>

                                    <div class="col-1-5 right-align">
                                        <label for="apasxolhsh5hmeron" class="col-form-label label-font-size">
                                            5ήμερη Απασχόληση
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center">
                                        <input 
                                            type="checkbox" class="form-check-input custom-checkbox checkbox-class" id="apasxolhsh5hmeron" name="apasxolhsh5hmeron" <%= ypokatasthma.apasxolhsh5hmeron ? 'checked' : '' %> value="" /> 
                                        <label for="apasxolhsh5hmeron" 
                                            id="label-apasxolhsh5hmeron" class="margin-left-0_75rem fw600">
                                            ΟΧΙ
                                        </label>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="ap_pinaka"
                                            class="col-form-label label-font-size">
                                                Α.Π. Κατάθεσης
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="ap_pinaka"
                                            id="ap_pinaka"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.ap_pinaka %>"
                                        />
                                    </div>

                                    <div class="col-3"></div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="hmnia_katatheshs"
                                            class="col-form-label label-font-size">
                                            Ημ/νία Κατάθεσης
                                        </label>
                                    </div>

                                    <% const dateForInput = d => d ? new Date(d).toISOString().slice(0,10) : '' ; %>

                                    <div class="col-2">
                                        <input
                                            type="date"
                                            name="hmnia_katatheshs"
                                            id="hmnia_katatheshs"
                                            class="date-control"
                                            value="<%= dateForInput(ypokatasthma.hmnia_katatheshs) %>"
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-4">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="sepe"
                                            class="col-form-label label-font-size">
                                            Παράρτημα ΣΕΠΕ
                                        </label>
                                    </div>
                                    <input
                                        type="hidden"
                                        name="sepe_stathera"
                                        id="sepe_stathera"
                                        class="form-control input-contents"
                                        value="<%= (ypokatasthma && ypokatasthma.sepe_ergoy)
                                            ? String(ypokatasthma.sepe_ergoy)
                                            : String(safe('sepe_ergoy_stathera')) %>"
                                        readonly
                                    />

                                    <div class="col-3-75">
                                        <select
                                            id="sepe"
                                            name="sepe"
                                            class="tom-dropdown selectpicker-dropdown-normal left-align"
                                            aria-label="Παράρτημα ΣΕΠΕ"
                                            data-api="/api/dropdown/ypokatasthmata/sepe"
                                            single
                                            data-target-input=<%= `sepe_stathera` %>
                                            data-preselect=<%= `sepe_stathera` %>
                                            data-preload-all="true"
                                            data-pad-length="3"
                                            data-xrhsh-related="false"
                                            data-team-related="false"
                                            data-company-related="false"
                                            data-mhnas-related="false"
                                            placeholder="Αναζήτηση Παραρτήματος ΣΕΠΕ">
                                        </select>
                                    </div>

                                    <div class="col-1-25-1"></div>
                                    
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="dypa"
                                            class="col-form-label label-font-size">
                                            Παράρτημα ΔΥΠΑ
                                        </label>
                                    </div>

                                    <input
                                        type="hidden"
                                        name="dypa_stathera"
                                        id="dypa_stathera"
                                        class="form-control input-contents"
                                        value="<%= (ypokatasthma && ypokatasthma.dypa_ergoy) ? String(ypokatasthma.dypa_ergoy) : String(safe('dypa_ergoy_stathera')) %>"
                                        readonly
                                    />

                                    <div class="col-3-75">
                                        <select
                                            id="dypa"
                                            name="dypa"
                                            class="tom-dropdown selectpicker-dropdown-normal left-align"
                                            aria-label="Παράρτημα ΔΥΠΑ"
                                            data-api="/api/dropdown/ypokatasthmata/dypa"
                                            single
                                            data-target-input=<%= `dypa_stathera` %>
                                            data-preselect=<%= `dypa_stathera` %>
                                            data-preload-all="true"
                                            data-pad-length="3"
                                            data-xrhsh-related="false"
                                            data-team-related="false"
                                            data-company-related="false"
                                            data-mhnas-related="false"
                                            placeholder="Αναζήτηση Παραρτήματος ΔΥΠΑ">
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer cardFooter">
                                <div class="d-inline-block d-flex cardFooter01">
                                    <button
                                        type="button"
                                        class="btn btn-brown rounded-4 buttons-contents mt-2 w-20 submitButton">
                                        <i class="bi bi-floppy"></i> Αποθήκευση
                                    </button>
                                    <a
                                        class="btn btn-brown rounded-4 buttons-contents mt-2 w-20"
                                        href="/companies/ypokatasthmata"
                                        ><i class="bi bi-chevron-double-left"></i> Επιστροφή
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </section>

            <section class="sel_2_section visible" data-section="Οικοδομικά Έργα">
                <div>
                    <form class="formRadius">

                        <%- include('../../partials/_csrfField') %>

                        <div class="card d-flex flex-column z-depth-5 width-percent-97 margin-left-percent-1_5 overflow-hidden">

                            <div class="card-header p-2 height-rem-3_5">
                                <label class="text-center w-100 headers-content sectionTitle"> </label>
                                </label>
                            </div>

                            <div class="card-body overflow-auto flex-grow-1 w-100 bg-white" id="cardBody2">
                                <div class="row form-group g-3 align-items-center">
                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size">
                                            Επιλεγμένη Εταιρεία
                                        </label>
                                    </div>

                                    <div class="col-8 left-align font-size-rem-1_1 cgreen">
                                        <label>
                                            <% if (company && company.kod && company.kod.length > 0) { %>
                                                <%- company.kod + "&nbsp;&nbsp;&nbsp; " + company.eponymia + " &nbsp;&nbsp;" +
                                                company.firstname %>
                                            <% } %>
                                        </label>
                                    </div>

                                    <div class="col-1-5 right-align">
                                        <label class="col-form-label label-font-size">
                                            Κωδικός Υποκ/τος
                                        </label>
                                    </div>

                                    <div class="col-1">
                                        <input
                                            type="text"
                                            name="kodikos_oikodomika"
                                            id="kodikos_oikodomika"
                                            class="form-control input-contents"
                                            value="<%= ypokatasthma.kodikos %>"
                                            readonly
                                        />
                                    </div>
                                </div>

                                <hr class="division"></hr>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label for="oikodomika_erga" class="col-form-label label-font-size">
                                            Οικοδομικά Έργα
                                        </label>
                                    </div>
                                    <div class="col-1 left-align checkbox-flex-center">
                                        <input class="form-check-input custom-checkbox checkbox-class" 
                                            type="checkbox" 
                                            id="oikodomika_erga" 
                                            name="oikodomika_erga" 
                                            <%= ypokatasthma.oikodomika_erga ? 'checked' : '' %>
                                            value="" /> 
                                        <label 
                                            for="oikodomika_erga" id="label-oikodomika_erga" class="margin-left-0_75rem fw600">ΟΧΙ
                                        </label>
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="amoe"
                                            class="col-form-label label-font-size">
                                            Α.Μ.Ο.Ε.
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="amoe"
                                            id="amoe"
                                            class="form-control input-contents"
                                            data-toggle="amoe"
                                            value="<%= ypokatasthma.amoe %>"
                                            disabled
                                        />
                                    </div>

                                    <div class="col-3"></div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="eidos_ergoy"
                                            class="col-form-label label-font-size">
                                            Περιγραφή Έργου
                                        </label>
                                    </div>
                                    <div class="col-4">
                                        <input
                                            type="text"
                                            name="eidos_ergoy"
                                            id="eidos_ergoy"
                                            class="form-control input-contents"
                                            data-toggle="eidos_ergoy"
                                            value="<%= ypokatasthma.eidos_ergoy %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label
                                            for="username_ergoy"
                                            class="col-form-label label-font-size field-required">
                                            Username Οικ.Έργου
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="username_ergoy"
                                            id="username_ergoy"
                                            class="form-control input-contents"
                                            data-toggle="username_ergoy"
                                            value="<%= ypokatasthma.username_ergoy %>"
                                            disabled
                                        />
                                    </div>

                                    <div class="col-3"></div>

                                    <div class="col-1-5 right-align">
                                        <label
                                            for="password_ergoy"
                                            class="col-form-label label-font-size field-required">
                                            Password Οικ.Έργου
                                        </label>
                                    </div>
                                    <div class="col-2">
                                        <input
                                            type="text"
                                            name="password_ergoy"
                                            id="password_ergoy"
                                            class="form-control input-contents"
                                            data-toggle="password_ergoy"
                                            value="<%= ypokatasthma.password_ergoy %>"
                                            disabled
                                        />
                                    </div>
                                </div>

                                <div class="row form-group g-3 align-items-center mb-1">
                                    <div class="col-1-5 right-align">
                                        <label 
