<div
  class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3 pb-2 mb-3 border-bottom" style="background-image: url('https://cdn.webpayrollsolutions.com/assets/img/wps1.png'); background-repeat: no-repeat; background-position: 0% 50%;">

  <form
    name="Ypokatasthmata"
    class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0"
    role="search"
    method="POST"
    action="/companies/ypokatasthmata/search">

    <div class="input-group">
      <span
        ><i
          class="bi bi-search bi-search-swing"
          style="font-size: 1.3vw; font-weight: 600; color: #006400"
        ></i
        >&nbsp;</span
      >
      <input
        type="search"
        name="searchTerm"
        id="searchInput"
        class="form-control rounded-end-2 ms-auto"
        placeholder="Αναζήτηση... ( πατείστε Enter )"
        aria-label="Search"
      />
    </div>
  </form>
</div>

<div class="card d-flex flex-column z-depth-5" style="width: 80%; margin-left: 10%">
  <div class="card-header p-0" style="height: 3.5rem !important;">
    <label class="text-center w-100 headers-content mt-2">
      Διαχείριση Υποκαταστημάτων
    </label>
  </div>
  <div>
    <table class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
      <thead style="font-size: 0.9vw;">
        <tr>
          <th scope="col" class="color-brown col-1">Κωδ.<i class="sort-icon bi"></i></th>
          <th scope="col" class="color-brown col-3">Περιγραφή<i class="sort-icon bi"></i></th>
          <th scope="col" class="color-brown col-3">Οδός<i class="sort-icon bi"></i></th>
          <th scope="col" class="color-brown col-1">Αριθμός<i class="sort-icon bi"></i></th>
          <th scope="col" class="color-brown col-3">Δημοτικό Διαμέρισμα<i class="sort-icon bi"></i></th>
        </tr>
      </thead>
    </table>
  </div>

  <div class="card-body p-0 overflow-auto flex-grow-1" style="height: 58vh; background-color: #ffffff;">
    <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
      <body>
        <% if (ypokatasthmata.length !== 0) { %>
          <% ypokatasthmata.forEach(element => { %>
            <tr class="input-content-regular" data-id="<%= element._id %>" >
              <td class="col-1"><%= element.kodikos %></td>
              <td class="col-3"><%= element.perigrafh %></td>
              <td class="col-3"><%= element.odos %></td>
              <td class="col-1"><%= element.arithmos %></td>
              <td class="col-3"><%= element.polhInfo.perigrafh %></td>    <!--Ενημερώνεται από INNER JOIN-->
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
          </tr>
        <% } %>
      </body>
    </table>
  </div>

  <div class="card-footer mt-auto">
    <div class="d-inline-block d-flex" style="
        margin-top: -0.5rem !important;
        margin-bottom: 2rem !important;
        margin-left: 0.625rem !important;
        margin-right: 0.625rem !important;
        justify-content: space-around;">

      <a 
        id="add-btn""
        href="/companies/ypokatasthmata/add" 
        role="button"
        data-bs-toggle="tooltip" title="Προσθήκη νέου υποκαταστήματος"
        data-bs-placement="bottom" 
        data-tooltip-max-width="15vw"
        class="btn btn-brown rounded-4 mb-3 buttons-content mt-2 col-2 
        <% if (!userPrivileges.admin && !userPrivileges.create) { %>
          disabled-link
        <% } %>"
        <% if (!userPrivileges.admin && !userPrivileges.create) { %>
          onclick="event.preventDefault();"
        <% } %> >
        <i class="buttons-content bi bi-plus-circle"></i> Εισαγωγή
      </a>
      
      <a 
        id="edit-btn""
        href="#" 
        role="button"
        data-bs-toggle="tooltip" title="Εμφάνιση - Διόρθωση των στοιχείων του επιλεγμένου υποκαταστήματος"
        data-tooltip-max-width="15vw"
        data-bs-placement="bottom" 
        class="btn btn-brown rounded-4 mb-3 buttons-content mt-2 col-2 
        <% if (!userPrivileges.admin && !userPrivileges.update) { %>
          disabled-link
        <% } %>"
        <% if (!userPrivileges.admin && !userPrivileges.update) { %>
          onclick="event.preventDefault();"<% } %> >
        <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
      </a>
    
      <a 
        id="delete-btn"
        href="#"
        role="button"
        data-bs-toggle="tooltip" title="Διαγραφή των στοιχείων του επιλεγμένου υποκαταστήματος"
        data-bs-placement="bottom" 
        data-tooltip-max-width="15vw"
        class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2 <% if (!userPrivileges.admin && !userPrivileges.delete) { %>
          disabled-link
        <% } %>"
        <% if (!userPrivileges.admin && !userPrivileges.delete) { %>
          onclick="event.preventDefault();"
        <% } %> >
        <i class="buttons-content bi bi-trash"></i> Διαγραφή
      </a>

      <a 
        href="/mainapp"
        role="button"
        class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2">
        <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
      </a>

      <% if (ypokatasthmata.length === 0) { %>
        <nav class="col-2" aria-label="Dashboard Pagination">
          <ul class="pagination pagination-sm justify-content-end mt-2">
            <li class="page-item disabled" style="cursor: not-allowed;">
              <i class="bi bi-chevron-bar-left"></i>
            </li>
            <li class="page-item disabled" style="cursor: not-allowed;">
              <i class="bi bi-chevron-left"></i>
            </li>
            <li class="page-item disabled" style="cursor: not-allowed;">
              <i class="bi bi-chevron-right"></i>
            </li>
            <li class="page-item disabled" style="cursor: not-allowed;">
              <i class="bi bi-chevron-bar-right"></i>
            </li>
          </ul>
        </nav>
      <% } else { %>
        <nav class="col-2" aria-label="Dashboard Pagination">
          <ul class="pagination pagination-sm justify-content-end mt-2">
            <% if (current == 1) { %>
              <li class="page-item disabled" style="cursor: not-allowed;">
                <a href="#" class="page-link"><i class="bi bi-chevron-bar-left" style="font-size: 0.5vw;"></i></a>
              </li>
              <li class="page-item disabled" style="cursor: not-allowed;">
                  <a href="#" class="page-link"><i class="bi bi-chevron-left" style="font-size: 0.5vw;"></i></a>
              </li>
            <% } else { %>
              <li class="page-item" style="cursor: pointer;">
                <a href="/companies/ypokatasthmata/?page=1" class="page-link"><i class="bi bi-chevron-bar-left" style="font-size: 0.5vw;"></i></a>
              </li>
              <li class="page-item" style="cursor: pointer;">
                <a href="/companies/ypokatasthmata/?page=<%= Number(current) - 1 %>" class="page-link"><i class="bi bi-chevron-left" style="font-size: 0.5vw;"></i></a>
              </li>
            <% } %> 
            <% var i = Number(current) > 2 ? Number(current) -1 : 1 %> 
            <% if (i !== 1) { %>
              <li class="page-item disabled" style="cursor: default;">
                <a href="#" class="page-link" style="font-size: 0.5vw;">...</a>
              </li>
            <% } %> 
            <% for( ; i <= (Number(current) + 2) && i <= pages; i++) { %> 
              <% if (i == current) { %>
                <li class="page-item" style="cursor: pointer;">
                  <a href="#" class="page-link pageItem" style="font-size: 0.5vw; padding-top: 8px; font-weight: 500;"><%= i %></a>
                </li>
              <% } else { %>
                <li class="page-item" style="font-size: 0.7vw; cursor: pointer;">
                  <a href="/companies/ypokatasthmata/?page=<%= i %>" class="page-link" style="font-size: 0.5vw; padding-top: 8px; font-weight: 500;"><%= i %></a>
                </li>
              <% } %> 
              <% if (i == Number(current) + 2 && i < pages) { %>
                <li class="page-item disabled" style="cursor: default;">
                  <a href="#" class="page-link" style="font-size: 0.5vw;">...</a>
                </li>
                <li class="page-item" style="cursor: pointer;">
                  <a href="/companies/ypokatasthmata/?page=<%= pages %>" class="page-link" style="font-size: 0.5vw; padding-top: 8px; font-weight: 500;"><%= pages %></a>
                </li>
              <% } %> 
            <% } %> 
            <% if (current == pages) { %>
              <li class="page-item disabled" style="cursor: not-allowed;">
                <a href="#" class="page-link"><i class="bi bi-chevron-right" style="font-size: 0.5vw;"></i></a>
              </li>
              <li class="page-item disabled" style="cursor: not-allowed;">
                <a href="#" class="page-link"><i class="bi bi-chevron-bar-right" style="font-size: 0.5vw;"></i></a>
              </li>
            <% } else { %>
              <li class="page-item" style="cursor: pointer;">
                <a href="/companies/ypokatasthmata/?page=<%= Number(current) + 1 %>" class="page-link"><i class="bi bi-chevron-right" style="font-size: 0.5vw;"></i></a>
              </li>
              <li class="page-item" style="font-size: 0.7vw; cursor: pointer;">
                <a href="/companies/ypokatasthmata/?page=<%= pages %>" class="page-link"><i class="bi bi-chevron-bar-right" style="font-size: 0.5vw;"></i
                ></a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>
    </div>
  </div>
</div>

<script src="/static/js/companies/ypokatasthmata/selectRowInTable.js"></script>
<script src="/static/js/common/sortTable.js"></script>
<!-- <script src="/static/js/common/changeUrl.js"></script> -->
