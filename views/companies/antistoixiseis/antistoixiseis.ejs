<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom bg-hero-cdn">

    <form
        name="Antistoixiseis"
        class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0"
        role="search"
        method="POST"
        action="/companies/antistoixiseis/search">

        <%- include('../../partials/_csrfField') %>

        <div class="input-group">
            <span><i class="bi bi-search bi-search-swing fsvw-1_3 fw600 cgreen"></i>&nbsp;</span>
            <input
                type="search"
                name="searchTerm"
                id="searchInput"
                class="form-control rounded-end-2 ms-auto fsvw-1_1 border-radius-10"
                placeholder="Αναζήτηση... ( πατείστε Enter )"
                aria-label="Search"/>
        </div>
    </form>
</div>

<div class="card d-flex flex-column z-depth-5 w-90 margin-left-percent-5 overflow-hidden">
    <div class="card-header p-0 height-rem-3_5">
        <label class="text-center w-100 headers-content mt-2">
        Διαχείριση Αντιστοιχίσεων Κ.Π.Κ.
        </label>
    </div>

    <div class="card-body p-0 overflow-auto flex-grow-1 height-vh-64 bg-white">
        <div>
            <table class="table table-striped table-bordered table-sm table-hover table-fixed mb-0" id="myTable">
                <!-- ίδιες στήλες για thead & tbody γιατί έχουμε ένα table -->
                <thead class="backgroundColor-brown font-size-rem-1_1 center-align">
                    <tr class="color-brown">
                        <th scope="col" class="color-brown col-0-5 text-center width-vw-4_67 sticky">
                        <i class="bi bi-chevron-expand fsvw-1_3"></i>
                        </th>
                        <th scope="col" class="col-1 text-center sticky">Κωδ.<i class="sort-icon bi"></i></th>
                        <th scope="col" class="col-10-55 sticky">Περιγραφή Κρατήσεων<i class="sort-icon bi"></i></th>
                    </tr>
                </thead>

                <tbody>
                    <% if (krathseis.length !== 0) { %>
                        <% krathseis.forEach(element => { %>
                            <tr data-id="<%= element._id %>" class="trigger-collapse">
                                <td class="col-0-5 text-center width-vw-4_67">
                                    <button class="btn btn-nesting fsvw-1_1" type="button" aria-expanded="false">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </td>

                                <td class="col-1 text-center fsvw-0_9"><%= element.kodikos %></td>
                                <td class="col-10-5 fsvw-0_9"><%= element.perigrafh %></td>
                            </tr>

                            <tr class="collapse-row">
                                <td class="col-12 p-0" colspan="3">
                                    <div class="collapse" id="antistoixiseis<%= element._id %>">
                                        <div class="card card-body fsvw-0_9 margin-bottom--0_1rem border-radius-7">
                                            <!-- Το JS θα φτιάξει τον nested table. -->
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer mt-auto cardFooter">
        <div class="d-inline-block d-flex cardFooter01">
            <div class="d-flex cardFooter02">
                <a 
                    id="add-btn"
                    href="#" 
                    role="button" 
                    data-scope="nested"
                    data-tooltip-max-width="15vw"
                    data-bs-toggle="tooltip" 
                    title="Προσθήκη νέας αντιστοίχισης Κ.Π.Κ." 
                    data-bs-placement="bottom"
                    class="btn btn-brown fsvw-0_8 rounded-4 mb-3 mt-2 mr-2 col-2-5 <%= (!userPrivileges.admin && !userPrivileges.create) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.admin || userPrivileges.create) ? '1' : '0' %>">
                    <i class="bi bi-plus-circle"></i> Προσθήκη
                </a>
                
                <a 
                    id="edit-btn"
                    href="#" 
                    role="button"
                    data-scope="nested"
                    data-tooltip-max-width="15vw"
                    data-bs-toggle="tooltip" title="Εμφάνιση - Διόρθωση των στοιχείων των  αντιστοιχίσεων Κ.Π.Κ." 
                    data-bs-placement="bottom" 
                    class="btn btn-brown rounded-4 mb-3 mt-2 mr-2 col-2-5 <%= (!userPrivileges.admin && !userPrivileges.update) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.admin || userPrivileges.update) ? '1' : '0' %>">
                    <i class="bi bi-pencil-square"></i> Συντήρηση
                </a>
                
                <a 
                    id="delete-btn"
                    href="#"
                    role="button"
                    data-scope="nested"
                    data-tooltip-max-width="15vw"
                    data-bs-toggle="tooltip" title="Διαγραφή των στοιχείων της επιλεγμένης αντιστοίχισης Κ.Π.Κ." 
                    data-bs-placement="bottom"
                    class="btn btn-brown rounded-4 mb-3 mt-2 mr-2 col-2-5 <%= (!userPrivileges.admin && !userPrivileges.delete) ? 'disabled-link' : '' %>"
                    data-allowed="<%= (userPrivileges.admin || userPrivileges.delete) ? '1' : '0' %>">
                    <i class="bi bi-trash"></i> Διαγραφή
                </a>
        
                <a 
                    href="/mainapp"
                    role="button"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                    data-tooltip-max-width="15vw"
                    title="Επιστροφή στην Αρχική Σελίδα της εφαρμογής"
                    class="btn btn-brown rounded-4 mb-3 mt-2 col-2-5">
                    <i class="bi bi-chevron-double-left"></i> Επιστροφή
                </a>
            </div>

            <div class="d-flex width-percent-15"></div>

            <!-- Pagination -->
            <nav class="col-2" aria-label="Dashboard Pagination">
                <ul class="pagination pagination-sm justify-content-end mt-2">
                    <% if (Number(current) === 1) { %>
                        <li class="page-item disabled">
                            <a href="#" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a>
                        </li>
                        <li class="page-item disabled">
                            <a href="#" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a>
                        </li>
                    <% } else { %>
                        <li class="page-item">
                            <a href="/companies/antistoixiseis/?page=1" class="page-link"><i class="bi bi-chevron-bar-left font-size-vw-0_5"></i></a>
                        </li>
                        <li class="page-item">
                            <a href="/companies/antistoixiseis/?page=<%= Number(current) - 1 %>" class="page-link"><i class="bi bi-chevron-left font-size-vw-0_5"></i></a>
                        </li>
                    <% } %>

                    <% var i = Number(current) > 2 ? Number(current) - 1 : 1; %>

                    <% if (i !== 1) { %>
                        <li class="page-item disabled">
                            <a href="#" class="page-link font-size-vw-0_5">...</a>
                        </li>
                    <% } %>

                    <% for (; i <= (Number(current) + 1) && i <= pages; i++) { %>
                        <% if (i === Number(current)) { %>
                            <li class="page-item is-current" aria-current="page">
                                <span class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></span>
                            </li>
                        <% } else { %>
                            <li class="page-item fsvw-0_7">
                                <a href="/companies/antistoixiseis/?page=<%= i %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= i %></a>
                            </li>
                        <% } %>

                        <% if (i === Number(current) + 1 && i < pages) { %>
                            <li class="page-item disabled">
                                <a href="#" class="page-link font-size-vw-0_5">...</a>
                            </li>
                            <li class="page-item">
                                <a href="/companies/antistoixiseis/?page=<%= pages %>" class="page-link font-size-vw-0_5 padding-top-px-8 fw500"><%= pages %></a>
                            </li>
                        <% } %>
                    <% } %>

                    <% if (Number(current) === Number(pages)) { %>
                        <li class="page-item disabled">
                            <a href="#" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a>
                        </li>
                        <li class="page-item disabled">
                            <a href="#" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a>
                        </li>
                    <% } else { %>
                        <li class="page-item">
                            <a href="/companies/antistoixiseis/?page=<%= Number(current) + 1 %>" class="page-link"><i class="bi bi-chevron-right font-size-vw-0_5"></i></a>
                        </li>
                        <li class="page-item fsvw-0_7">
                            <a href="/companies/antistoixiseis/?page=<%= pages %>" class="page-link"><i class="bi bi-chevron-bar-right font-size-vw-0_5"></i></a>
                        </li>
                    <% } %>
                </ul>
            </nav>
        </div>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>

<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>

<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getCompanyDescription<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getXrhsh<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getPeriod<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/getUser<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/blockInvalidClick<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/companies/antistoixiseis/nestingTables<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/companies/antistoixiseis/selectRowInTable<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/companies/antistoixiseis/selectRowsInNestedTable<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
<script nonce="<%= nonce %>" src="/static/<%= NODE_ENV === 'production' ? 'min.js' : 'js' %>/common/tooltipsForButtons<%= NODE_ENV === 'production' ? '.min' : '' %>.js"></script>
