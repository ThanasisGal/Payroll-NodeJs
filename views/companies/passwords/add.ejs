<div class="tadded-container">
  <div class="container-fluid">
    <div class="menu_Links">
      <ul>
        <li class="active" style="display: none;">Σταθερά Στοιχεία</li>
      </ul>
    </div>
    <!-- <hr style="margin-top: -2rem" /> -->

    <div class="sections">
      <section class="sel_1_section visible" data-section="Σταθερά Στοιχεία">
        <div class="container">
          <form class="formRadius">

            </br></br></br></br>

            <div class="card d-flex flex-column z-depth-5 w-97" style="margin-left: 1.5%;">

              <div class="card-header">
                <label class="text-center headers-content">
                  Εισαγωγή Νέου Κωδικού Πρόσβασης
                </label>
              </div>

              <div class="card-body overflow-auto flex-grow-1" style="height: 21vh; background-color: #ffffff;" >
                <input
                  type="hidden"
                  name="companyId"
                  id="companyId"
                  class="form-control"
                  value="<%= company._id %>"
                />
                <input
                  type="hidden"
                  name="companyKodikos"
                  id="companyKodikos"
                  class="form-control"
                  value="<%= company.kod %>"
                />
                <input
                  type="hidden"
                  name="companyTeam"
                  id="companyTeam"
                  class="form-control"
                  value="<%= company.team %>"
                />

                <div class="row form-group g-3 align-items-center">
                  <div class="col-1-5 right-align">
                    <label class="col-form-label label-font-size">
                      Επιλεγμένη Εταιρεία
                    </label>
                  </div>
                  <div
                    class="col-8 left-align"
                    style="font-size: 1rem; color: #1f6d00">
                    
                    <label class="col-form-label field-required">
                      <% if (company && company.kod && company.kod.length > 0) { %> 
                        <%- company.kod + "&nbsp;&nbsp;&nbsp; " + company.eponymia + " &nbsp;&nbsp;" + company.firstname %>
                      <% } %>
                    </label>
                  </div>
                </div>

                <hr class="division"></hr>

                <div class="row form-group g-3 align-items-center mb-1">
                  <div class="col-1-5 right-align">
                    <label
                      for="kodikos"
                      class="col-form-label label-font-size field-required">
                      Κωδικός
                    </label>
                  </div>
                  <div class="col-1">
                    <input
                      type="text"
                      name="Kodikos"
                      id="Kodikos"
                      class="form-control input-contents"
                      value=""
                      required
                      maxlength="4"
                      pattern="[0-9]{1,}"
                    />
                  </div>

                  <div class="col-4"></div>

                  <div class="col-1-5 right-align">
                    <label
                      for="perigrafh"
                      class="col-form-label label-font-size">
                        Περιγραφή
                    </label>
                  </div>
                  <div class="col-3">
                    <input
                      type="text"
                      name="perigrafh"
                      id="perigrafh"
                      class="form-control input-contents"
                      value=""
                      required
                    />
                  </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-1">
                  <div class="col-1-5 right-align">
                    <label
                      for="username"
                      class="col-form-label label-font-size">
                      Username
                    </label>
                  </div>
                  <div class="col-3">
                    <input
                      type="text"
                      name="username"
                      id="username"
                      class="form-control input-contents"
                      value=""
                      required
                    />
                  </div>

                  <div class="col-2"></div>

                  <div class="col-1-5 right-align">
                    <label
                      for="password"
                      class="col-form-label label-font-size">
                      Password
                    </label>
                  </div>
                  <div class="col-3">
                    <input
                      type="text"
                      name="password"
                      id="password"
                      class="form-control input-contents"
                      value=""
                      required
                    />
                  </div>
                </div>

              </div>
              <div
                class="card-footer mt-auto"
              >
                <div
                  class="d-inline-block d-flex"
                  style="
                    margin-top: -0.5rem !important;
                    margin-bottom: -1rem !important;
                    margin-left: 10px !important;
                    margin-right: 10px !important;
                    justify-content: space-around;
                  "
                >
                  <button
                    type="button"
                    class="btn btn-brown rounded-4 mt-2 w-20 buttons-content submitButton" 
                  >
                    <i class="bi bi-floppy"></i> Αποθήκευση
                  </button>
                  <a
                    class="btn btn-brown buttons-content rounded-4 mt-2 w-20"
                    href="/companies/passwords"
                    ><i class="bi bi-chevron-double-left"></i> Επιστροφή
                  </a>
                </div>
              </div>
            </div>
          </form>
        </div>
      </section>
    </div>

    <script src="/static/js/common/getCompanyDescription.js"></script>
    <script src="/static/js/companies/passwords/getFieldValues.js"></script>
    <script src="/static/js/common/checkAfm.js"></script>
    <script src="/static/js/common/navTabs.js"></script>
    <script src="/static/js/common/toggleLabel.js"></script>
    <script src="/static/js/dates/convertDateToISO.js"></script>
    <script src="/static/js/common/tooltipsForButtons.js"></script>
    <script src="/static/js/common/moveByEnter.js"></script>
    <!-- <script src="/static/js/common/changeUrl.js"></script> -->
  </div>
</div>
