<div id="payrollPhasesPanelShell" class="position-relative">
    <div id="payrollPhasesPanel" class="card border-info shadow-sm d-none mb-3" aria-live="polite">
        <div class="card-header bg-info text-white py-2 d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Μισθολογικές φάσεις περιόδου</span>
            <button
                type="button"
                id="payrollPhasesCloseBtn"
                class="payroll-phases-icon-btn payroll-phases-close-btn"
                title="Κλείσιμο"
                aria-label="Κλείσιμο μισθολογικών φάσεων"
            >
                <span aria-hidden="true">×</span>
                <span class="visually-hidden">Κλείσιμο μισθολογικών φάσεων</span>
            </button>
        </div>
        <div class="card-body py-2">
            <div id="payrollPhasesSummary" class="mb-2"></div>
            <div id="payrollPhasesList" class="mb-2"></div>
            <div id="payrollPhasesWarnings" class="mb-2"></div>
            <div id="payrollPhasesDiagnostics" class="small text-muted"></div>
        </div>
    </div>
</div>
