        <script nonce="<%= nonce %>">
            window.getCSRFToken = function () {
                const meta = document.querySelector('meta[name="csrf-token"]');
                if (meta) return meta.getAttribute('content');

                const input = document.querySelector('input[name="_csrf"]');
                if (input) return input.value;

                console.warn('⚠️ CSRF token not found!');
                return null;
            };
        </script>

        <!-- =========================================================
			APP LOADER API + Smooth Progress (FIXED)
			========================================================= -->
        <script nonce="<%= nonce %>">
            (function () {
                const el = () => document.getElementById('appLoader');
                const titleEl = () => document.getElementById('appLoaderTitle');
                const stepEl = () => document.getElementById('appLoaderStep');
                const fillEl = () => document.getElementById('appLoaderProgressFill');
                const textEl = () => document.getElementById('appLoaderProgressText');

                let rafId = null;
                let value = 0;
                let target = 0;
                let cap = 90;
                let startedAt = 0;
                let lastTs = 0;
                let suffixText = '';

                function buildMeta(percentNumber) {
                    const pct = Math.round(Math.max(0, Math.min(100, Number(percentNumber) || 0)));
                    return `${pct}%${suffixText ? ' • ' + suffixText : ''}`;
                }

                function setProgress(p) {
                    const clamped = Math.max(0, Math.min(100, Number(p) || 0));
                    const fill = fillEl();
                    const text = textEl();

                    if (fill) fill.style.width = clamped + '%';
                    if (text) text.textContent = buildMeta(clamped);
                }

                function startSmooth() {
                    stopSmooth();

                    value = 0;
                    target = 0;
                    cap = 90;

                    startedAt = performance.now();
                    lastTs = startedAt;

                    setProgress(0);

                    const SPEED_PER_SEC = 2.4;

                    const tick = (now) => {
                        const root = el();

                        if (!root || !root.classList.contains('is-visible')) {
                            rafId = null;
                            return;
                        }

                        const dt = Math.max(0, (now - lastTs) / 1000);
                        lastTs = now;

                        const elapsed = (now - startedAt) / 1000;
                        const dynamicCap = Math.min(95, cap + Math.floor(elapsed / 10) * 2);

                        const next = Math.max(
                            target,
                            Math.min(dynamicCap, value + SPEED_PER_SEC * dt)
                        );

                        if (next > value) {
                            value = next;
                            setProgress(value);
                        }

                        rafId = requestAnimationFrame(tick);
                    };

                    rafId = requestAnimationFrame(tick);
                }

                function stopSmooth() {
                    if (rafId) cancelAnimationFrame(rafId);
                    rafId = null;
                }

                window.showLoader = function (text) {
                    const root = el();
                    if (!root) return;

                    if (titleEl()) titleEl().textContent = 'Παρακαλώ περιμένετε...';

                    // ✅ Ενεργοποίηση overlay
                    const overlay = document.getElementById('contentDimOverlay');
                    if (overlay) overlay.classList.add('is-active');

                    root.classList.add('is-visible');
                    startSmooth();
                };

                window.hideLoader = function () {
                    const root = el();
                    if (!root) return;

                    stopSmooth();
                    root.classList.remove('is-visible');

                    // ✅ Απενεργοποίηση overlay
                    setTimeout(() => {
                        const overlay = document.getElementById('contentDimOverlay');
                        if (overlay) overlay.classList.remove('is-active');
                    }, 300);

                    value = 0;
                    target = 0;
                    cap = 90;
                    suffixText = '';

                    if (stepEl()) stepEl().textContent = '';
                    if (titleEl()) titleEl().textContent = 'Παρακαλώ περιμένετε...';
                    setProgress(0);
                };

                window.applyServerProgress = function (percent, message, step, totalSteps) {
                    const root = el();
                    if (root && !root.classList.contains('is-visible')) {
                        window.showLoader(message || 'Εκτελείται διαδικασία...');
                    }

                    const p = Math.max(0, Math.min(100, Number(percent) || 0));

                    if (titleEl()) titleEl().textContent = 'Παρακαλώ περιμένετε...';

                    const hasStep = Number(step) > 0 && Number(totalSteps) > 0;
                    // if (stepEl())
                    //     stepEl().textContent = hasStep ? `Βήμα ${step}/${totalSteps}` : '';
                    if (stepEl()) stepEl().textContent = hasStep && message ? String(message) : '';

                    if (hasStep && message) suffixText = `Βήμα ${step}/${totalSteps}: ${message}`;
                    else if (hasStep) suffixText = `Βήμα ${step}/${totalSteps}`;
                    else if (message) suffixText = String(message);
                    else suffixText = '';

                    if (fillEl()) fillEl().style.width = p + '%';

                    target = Math.max(target, p);
                    cap = Math.max(cap, Math.min(99, target));
                    value = Math.min(value, target);

                    setProgress(value);
                };

                window.finishProgressDone = function (message) {
                    window.applyServerProgress(100, message || 'Ολοκληρώθηκε', 0, 0);
                    setTimeout(() => window.hideLoader(), 600);
                };

                window.finishProgressError = function (message) {
                    const msg = message || 'Σφάλμα';
                    if (titleEl()) titleEl().textContent = `⚠️ ${msg}`;

                    suffixText = `⚠️ ${msg}`;
                    setProgress(value);

                    setTimeout(() => window.hideLoader(), 1500);
                };
            })();
        </script>

        <!-- =========================================================
			SOCKET.IO CLIENT SETUP
			========================================================= -->
        <script src="/socket.io/socket.io.js"></script>

        <script nonce="<%= nonce %>">
            (function () {
                'use strict';

                const hostname = window.location.hostname;
                const isDev =
                    hostname === 'localhost' ||
                    hostname === '127.0.0.1' ||
                    hostname.startsWith('192.168.');

                const socketUrl = isDev
                    ? `http://${hostname}:${window.location.port || 5000}`
                    : window.location.origin;

                window.socket = io(socketUrl, {
                    path: '/socket.io/',
                    transports: ['websocket', 'polling'],
                    reconnection: true,
                    reconnectionDelay: 1000,
                    reconnectionDelayMax: 5000,
                    reconnectionAttempts: 5,
                    timeout: 20000,
                    autoConnect: true
                });

                const socket = window.socket;

                socket.on('connect', function () {
                    const userId = '<%= locals.userId || "" %>';
                    if (userId && userId.trim() !== '') {
                        socket.emit('join', userId);
                    }
                });

                // EFKA progress events (percent + message + step/totalSteps)
                socket.on('efka:progress', function (data) {
                    console.log('PROGRESS FROM SERVER:', data);
                    window.applyServerProgress(
                        data?.percent,
                        data?.message,
                        data?.step,
                        data?.totalSteps
                    );
                });

                socket.on('efka:done', function (data) {
                    window.finishProgressDone(data?.message);
                });

                socket.on('efka:error', function (data) {
                    window.finishProgressError(data?.message);
                });

                // ERGANH progress events (percent + message + step/totalSteps)
                socket.on('erganh:progress', function (data) {
                    window.applyServerProgress(
                        data?.percent,
                        data?.message,
                        data?.step,
                        data?.totalSteps
                    );
                });

                socket.on('erganh:done', function (data) {
                    // ✅ Να εξαφανίζεται πριν από το Swal: θα το κάνει και το uploadToErganh(),
                    // αλλά το κρατάμε σαν safety net.
                    window.finishProgressDone(data?.message || 'Ολοκληρώθηκε');
                });

                socket.on('erganh:error', function (data) {
                    window.finishProgressError(data?.message || 'Σφάλμα');
                });
            })();
        </script>

        <script nonce="<%= nonce %>">
            (function () {
                const efkaRoot = () => document.getElementById('appLoader');
                const simpleRoot = () =>
                    document.querySelector('.app-loader--simple[data-loader="simple"]');

                function setSimpleText(text) {
                    const root = simpleRoot();
                    if (!root) return;

                    // ✅ title ΠΑΝΤΑ σταθερό
                    const title = root.querySelector('.app-loader__title');
                    if (title) title.textContent = 'Παρακαλώ περιμένετε...';

                    // ✅ meta αλλάζει ανά περίπτωση
                    const meta = root.querySelector('.app-loader__meta');
                    if (meta) meta.innerHTML = '&nbsp;' + (text || 'Εκτέλεση διαδικασίας...');
                }

                // Βρες τις συναρτήσεις showSimple και hideSimple

                function showSimple(text) {
                    const efka = efkaRoot();
                    if (efka && efka.classList.contains('is-visible')) return;

                    const root = simpleRoot();
                    if (!root) return;
                    setSimpleText(text);

                    root.classList.add('is-visible');
                }

                function hideSimple() {
                    const root = simpleRoot();
                    if (!root) return;
                    root.classList.remove('is-visible');
                }

                let pendingTimer = null;
                let activeCount = 0;
                let shownAt = 0;

                const DEFAULT_DELAY = 250; // anti-flicker: δείξε μόνο αν αργήσει > 250ms
                const MIN_VISIBLE = 200; // αν εμφανιστεί, κράτα το τουλάχιστον 200ms

                window.AppLoader = {
                    begin(text = 'Παρακαλώ περιμένετε...', delayMs = DEFAULT_DELAY) {
                        activeCount++;

                        const root = simpleRoot();
                        if (root && root.classList.contains('is-visible')) {
                            setSimpleText(text);
                            return;
                        }

                        if (pendingTimer) clearTimeout(pendingTimer);
                        pendingTimer = setTimeout(() => {
                            pendingTimer = null;
                            if (activeCount > 0) {
                                shownAt = Date.now();
                                showSimple(text);
                            }
                        }, delayMs);
                    },

                    end() {
                        activeCount = Math.max(0, activeCount - 1);

                        if (activeCount > 0) return;

                        if (pendingTimer) {
                            clearTimeout(pendingTimer);
                            pendingTimer = null;
                        }

                        const root = simpleRoot();
                        if (!root || !root.classList.contains('is-visible')) return;

                        const elapsed = Date.now() - shownAt;
                        const wait = Math.max(0, MIN_VISIBLE - elapsed);
                        setTimeout(() => hideSimple(), wait);
                    },

                    // helper για promises
                    wrap(promise, text, delayMs = DEFAULT_DELAY) {
                        this.begin(text, delayMs);
                        return Promise.resolve(promise).finally(() => this.end());
                    },

                    // manual (αν ποτέ το χρειαστώ)
                    show(text) {
                        shownAt = Date.now();
                        showSimple(text);
                    },
                    hide() {
                        activeCount = 0;
                        if (pendingTimer) clearTimeout(pendingTimer);
                        pendingTimer = null;
                        hideSimple();
                    }
                };

                // reset σε back/forward cache
                window.addEventListener('pageshow', () => window.AppLoader.hide());
            })();
        </script>

        <script nonce="<%= nonce %>">
            (function () {
                if (!window.fetch) return;

                const _fetch = window.fetch.bind(window);

                window.fetch = function (input, init) {
                    // opt-out: init?.skipLoader === true
                    if (init && init.skipLoader) return _fetch(input, init);

                    // προαιρετικά: δες URL για καλύτερο text
                    const url =
                        typeof input === 'string' ? input : input && input.url ? input.url : '';
                    const txt = 'Παρακαλώ περιμένετε...';

                    window.AppLoader.begin(txt, 200);

                    return _fetch(input, init).finally(() => window.AppLoader.end());
                };
            })();
        </script>

        <script nonce="<%= nonce %>">
            (function () {
                if (!window.XMLHttpRequest) return;

                const XHR = window.XMLHttpRequest;
                const _open = XHR.prototype.open;
                const _send = XHR.prototype.send;

                XHR.prototype.open = function (method, url) {
                    this.__loader_url = url;
                    return _open.apply(this, arguments);
                };

                XHR.prototype.send = function () {
                    // opt-out: set xhr.__skipLoader = true πριν το send (αν ποτέ χρειαστεί)
                    if (!this.__skipLoader) {
                        window.AppLoader.begin('Εκτέλεση διαδικασίας...', 250);

                        const done = () => {
                            this.removeEventListener('loadend', done);
                            this.removeEventListener('error', done);
                            this.removeEventListener('abort', done);
                            window.AppLoader.end();
                        };

                        this.addEventListener('loadend', done);
                        this.addEventListener('error', done);
                        this.addEventListener('abort', done);
                    }

                    return _send.apply(this, arguments);
                };
            })();
        </script>

        <script nonce="<%= nonce %>">
            (function () {
                // Links: μόνο same-tab navigations
                document.addEventListener(
                    'click',
                    function (e) {
                        const a = e.target.closest && e.target.closest('a[href]');
                        if (!a) return;

                        // ignore new tab / modifiers
                        if (a.target && a.target !== '_self') return;
                        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

                        const href = a.getAttribute('href') || '';
                        if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;

                        // same origin only
                        try {
                            const u = new URL(href, window.location.href);
                            if (u.origin !== window.location.origin) return;
                        } catch {
                            return;
                        }

                        // anti-flicker: αν γίνει γρήγορα, δεν θα προλάβει να δείξει
                        window.AppLoader.begin('Εκτέλεση διαδικασίας...', 250);
                        // δεν κάνουμε end — θα φύγει η σελίδα. Αν δεν φύγει, το pageshow reset το καθαρίζει.
                    },
                    true
                );

                // Full page submits
                document.addEventListener(
                    'submit',
                    function (e) {
                        const form = e.target;
                        if (!(form instanceof HTMLFormElement)) return;

                        if (form.hasAttribute('data-no-loader')) return;
                        if (form.target && form.target !== '' && form.target !== '_self') return;
                        if (form.checkValidity && !form.checkValidity()) return;

                        const msg =
                            form.getAttribute('data-loader-text') || 'Εκτέλεση διαδικασίας...';
                        window.AppLoader.begin(msg, 250);
                    },
                    true
                );
            })();
        </script>

        <script nonce="<%= nonce %>">
            (function () {
                'use strict';

                // ✅ Παρακολουθεί όλους τους loaders και προσθέτει class στο body
                const observeLoaders = () => {
                    const loaders = document.querySelectorAll('.app-loader');

                    const checkLoadersState = () => {
                        const anyVisible = Array.from(loaders).some((loader) =>
                            loader.classList.contains('is-visible')
                        );

                        if (anyVisible) {
                            document.body.classList.add('loader-active');
                        } else {
                            document.body.classList.remove('loader-active');
                        }
                    };

                    // MutationObserver για να παρακολουθεί αλλαγές στα classes
                    const observer = new MutationObserver(checkLoadersState);

                    loaders.forEach((loader) => {
                        observer.observe(loader, {
                            attributes: true,
                            attributeFilter: ['class']
                        });
                    });

                    // Initial check
                    checkLoadersState();
                };

                // Εκτέλεση όταν φορτώσει η σελίδα
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', observeLoaders);
                } else {
                    observeLoaders();
                }
            })();
        </script>
    </body>
</html>
