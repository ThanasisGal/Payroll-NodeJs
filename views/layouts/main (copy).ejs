<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title><%= locals.title %></title>
        <meta name="description" content="<%= locals.description %>" />
        <meta name="csrf-token" content="<%= csrfToken %>" />
        <meta name="app-root" content="/mainapp" />

        <script nonce="<%= nonce %>">
            (function () {
                const ua = navigator.userAgent;
                const htmlTag = document.documentElement;

                if (ua.indexOf('Firefox') > -1) htmlTag.classList.add('firefox');
                else if (ua.indexOf('Edg') > -1) htmlTag.classList.add('edge');
                else if (ua.indexOf('Chrome') > -1 && ua.indexOf('Edg') === -1)
                    htmlTag.classList.add('chrome');
                else if (ua.indexOf('Safari') > -1 && ua.indexOf('Chrome') === -1)
                    htmlTag.classList.add('safari');
            })();
        </script>

        <script src="<%= cdnUrl('own/vendor/decimal.min.js') %>"></script>

        <link href="<%= cdnUrl('css/bootstrap.min.css') %>" rel="stylesheet" />
        <link href="<%= cdnUrl('css/bootstrap-icons.cdn.css') %>" rel="stylesheet" />
        <link href="<%= cdnUrl('own/vendor/tom-select.css') %>" rel="stylesheet" />
        <link rel="icon" href="<%= cdnUrl('img/favicon.ico') %>" type="image/x-icon" />

        <!-- Preconnect για γρηγορότερο loading -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

        <link
            href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;600;700&display=swap"
            rel="stylesheet"
        />

        <link rel="stylesheet" href="<%= css('main') %>" />

        <link href="<%= cdnUrl('own/css/navTabs.css') %>" rel="stylesheet" />
    </head>

    <body
        data-mode="<%= typeof mode !== 'undefined' ? mode : '' %>"
        data-context="<%= typeof context !== 'undefined' ? context : '' %>"
        class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>"
    >
        <!-- APP LOADER (BEM) -->
        <div id="appLoader" class="app-loader">
            <div class="app-loader__box">
                <div class="app-loader__row">
                    <div class="app-loader__spinner"></div>

                    <div class="app-loader__textwrap">
                        <div id="appLoaderTitle" class="app-loader__title">
                            Παρακαλώ περιμένετε...
                        </div>
                        <div id="appLoaderStep" class="app-loader__step"></div>
                    </div>
                </div>

                <div class="app-progress">
                    <div id="appLoaderProgressFill" class="app-progress__fill"></div>
                </div>

                <div id="appLoaderProgressText" class="app-loader__meta">0%</div>
            </div>
        </div>

        <!-- APP LOADER (SIMPLE / GENERIC DELAYS) -->
        <div class="app-loader app-loader--simple" data-loader="simple">
            <div class="app-loader__box">
                <div class="app-loader__row">
                    <div class="app-loader__spinner"></div>

                    <div class="app-loader__textwrap">
                        <div class="app-loader__title">Παρακαλώ περιμένετε...</div>
                        <div class="app-loader__meta">Εκτέλεση διαδικασίας...</div>
                    </div>
                </div>
            </div>
        </div>

        <div id="contentDimOverlay" class="content-dim-overlay"></div>

        <%- include('../partials/header.ejs') %>

        <div class="container-fluid container-scroll">
            <div class="row">
                <%- include('../partials/sidebar.ejs') %>
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-transparent">
                    <%- body %>
                </main>
            </div>

            <%- include('../partials/footer.ejs') %>
        </div>

