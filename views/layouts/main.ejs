<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= locals.title %></title>
        <meta name="description" content="<%= locals.description %>" />
        <meta name="csrf-token" content="<%= csrfToken %>">
        <meta name="app-root" content="/mainapp">
        
        <!-- Επιτρέπεται από strict CSP μέσω nonce -->
        <script nonce="<%= nonce %>">
            (function() {
                let ua = navigator.userAgent;
                let htmlTag = document.documentElement;

                if (ua.indexOf("Firefox") > -1) {
                    htmlTag.classList.add("firefox");
                } else if (ua.indexOf("Edg") > -1) {
                    htmlTag.classList.add("edge");
                } else if (ua.indexOf("Chrome") > -1 && ua.indexOf("Edg") === -1) {
                    htmlTag.classList.add("chrome");
                } else if (ua.indexOf("Safari") > -1 && ua.indexOf("Chrome") === -1) {
                    htmlTag.classList.add("safari");
                }
            })();
        </script>

        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/decimal.min.js"></script>

        <!-- Προαιρετικά: preconnect για Google Fonts -->
        <!-- <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /> -->

        <link href="https://cdn.webpayrollsolutions.com/assets/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.webpayrollsolutions.com/assets/css/bootstrap-icons.cdn.css">
        <link rel="stylesheet" href="https://cdn.webpayrollsolutions.com/assets/own/vendor/tom-select.css" />
        <link rel="icon" href="https://cdn.webpayrollsolutions.com/assets/img/favicon.ico" type="image/x-icon" />
        <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;600;700&display=swap" rel="stylesheet">

        <!-- Το κύριο CSS -->
        <!-- <link rel="stylesheet" href="/static/css/main.css" /> -->
        <!-- <link rel="stylesheet" href="https://cdn.webpayrollsolutions.com/assets/own/css/main.css" /> -->
         <link rel="stylesheet" href="<%= css('main') %>">
        <link rel="stylesheet" href="https://cdn.webpayrollsolutions.com/assets/own/css/navTabs.css" />
    </head>

    <body
        data-mode="<%= typeof mode !== 'undefined' ? mode : '' %>"
        data-context="<%= typeof context !== 'undefined' ? context : '' %>"
        class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

        <div id="appLoader" class="loader-container">
            <div class="loader"></div>
            <div class="loader-text">Παρακαλώ περιμένετε...</div>
        </div>

        <%- include('../partials/header.ejs') %>
        <div class="container-fluid container-scroll">
            <div class="row">
                <%- include('../partials/sidebar.ejs') %>

                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-transparent"><%- body %></main>
            </div>

            <%- include('../partials/footer.ejs') %>
        </div>

        <% const isProduction = NODE_ENV === 'production'; %>
        <script nonce="<%= nonce %>">
            window.RUNTIME_ENV = "<%= NODE_ENV %>";
        </script>

        <script src="<%= script('common/logger') %>"></script>
        <script src="<%= script('utils/tree') %>"></script>
        <script src="<%= script('utils/miscProgs') %>"></script>
        <script src="<%= script('common/getCompanyDescription') %>"></script>
        <script src="<%= script('common/getXrhsh') %>"></script>
        <script src="<%= script('common/getPeriod') %>"></script>
        <script src="<%= script('common/getAppDate') %>"></script>
        <script src="<%= script('common/getUser') %>"></script>
        <script src="<%= script('common/navTabs') %>"></script>
        <script src="<%= script('common/getUserRole') %>"></script>
        <script src="<%= script('common/moveByEnter') %>"></script>
        <script src="<%= script('common/changeFontSizeSelectDropdownMenu') %>"></script>
        <script src="<%= script('common/tooltipsForButtons') %>"></script>
        <script src="<%= script('common/input_auto_select') %>"></script>
        <script src="<%= script('dates/convertDateToISO') %>"></script>
        
        <script nonce="<%= nonce %>">
            window.addEventListener("load", function () {
                const el = document.querySelector(".loader-container");
                if (!el) return;
                el.classList.remove("visible");
                el.classList.add("is-hidden");
                // προαιρετικά
                // el.style.setProperty('display','none','important');
            }, { once: true });
        </script>

        <!-- Εξωτερικά vendor scripts με nonce -->
        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/jquery.min.js"></script>
        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/tom-select.complete.js"></script>
        <script type="module" src="<%= script('app') %>"></script>
        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/select2.min.js"></script>
        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/sweetalert2.min.js"></script>
        <script src="https://cdn.webpayrollsolutions.com/assets/own/vendor/math.min.js"></script>
        <script src="<%= script('common/checkScreenAnalysis') %>" defer></script>
        <script src="<%= script('common/deviceSwitcher') %>" defer></script>

        <script nonce="<%= nonce %>">
            // 🔑 Global CSRF helper
            window.getCSRFToken = function() {
                // 1. Από meta tag
                const meta = document.querySelector('meta[name="csrf-token"]');
                if (meta) return meta.getAttribute('content');
                
                // 2. Από hidden input (fallback)
                const input = document.querySelector('input[name="_csrf"]');
                if (input) return input.value;
                
                console.warn('⚠️ CSRF token not found!');
                return null;
            };
        </script>

        <!-- ============================================================================
            SOCKET.IO CLIENT SETUP (Environment-Aware + CSP-Compliant)
            ============================================================================ -->

        <!-- ✅ Load Socket.io client library (external script - no nonce needed) -->
        <script src="/socket.io/socket.io.js"></script>

        <!-- ✅ Initialize Socket.io connection (inline script - REQUIRES nonce!) -->
        <script nonce="<%= nonce %>">
        (function() {
            'use strict';
            
            // ================================================================
            // ✅ DETECT ENVIRONMENT
            // ================================================================
            const hostname = window.location.hostname;
            const isDev = hostname === 'localhost' || 
                        hostname === '127.0.0.1' || 
                        hostname.startsWith('192.168.');
            
            // ================================================================
            // ✅ BUILD SOCKET.IO CONNECTION URL
            // ================================================================
            const socketUrl = isDev 
                ? `http://${hostname}:${window.location.port || 5000}`
                : window.location.origin;
            
            console.log('\n🔧 ════════════════════════════════════════════════════════');
            console.log('🔧 [SOCKET] Initializing Socket.io connection');
            console.log('🔧 ════════════════════════════════════════════════════════');
            console.log('   Environment:', isDev ? 'DEVELOPMENT' : 'PRODUCTION');
            console.log('   Server URL:', socketUrl);
            console.log('   Path:', '/socket.io/');
            console.log('🔧 ════════════════════════════════════════════════════════\n');
            
            // ================================================================
            // ✅ INITIALIZE SOCKET.IO (Global variable)
            // ================================================================
            window.socket = io(socketUrl, {
                path: '/socket.io/',
                transports: ['websocket', 'polling'],
                reconnection: true,
                reconnectionDelay: 1000,
                reconnectionDelayMax: 5000,
                reconnectionAttempts: 5,
                timeout: 20000,
                autoConnect: true
            });
            
            // ================================================================
            // ✅ CONNECTION SUCCESSFUL
            // ================================================================
            socket.on('connect', function() {
                console.log('\n✅ ════════════════════════════════════════════════════════');
                console.log('✅ [SOCKET] Connected to server');
                console.log('✅ ════════════════════════════════════════════════════════');
                console.log('   Socket ID:', socket.id);
                console.log('   Transport:', socket.io.engine.transport.name);
                console.log('   Connected:', socket.connected);
                console.log('✅ ════════════════════════════════════════════════════════\n');
                
                // ✅ Join user-specific room (if logged in)
                const userId = '<%= locals.userId || "" %>';
                if (userId && userId.trim() !== '') {
                    socket.emit('join', userId);
                    console.log('📡 [SOCKET] Joining user room:', userId);
                }
            });
            
            // ================================================================
            // ✅ JOINED ROOM CONFIRMATION
            // ================================================================
            socket.on('joined', function(data) {
                console.log('✅ [SOCKET] Joined room successfully:', data);
            });
            
            // ================================================================
            // ✅ DISCONNECTED
            // ================================================================
            socket.on('disconnect', function(reason) {
                console.log('\n❌ ════════════════════════════════════════════════════════');
                console.log('❌ [SOCKET] Disconnected from server');
                console.log('❌ ════════════════════════════════════════════════════════');
                console.log('   Reason:', reason);
                console.log('   Will reconnect:', socket.io.reconnection());
                console.log('❌ ════════════════════════════════════════════════════════\n');
            });
            
            // ================================================================
            // ✅ CONNECTION ERROR
            // ================================================================
            socket.on('connect_error', function(error) {
                console.error('\n❌ ════════════════════════════════════════════════════════');
                console.error('❌ [SOCKET] Connection error');
                console.error('❌ ════════════════════════════════════════════════════════');
                console.error('   Error:', error.message);
                console.error('   Type:', error.type);
                console.error('❌ ════════════════════════════════════════════════════════\n');
            });
            
            // ================================================================
            // ✅ RECONNECTION HANDLERS
            // ================================================================
            socket.on('reconnect', function(attemptNumber) {
                console.log('🔄 [SOCKET] Reconnected successfully after', attemptNumber, 'attempts');
            });
            
            socket.on('reconnect_attempt', function(attemptNumber) {
                console.log('🔄 [SOCKET] Reconnection attempt:', attemptNumber);
            });
            
            socket.on('reconnect_error', function(error) {
                console.error('❌ [SOCKET] Reconnection error:', error.message);
            });
            
            socket.on('reconnect_failed', function() {
                console.error('❌ [SOCKET] Reconnection failed (max attempts reached)');
            });
            
            // ================================================================
            // ✅ PONG HANDLER (for testing)
            // ================================================================
            socket.on('pong', function(data) {
                console.log('✅ [SOCKET] Pong received:', data);
            });
            
        })();
        </script>

        <script  nonce="<%= nonce %>">
            function showLoader(text) {
                const el = document.getElementById('appLoader');
                if (!el) return;

                const t = el.querySelector('.loader-text');
                if (t && text) t.textContent = text;

                el.classList.remove('is-hidden');
                el.classList.add('visible');

                el.style.display = 'flex';
            }

            function hideLoader() {
                const el = document.getElementById('appLoader');
                if (!el) return;

                el.classList.remove('visible');
                el.classList.add('is-hidden');

                el.style.display = 'none';
            }
        </script>

    </body>
</html>
