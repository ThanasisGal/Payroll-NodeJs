<div
  class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3 pb-2 mb-3 border-bottom"
>
  <h1 class="h4">
    Διόρθωση - Διαγραφή Στοιχείων Χρήστη : <%= users.lastName %> <%=
    users.firstName %>
  </h1>
</div>

<div class="col py-3">
  <div class="row">
    <div class="col">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item">
            <a href="/admin">Dashboard</a>
          </li>
          <li class="breadcrumb-item active">
            <%= users.firstName %> <%= users.lastName %>
          </li>
        </ol>
      </nav>
    </div>
    <div class="col text-end fw-lighter">
      <b style="font-style: italic; font-size: 11px"
        >Τελευταία Ενημέρωση : <%= new Date(users.updatedAt).toLocaleString()
        %></b>
      <b>Κωδ.Χρήστη :</b>
      <b style="font-weight: 500; color: blue"><%= users._id %></b>
    </div>
  </div>
</div>

<div class="card z-depth-5">
  <div class="card-body">
    <form id="editUserForm" action="/admin/edit/<%= users.id %>?_method=PUT" method="POST">
      <%- include('../partials/_csrfField') %>
      <div class="row form-group g-3 align-items-center mb-2">
        <div class="col-1-5 right-align">
          <label for="firstName" class="col-form-label field-required"
            >Όνομα</label
          >
        </div>
        <div class="col-4">
          <input
            type="text"
            name="firstName"
            id="firstName"
            class="form-control"
            value="<%= users.firstName %>"
            required
          />
        </div>

        <div class="col-1-5 right-align">
          <label for="lastName" class="col-form-label field-required"
            >Επώνυμο</label
          >
        </div>
        <div class="col-4">
          <input
            type="text"
            name="lastName"
            id="lastName"
            class="form-control"
            value="<%= users.lastName %>"
            required
          />
        </div>
      </div>

      <div class="row form-group g-3 align-items-center mb-2">
        <div class="col-1-5 right-align">
          <label for="email" class="col-form-label field-required">Email</label>
        </div>
        <div class="col-4">
          <input
            type="text"
            name="email"
            id="email"
            class="form-control"
            value="<%= users.email %>"
            required
          />
        </div>

        <div class="col-1-5 right-align">
          <label for="password" class="col-form-label field-required"
            >Password</label
          >
        </div>
        <div class="col-4">
          <input
            type="text"
            name="password"
            id="password"
            class="form-control"
            value="<%= users.password %>"
            required
          />
        </div>
      </div>

      <div class="row form-group g-3 align-items-center mb-2">
        <div class="col-1-5 right-align">
          <label for="tel" class="col-form-label">Τηλέφωνο</label>
        </div>
        <div class="col-4">
          <input
            type="text"
            name="tel"
            id="tel"
            class="form-control"
            value="<%= users.tel %>"
          />
        </div>

        <div class="col-1-5 right-align">
          <label for="team" class="col-form-label-sm field-required"
            >Ομάδα Εργασίας</label
          >
        </div>
        <div class="col-4">
          <input
            type="text"
            name="team"
            id="team"
            class="form-control"
            value="<%= users.team %>"
            style="outline: 4 !important"
            required
          />
        </div>
      </div>

      <div class="row form-group g-3 align-items-center mb-2">
        <div class="col-1-5 right-align">
          <label for="group" class="col-form-label field-required">Role</label>
        </div>

        <div class="col-4 user-radio-group">
          <% userRoleOptions.forEach((option) => { %>
            <div class="form-check form-check-inline user-radio-option">
              <input
                class="form-check-input"
                type="radio"
                name="radioRoles"
                id="role-<%= option.value %>"
                value="<%= option.value %>"
                <%= option.value === normalizedUserRole ? 'checked' : '' %>
                required
              />
              <label class="form-check-label" for="role-<%= option.value %>"><%= option.label %></label>
            </div>
          <% }) %>
        </div>

        <div class="col-1-5 right-align">
          <label for="group1" class="col-form-label field-required"
            >Status</label
          >
        </div>

        <% if (users.situation == 'A') { %>
        <div class="col-4 user-radio-group">
          <div class="form-check form-check-inline user-radio-option">
            <input
              class="form-check-input"
              type="radio"
              name="radioStatus"
              id="radioActive"
              value="A"
              checked
            />
            <label class="form-check-label" for="radioActive">Ενεργός</label>
          </div>
          <div class="form-check form-check-inline user-radio-option">
            <input
              class="form-check-input"
              type="radio"
              name="radioStatus"
              id="radioInactive"
              value="I"
            />
            <label class="form-check-label" for="radioInactive"
              >Ανενεργός</label
            >
          </div>
        </div>

        <% } %> <% if (users.situation == 'I') { %>
        <div class="col-4 user-radio-group">
          <div class="form-check form-check-inline user-radio-option">
            <input class="form-check-input" type="radio" name="radioStatus" id="radioActive" value="A" />
            <label class="form-check-label" for="radioActive">Ενεργός</label>
          </div>
          <div class="form-check form-check-inline user-radio-option">
            <input
              class="form-check-input"
              type="radio"
              name="radioStatus"
              id="radioInactive"
              value="I"
              checked
            />
            <label class="form-check-label" for="radioInactive"
              >Ανενεργός</label
            >
          </div>
        </div>
        <% } %>
      </div>

      <div class="row form-group g-3 align-items-center mb-4">
        <div class="col-1-5 right-align padding-right-10">
          <label for="details" class="col-form-label">Σημειώσεις</label>
        </div>
        <div class="col-9-5">
          <textarea
            class="form-control"
            name="details"
            id="details"
            cols="30"
            rows="5"
          ><%= users.details || '' %></textarea>
        </div>
      </div>

    </form>
  </div>
  <div class="card-footer user-admin-card-footer">
    <div class="user-admin-actions">
      <button type="submit" form="editUserForm" class="btn user-admin-action-btn user-admin-action-secondary mb-1 mt-2">
        <i class="bi bi-person-gear"></i> Ενημέρωση
      </button>
      <button
        type="button"
        class="btn user-admin-action-btn user-admin-action-danger mb-1 mt-2"
        data-bs-toggle="modal"
        id="deleteButton"
        data-bs-target="#deleteModal"
      >
        <i class="bi bi-person-x"></i> Διαγραφή
      </button>
      <a class="btn user-admin-action-btn user-admin-action-secondary mb-1 mt-2" href="/admin"
        ><i class="bi bi-table"></i> Επιστροφή</a
      >
    </div>
  </div>
</div>

<%- include('../partials/modalDelete.ejs') %>
