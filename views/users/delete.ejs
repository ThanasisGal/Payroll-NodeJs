<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <h1 class="h3">Διαγραφή Χρήστη</h1>
</div>

<div class="card z-depth-5">
  <div class="card-body text-center py-4">
    <p class="mb-2">
      Ο χρήστης <strong><%= users.lastName %> <%= users.firstName %></strong> θα διαγραφεί οριστικά.
    </p>
    <p class="mb-0">Είστε σίγουρος(η);</p>
  </div>
  <div class="card-footer user-admin-card-footer">
    <div class="user-admin-actions">
      <a href="/admin" class="btn user-admin-action-btn user-admin-action-secondary">
        Ακύρωση
      </a>
      <form action="/admin/edit/<%= users._id %>?_method=DELETE" method="POST" class="m-0">
        <%- include('../partials/_csrfField') %>
        <button type="submit" class="btn user-admin-action-btn user-admin-action-danger">
          Διαγραφή Χρήστη
        </button>
      </form>
    </div>
  </div>
</div>
