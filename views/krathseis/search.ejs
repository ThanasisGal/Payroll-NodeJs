<!-- <% var maxEntriesPerPage = entries; %>
<% var cardbodyHeight=totalRecs <= maxEntriesPerPage ? (totalRecs * 8): (maxEntriesPerPage * 8); %> 
 -->
<div
  class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-4 mt-3 pb-3 mb-4 border-bottom" style="background-image: url('https://cdn.webpayrollsolutions.com/assets/img/wps1.png'); background-repeat: no-repeat; background-position: 0% 50%;">
</div>

  <div class="card d-flex flex-column z-depth-5" style="width: 97%; margin-left: 1.5%; overflow-y: hidden; ">
    <div class="card-header p-0" style="height: 3.5rem !important;">
      <label class="text-center w-100 headers-content mt-2">
        <% if (sTerm && sTerm.length > 0) { %>
          Εμφάνιση Κρατήσεων ( με κριτήριο αναζήτησης "<%= sTerm %>" )
        <% } else { %>
          Εμφάνιση Κρατήσεων
        <% } %>
      </label>
    </div>
  <div>
    <table 
      class="table table-striped table-bordered table-sm table-hover mb-0" id="myTableHeader">
      <thead style="font-size: 0.9vw;">
        <tr>
          <th scope="col" class="color-brown col-0-5 text-center" style="width: 4.6665vw !important;"><i class="bi bi-chevron-expand" style="color: #004b00; font-size: 1.3vw !important;"></i></th>
          <th scope="col" class="color-brown col-1">Κωδ.</th>
          <th scope="col" class="color-brown col-10-55">Περιγραφή</th>
        </tr>
      </thead>
    </table>
  </div>
  
  <div class="card-body p-0 overflow-auto flex-grow-1" style="height: 58.5vh; background-color: #ffffff;">
    <% if (krathseisFilteredRecs && krathseisFilteredRecs.length> 0) { %>
      <table class="table table-striped table-bordered table-sm table-hover" id="myTable">
        <tbody>
          <% krathseisFilteredRecs.forEach(element => { %>
            <tr data-id="<%= element._id %>">
              <td class="col-0-5">
                <button class="btn btn-nesting text-center" style="font-size: 1vw !important; width: 4.16667vw !important;" type="button" data-bs-toggle="collapse" data-bs-target="#pososta<%= element._id %>" aria-expanded="false" aria-controls="pososta<%= element._id %>"><i class="bi bi-chevron-down"></i>
                </button>
              </td>
              <td class="col-1" style="padding-top: 10px;"><%- element.kodikos %></td>
              <td class="col-10-5" style="padding-top: 10px;"><%- element.perigrafh %></td>
            </tr>

            <tr>
              <td class="col-12" colspan="3">
                <div class="collapse" id="pososta<%= element._id %>">
                  <div class="card card-body" style="margin-bottom: 0.1rem !important; font-size: 0.9vw !important; border-radius: 0.4375rem !important;">
                    <!-- Το περιεχόμενο των PosostaKrathseon θα φορτωθεί εδώ δυναμικά -->
                  </div>
                </div>
              </td>
            </tr>
          <% }) %>

          <% if (krathseisFilteredRecs.length === 0) { %>
            <tr>
            <td colspan="3" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <% } %>
  </div>

  <div class="card-footer mt-auto">
    <div class="d-flex" style="margin: -0.5rem 0.625rem 2rem;">
      <div class="d-flex dropup" style="width: 60%; justify-content: space-around;">
        <div class="dropdown">
          <a class="btn btn-brown rounded-4 mb-3 buttons-content mt-2 col-2 dropdown-toggle <%= (!userPrivileges.privileges.admin && !userPrivileges.privileges.create) ? 'disabled' : '' %>"
            href="#" 
            role="button" 
            id="add-btn" 
            data-bs-toggle="<%= (!userPrivileges.privileges.admin && !userPrivileges.privileges.create) ? '' : 'dropdown' %>" 
            aria-expanded="false"
            style="width: 12vw;"
            data-bs-placement="top" 
            data-tooltip-max-width="15vw"
            title="Επιλογή προσθήκης νέας κρατήσης ή νέων ποσοστών κρατήσεων">
          <i class="buttons-content bi bi-plus-circle"></i> Εισαγωγή
          </a>
              
          <ul class="dropdown-menu custom-dropdown-menu" aria-labelledby="add-btn">
            <li><a class="dropdown-item" href="/krathseis/genika/add">Προσθήκη Κρατήσεων</a></li>
            <li><a class="dropdown-item" href="/krathseis/pososta/add">Προσθήκη Ποσοστών Κρατήσεων</a></li>
          </ul>
        </div>
            
        <a id="edit-btn"
          href="#" 
          role="button"
          data-bs-toggle="tooltip" title="Εμφάνιση - Διόρθωση των στοιχείων των κρατήσεων ή των ποσοστών των κρατήσεων ανάλογα με το τι θα επιλέξετε"
          data-tooltip-max-width="15vw"
          data-bs-placement="bottom" 
          class="btn btn-brown rounded-4 mb-3 buttons-content mt-2 col-2 <%= (!userPrivileges.privileges.admin && !userPrivileges.privileges.update) ? 'disabled' : '' %>">
          <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
        </a>
        
        <a id="delete-btn"
          href="#"
          role="button"
          data-bs-toggle="tooltip" title="Διαγραφή των στοιχείων  των κρατήσεων ή των ποσοστών των κρατήσεων ανάλογα με το τι θα επιλέξετε"
          data-bs-placement="bottom" 
          data-tooltip-max-width="15vw"
          class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2 <%= (!userPrivileges.privileges.admin && !userPrivileges.privileges.delete) ? 'disabled-link' : '' %>"
          <%= (!userPrivileges.privileges.admin && !userPrivileges.privileges.delete) ? 'onclick="event.preventDefault();"' : '' %> >
          <i class="buttons-content bi bi-trash"></i> Διαγραφή
        </a>

        <a 
          href="/krathseis/krathseis"
          role="button"
          class="btn btn-brown rounded-4 buttons-content mb-3 mt-2 col-2">
          <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
        </a>
      </div>

      <div class="d-flex" style="width: 15%;"></div>

      <!-- Pagination -->
      <div class="ms-auto" style="flex-grow: 1; max-width: 25%; font_size: 0.8vw !important">
        <nav aria-label="Page navigation">
          <ul class="pagination justify-content-end">
            <% if (Number(current) > 1) { %>
              <li class="page-item">
                <a class="page-link" href="/krathseis/search/?page=1" aria-label="First">
                  <i class="bi bi-chevron-bar-left"></i>
                </a>
              </li>
              <li class="page-item">
                <a class="page-link" href="/krathseis/search/?page=<%= Number(current) - 1 %>" aria-label="Previous">
                  <i class="bi bi-chevron-left"></i>
                </a>
              </li>
            <% } %>

            <!-- Number(current) Page -->
            <li class="page-item active"><a class="page-link" href="#"><%= Number(current) %></a></li>

            <!-- Dynamic "next pages" and "..." logic -->
            <% if (Number(current) < pages) { %>
              <% let upTo = Math.min(Number(current) + 2, pages); %>
              <% for(let i = Number(current) + 1; i <= upTo; i++) { %>
                <li class="page-item"><a class="page-link" href="/krathseis/search/?page=<%= i %>"><%= i %></a></li>
              <% } %>
              <% if (upTo < pages) { %>
                <li class="page-item disabled"><span class="page-link">...</span></li>
                <li class="page-item"><a class="page-link" href="/krathseis/search/?page=<%= pages %>"><%= pages %></a></li>
              <% } %>
            <% } %>

            <% if (Number(current) < pages) { %>
              <li class="page-item">
                <a class="page-link" href="/krathseis/search/?page=<%= Number(current) + 1 %>" aria-label="Next">
                  <i class="bi bi-chevron-right"></i>
                </a>
              </li>
              <li class="page-item">
                <a class="page-link" href="/krathseis/search/?page=<%= pages %>" aria-label="Last">
                  <i class="bi bi-chevron-bar-right"></i>
                </a>
              </li>
            <% } else { %>
              <li class="page-item disabled"><span class="page-link">
                <i class="bi bi-chevron-right"></i></span></li>
              <li class="page-item disabled"><span class="page-link">
                <i class="bi bi-chevron-bar-right"></i></span></li>
            <% } %>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</div>

<% if (process.env.NODE_ENV === 'production') { %>
  <script src="/static/min.js/krathseis/krathseis_ejs.min.js"></script>
<% } else { %>
  <script src="/static/js/common/getCompanyDescription.js"></script>
  <script src="/static/js/common/getXrhsh.js"></script>
  <script src="/static/js/common/getPeriod.js"></script>
  <script src="/static/js/common/getUser.js"></script>
  <script src="/static/js/common/adjustFontSizeToFit.js"></script>
  <script src="/static/js/krathseis/nestingTables.js"></script>
  <script src="/static/js/krathseis/selectRowInTable.js"></script>
  <script src="/static/js/krathseis/selectRowsInNestedTable.js"></script>
  <script src="/static/js/common/tooltipsForButtons.js"></script>
<% } %>
