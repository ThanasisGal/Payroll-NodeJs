<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom bg-hero-cdn">

  	<form
        name="Krathseis"
        class="nav col-12 col-md-auto flex-end mb-2 ms-auto mb-md-0"
        role="search"
        method="POST"
        action="/krathseis/search">

        <%- include('../partials/_csrfField') %>

        <div class="input-group">
            <span><i class="bi bi-search bi-search-swing fsvw-1_3 fw600 cgreen"></i>&nbsp;</span>
            <input
                type="search"
                name="searchTerm"
                id="searchInput"
                class="form-control rounded-end-2 ms-auto fsvw-1_1 border-radius-10 use-default-enter"
                placeholder="Αναζήτηση... ( πατείστε Enter )"
                autocomplete="off"
                aria-label="Search"/>
        </div>
    </form>
</div>

<div class="card d-flex flex-column z-depth-5 w-99 margin-left-0_5rem overflow-visible">
    <div class="card-header p-0 height-rem-3_5">
		<label class="text-center w-100 headers-content mt-2">
			Διαχείριση Κρατήσεων
		</label>
	</div>

    <div class="card-body p-0 flex-grow-1 bg-white">
		<div class="table-scroll-container">
             <table class="table table-striped table-bordered table-sm table-hover table-fixed mb-0" id="myTable">
				<thead class="backgroundColor-brown font-size-vw-0_875;">
					<tr>
						<th scope="col" class="color-brown col-0-5 text-center width-vw-4_67"><i class="bi bi-chevron-expand color004b00 fsvw-1_3"></i></th>
						<th scope="col" class="color-brown col-1">Κωδ.</th>
						<th scope="col" class="color-brown col-10-55">Περιγραφή</th>
					</tr>
				</thead>

				<tbody>
					<% if (krathseis.length !== 0) { %>
						<% krathseis.forEach(element => { %>
                            <tr data-id="<%= element._id %>" class="trigger-collapse">
                                <td class="col-0-5 text-center width-vw-4_67">
									<button
										class="btn btn-nesting fsvw-1_1"
										type="button"
										aria-expanded="false"
										data-bs-toggle="collapse"
										data-bs-target="#pososta<%= element._id %>">
										<i class="bi bi-chevron-down"></i>
                                    </button>
                                </td>
                                <td class="col-1 text-center fsvw-0_9"><%= element.kodikos %></td>
                                <td class="col-10-5 fsvw-0_9"><%= element.perigrafh %></td>
							</tr>

                            <tr class="collapse-row">
								<td class="col-12 p-0" colspan="3">
									<div class="collapse" id="pososta<%= element._id %>">
                                        <div class="card card-body fsvw-0_9 margin-bottom--0_1rem border-radius-7">
                                            <!-- Το JS θα φτιάξει τον nested table. -->
										</div>
									</div>
								</td>
							</tr>

						<% }) %>
					<% } else { %>
						<tr>
						<td colspan="3" class="records-not-found">Δεν βρέθηκαν εγγραφές.</td>
						</tr>
					<% } %>
				</tbody>
			</table>
		</div>
	</div>


    <%
        // Τιμές σελίδωσης & πολλαπλασιαστή
        const cur     = Math.max(1, Number(current || 1));
        const total   = Math.max(1, Number(pages   || 1));
        const perxVal = Math.min(5, Math.max(1, parseInt(perx, 10) || 1));

        // Αν κρατάς κι άλλα query params (π.χ. sTerm), βάλε τα εδώ:
        const qsParts = [];
        // if (typeof sTerm === 'string' && sTerm) qsParts.push('sTerm=' + encodeURIComponent(sTerm));

        const qsKeep  = qsParts.length ? '&' + qsParts.join('&') : '';

        // Βάση URL της τρέχουσας σελίδας (άλλαξέ το αν χρειάζεται)
        const base    = '/krathseis/Krathseis';

        // Helpers για href
        const href     = (p) => `${base}?page=${p}&perx=${perxVal}${qsKeep}`;
        const perxHref = (n) => `${base}?page=1&perx=${n}${qsKeep}`;

        // Περιοχή αριθμών που εμφανίζεις
        const start = Math.max(1, cur - 1);
        const end   = Math.min(total, cur + 1);
    %>

    <div class="card-footer d-flex align-items-center flex-nowrap gap-0_75rem nowrap overflow-x-auto">

        <!-- Αριστερά: Κουμπιά δράσεων -->
        <div class="d-flex align-items-center flex-nowrap gap-0_5rem">
			<div class="dropup">
				<button 
					class="btn btn-brown rounded-4 mb-3 buttons-content mt-3 dropdown-toggle <% if (!userPrivileges.admin && !userPrivileges.create) { %>disabled-link<% } %>" 
					type="button" 
					id="add-btn" 
					data-bs-toggle="dropdown"
					data-bs-display="static"
					data-bs-boundary="viewport"
					aria-expanded="false"
					data-bs-placement="top"
					data-tooltip-max-width="15vw"
					data-bs-title="Επιλογή προσθήκης νέας κράτησης ή νέων ποσοστών κρατήσεων"
					<% if (!userPrivileges.admin && !userPrivileges.create) { %>onclick="event.preventDefault();"<% } %>>
					<i class="buttons-content bi bi-plus-circle"></i>
					Εισαγωγή
				</button>

				<ul class="dropdown-menu custom-dropdown-menu" aria-labelledby="add-btn">
					<li><a class="dropdown-item" href="/krathseis/genika/add">Προσθήκη Κρατήσεων</a></li>
					<li><a class="dropdown-item" href="/krathseis/pososta/add">Προσθήκη Ποσοστών Κρατήσεων</a></li>
				</ul>
			</div>

            <a id="edit-btn" href="#"
            class="btn btn-brown rounded-4 buttons-content <%= (!userPrivileges.admin && !userPrivileges.update) ? 'disabled-link' : '' %>"
            data-allowed="<%= (userPrivileges.admin || userPrivileges.update) ? '1' : '0' %>">
            <i class="buttons-content bi bi-pencil-square"></i> Συντήρηση
            </a>

            <a id="delete-btn" href="#"
            class="btn btn-brown rounded-4 buttons-content <%= (!userPrivileges.admin && !userPrivileges.delete) ? 'disabled-link' : '' %>"
            data-allowed="<%= (userPrivileges.admin || userPrivileges.delete) ? '1' : '0' %>">
            <i class="buttons-content bi bi-trash"></i> Διαγραφή
            </a>

            <a href="/mainapp" class="btn btn-brown rounded-4 buttons-content" id="back-btn">
            <i class="buttons-content bi bi-chevron-double-left"></i> Επιστροφή
            </a>
        </div>

        <!-- ΑΜΕΣΩΣ μετά το “Επιστροφή”: Πολλαπλασιαστής -->
        <div class="d-flex align-items-center flex-nowrap gap-0_5rem ms-2" id="perx-block">
            <span class="small text-muted font-size-rem-0_72">Εγγραφές: <strong> <%= basePer %> </strong></span>
            <ul class="pagination pagination-sm mb-0 margin-top--0_5rem perx-pagination">
                <% [1,2,3,4,5].forEach(n => { %>
                    <li class="page-item <%= perxVal === n ? 'active' : '' %>">
                    <a class="page-link" href="<%= perxHref(n) %>" <%= perxVal === n ? 'aria-current="true"' : '' %>>×<%= n %></a>
                    </li>
                <% }) %>
            </ul>
            <label class="small text-muted text-center font-size-rem-0_72"><strong>= <%= entries %> </strong> / Σελίδα</label>
        </div>

        <!-- ΟΛΟΣ ο υπόλοιπος χώρος μπαίνει εδώ -->
        <div class="flex-grow-1"></div>

        <!-- Δεξιά: Pagination -->
        <nav aria-label="Πλοήγηση σελίδων">
            <ul class="pagination pagination-sm mb-0 margin-top--0_5rem">
                <!-- First / Prev -->
                <li class="page-item <%= cur === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= cur === 1 ? '#' : href(1) %>" aria-label="First"
                        <%= cur === 1 ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-bar-left"></i></a>
                </li>
                <li class="page-item <%= cur === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= cur === 1 ? '#' : href(cur - 1) %>" aria-label="Previous"
                        <%= cur === 1 ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-left"></i></a>
                </li>

                <!-- Ellipsis πριν -->
                <% if (start > 1) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                <% } %>

                <!-- Αριθμημένες -->
                <% for (let i = start; i <= end; i++) { %>
                    <li class="page-item <%= i === cur ? 'active' : '' %>" <%= i === cur ? 'aria-current="page"' : '' %>>
                        <% if (i === cur) { %>
                            <span class="page-link"><%= i %></span>
                        <% } else { %>
                            <a class="page-link" href="<%= href(i) %>"><%= i %></a>
                        <% } %>
                    </li>
                <% } %>

                <!-- Ellipsis μετά + τελευταία -->
                <% if (end < total) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                    <li class="page-item"><a class="page-link" href="<%= href(total) %>"><%= total %></a></li>
                <% } %>

                <!-- Next / Last -->
                <li class="page-item <%= cur === total ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= cur === total ? '#' : href(cur + 1) %>" aria-label="Next"
                        <%= cur === total ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item <%= cur === total ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= cur === total ? '#' : href(total) %>" aria-label="Last"
                            <%= cur === total ? 'tabindex="-1" aria-disabled="true"' : '' %>><i class="bi bi-chevron-bar-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<% const isProduction = NODE_ENV === 'production'; %>

<script nonce="<%= nonce %>">
    window.RUNTIME_ENV = "<%= NODE_ENV %>";
</script>

<script src="<%= script('common/blockInvalidClick') %>"></script>
<script src="<%= script('common/adjustFontSizeToFit') %>"></script>
<script src="<%= script('Krathseis/nestingTables') %>"></script>
<script src="<%= script('Krathseis/selectRowInTable') %>"></script>
<script src="<%= script('Krathseis/selectRowsInNestedTable') %>"></script>
<script src="<%= script('common/hideTooltips') %>"></script>