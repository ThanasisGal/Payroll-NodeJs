<div
    class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3-0 pb-2-0 mb-3 mt-2-5 border-bottom bg-hero-cdn">
</div>

<!-- ✅ FLASH MESSAGES (for success after redirect) -->
<%- include('../partials/flash') %>

<!-- ✅ DIRECT ERROR DISPLAY (for validation errors) -->
<% if (typeof error !== 'undefined' && error) { %>
  <div class="container w-50 mt-3">
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <strong><i class="bi bi-exclamation-triangle-fill"></i> Σφάλμα:</strong> <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  </div>
<% } %>

</br> </br>

<div class="container w-50">
	<form action="/register/userRegistration" method="POST">

		<%- include('../partials/_csrfField') %>

		<div class="card z-depth-5">
			<label class="card-header bg-header text-center"
				><h4>Εγγραφή Χρήστη</h4></label>

			<div class="card-body">
				<div class="col-9">
					<input type="hidden" name="tmpEmail" id="tmpEmail" class="form-control" value="" readonly />
				</div>

			
				<div class="row form-group g-3 align-items-center mt-2 mb-1">
					<div class="col-3 right-align">
						<label for="firstName" class="col-form-label field-required">Όνομα</label>
					</div>
					<div class="col-9">
						<input type="text" name="firstName" id="firstName" class="form-control" value="" required />
					</div>
				</div>

				<div class="row form-group g-3 align-items-center mb-1">
					<div class="col-3 right-align">
						<label for="lastName" class="col-form-label field-required">Επώνυμο</label>
					</div>
					<div class="col-9">
						<input type="text" name="lastName" id="lastName" class="form-control" value="" required />
					</div>
				</div>

				<div class="row form-group g-3 align-items-center mb-1">
					<div class="col-3 right-align">
						<label for="Email" class="col-form-label field-required">Email</label>
					</div>
					<div class="col-9">
						<input type="email" name="email" id="email" class="form-control" value="" readonly required />
					</div>
				</div>

				<div class="row form-group g-3 align-items-center mb-1">
					<div class="col-3 right-align">
						<label for="tel" class="col-form-label">Τηλέφωνο</label>
					</div>
					<div class="col-9">
						<input type="tel" name="tel" id="tel" class="form-control" value="" pattern="[0-9]{10}" data-bs-title="10ψήφιο τηλέφωνο (πχ 2101234567)" />
					</div>
				</div>

				<div class="row form-group g-3 align-items-center mb-1">
					<div class="col-3 right-align">
						<label for="team" class="col-form-label field-required">Ομάδα Εργασίας</label>
					</div>
					<div class="col-9">
						<input type="text" name="team" id="team" class="form-control" value="" maxlength="3" data-bs-title="Αν είστε supervisor ορίστε μία ομάδα εργασίας (μέχρι 3 χαρακτήρες), ενώ αν είστε απλός χρήστης πρέπει να απευθυνθείτε στον supervisor για να σας δηλώσει σε μια ομάδα εργασίας και να ορίσει τα δικαιώματά σας στην εφαρμογή" required />
					</div>
				</div>

				<div class="row form-group g-3 align-items-center mb-1">
					<div class="col-3 right-align">
						<label for="Password" class="col-form-label field-required" >Password</label>
					</div>
					<div class="col-9">
						<input type="password" name="password" id="password" class="form-control" minlength="8" value="" required aria-describedby="passwordHelpBlock" />
						<!-- ✅ PASSWORD REQUIREMENTS HINT -->
						<small id="passwordHelpBlock" class="form-text text-muted">
							<i class="bi bi-info-circle"></i>
							Το password πρέπει να περιέχει τουλάχιστον:  1 κεφαλαίο και 1 πεζό (Λατινικό Χαρακτήρα), 1 αριθμό και 1 ειδικό χαρακτήρα (@$!%*?&)
						</small>
					</div>
				</div>

				<div class="row form-group g-3 align-items-center mb-1">
					<div class="col-3 right-align">
						<label for="password_confirmation" class="col-form-label field-required" >Επιβεβαίωση Password</label>
					</div>
					<div class="col-9">
						<input type="password" name="password_confirmation" id="password_confirmation" class="form-control" minlength="8" value="" required />
					</div>
				</div>

				<div>
					<input type="hidden" name="privileges" id="privileges" class="form-control" value="V" />
				</div>

				<div>
					<input type="hidden" name="situation"id="situation"class="form-control"value="A" />
				</div>

				<div>
					<input type="hidden" name="details" id="details" class="form-control" value="" />
				</div>
				
				<div>
					<input type="hidden" name="isVerified" id="isVerified" class="form-control" value="false" />
				</div>

				<div>
					<input type="hidden" name="isAdmin" id="isAdmin" class="form-control" value="false" />
				</div>
			</div>

			<div class="card-footer cardFooter">
				<div class="d-inline-block d-flex cardFooter01">
					<button type="submit" class="btn btn-brown rounded-4 w-40 mb-1 mt-2"><i class="bi bi-person-plus"></i> Προσθήκη Χρήστη
					</button>
					<a class="btn btn-brown rounded-4 w-40 mb-1 mt-2" href="/login">
						<i class="bi bi-chevron-double-left"></i> Επιστροφή</a>
				</div>
			</div>
		</div>
	</form>
</div>

<script nonce="<%= nonce %>">
	window.addEventListener('DOMContentLoaded', (event) => {
		let url = new URL(document.location.href);
		let params = new URLSearchParams(url.search);
		let hex = params.get("mail");
		let mail = '';

		if (hex) {
		for (let i = 0; i < hex.length; i += 2) {
			mail += String.fromCharCode(parseInt(hex.substr(i, 2), 16));
		}
		document.getElementById("email").value = mail;
		document.getElementById("firstName").focus();
		}
	});
</script>