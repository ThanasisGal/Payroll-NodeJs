<div class="container w-40">
  <form action="/login/verify-email" method="POST">
    
    <div class="card z-depth-5">
      <label class="card-header bg-header text-center"
        ><h4>Επαλήθευση Email</h4></label
      >
      <div class="card-body">
        <div class="row form-group g-3 align-items-center mt-2 mb-5">
          <div class="col-2 left-align">
            <label for="email" class="col-form-label field-required"
              >e-mail</label
            >
          </div>
          <div class="col-10">
            <input
              type="text"
              name="email"
              id="email"
              class="form-control"
              required
            />
          </div>
        </div>

      </div>

      <div class="card-footer" style="margin-left: 0.1rem !important; margin-right: 0.1rem !important;">
        <div
          class="d-inline-block d-flex"
          style="
          margin-top: -0.5rem !important;
          margin-bottom: -1rem !important;
          margin-left: 10px !important;
          margin-right: 10px !important;
          justify-content: space-around;"
        >
          <button type="submit" class="btn btn-brown rounded-4 w-25 mb-1 mt-2"><i class="bi bi-send"></i> Αποστολή
          </button>
          <a class="btn btn-brown rounded-4 w-25 mb-1 mt-2" href="/"
            ><i class="bi bi-x-octagon"></i> Ακύρωση</a
          >
        </div>
      </div>
    </div>
  </form>
</div>
