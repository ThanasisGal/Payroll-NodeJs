
<div
    class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3-0 pb-2-0 mb-3 mt-2-5 border-bottom">
</div>
<%- include('../partials/flash') %>

</br></br>
<div class="container w-40">
    <form id="verifyForm" action="/login/verify-email" method="POST">
        <%- include('../partials/_csrfField') %>
    
        <div class="card z-depth-5">
            <label class="card-header bg-header text-center">
                <h4>Επαλήθευση Email</h4>
            </label>
      
            <div class="card-body">
                <div class="row form-group g-3 align-items-center mt-2 mb-5">
                    <div class="col-2 left-align">
                        <label for="email" class="col-form-label field-required">
                            e-mail
                        </label>
                    </div>
                    <div class="col-10">
                        <input
                            type="text"
                            name="email"
                            id="email"
                            class="form-control"
                            required
                        />
                    </div>
                </div>
            </div>

            <div class="card-footer cardFooter">
                <div class="d-inline-block d-flex cardFooter01">
                    <button type="submit" id="verifyBtn" class="btn btn-brown rounded-4 w-25 mb-1 mt-2"><i class="bi bi-send"></i> Αποστολή</button>
                    <a class="btn btn-brown rounded-4 w-25 mb-1 mt-2" href="/"><i class="bi bi-x-octagon"></i> Ακύρωση</a>
                </div>
            </div>
        </div>
    </form>
</div>

<script nonce="<%= nonce %>">
    (function () {
        const form = document.getElementById('verifyForm');
        const btn  = document.getElementById('verifyBtn');
        form.addEventListener('submit', function () {
        if (btn) { btn.disabled = true; btn.classList.add('disabled'); }
        });
    })();
</script>
