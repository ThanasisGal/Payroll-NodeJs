<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 mt-2 border-bottom bg-hero-cdn">
</div>

<%- include('../partials/flash') %>

<br><br>

<div class="container-fluid height-vh-90 pad-0">
    <form action="/login/reset_old_password/<%= uid %>/<%= token %>" method="POST" novalidate>
        <%- include('../partials/_csrfField') %>
        
        <div class="card d-flex flex-column z-depth-5 width-percent-60 margin-left-percent-20 overflow-visible">
            <!-- ✅ Διόρθωση:  Πρόσθεσα closing quote -->
            <div class="card-header p-2 height-rem-3_5">
                <label class="text-center w-100 headers-content sectionTitle">
                    Ορισμός νέου κωδικού πρόσβασης
                </label>
            </div>

            <!-- ✅ Διόρθωση: bg-white (όχι bg-whitw) -->
            <div class="card-body overflow-auto flex-grow-1 w-100 bg-white">
                <!-- ✅ Error alert -->
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger mb-3" role="alert">
                        <strong>Σφάλμα:</strong> <%= error %>
                    </div>
                <% } %>

                <!-- Password field -->
                <div class="row form-group g-3 align-items-center mt-2 mb-1">
                    <div class="col-4 right-align mt-n-0-5">
                        <label for="password" class="col-form-label label-font-size field-required">
                            Νέος κωδικός
                        </label>
                    </div>
                    <div class="col-6">
                        <input
                            type="password"
                            name="password"
                            id="password"
                            class="form-control"
                            required
                            minlength="8"
                            placeholder="Τουλάχιστον 8 χαρακτήρες"
                            <% if (typeof error === 'undefined' || !error) { %>autofocus<% } %>
                            aria-invalid="<%= error ? 'true' : 'false' %>"
                            aria-describedby="passwordHelp"
                        />
                        <small id="passwordHelp" class="form-text text-muted">
                            Ο κωδικός πρέπει να περιέχει:  κεφαλαία, πεζά, αριθμό και ειδικό χαρακτήρα (@$!%*?&)
                        </small>
                    </div>
                </div>

                <!-- Password confirmation field -->
                <div class="row form-group g-3 align-items-center">
                    <div class="col-4 right-align">
                        <label for="password2" class="col-form-label label-font-size field-required">
                            Επιβεβαίωση κωδικού
                        </label>
                    </div>
                    <div class="col-6">
                        <!-- ✅ Αφαίρεσα το value (security best practice) -->
                        <input
                            type="password"
                            name="password2"
                            id="password2"
                            class="form-control"
                            required
                            minlength="8"
                            placeholder="Επαναλάβετε τον κωδικό"
                        />
                    </div>
                </div>
                <br>
            </div>

            <!-- Footer -->
            <div class="card-footer margin-left--1rem margin-right--1rem">
                <div class="d-inline-block d-flex cardFooter01">
                    <button type="submit" class="btn btn-brown rounded-4 buttons-contents mt-2 w-20">
                        <i class="bi bi-floppy"></i> Αποθήκευση
                    </button>
                    <a class="btn btn-brown rounded-4 buttons-contents mt-2 w-20" href="/login">
                        <i class="bi bi-x-octagon"></i> Ακύρωση
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- ✅ Client-side validation -->
<% if (typeof nonce !== 'undefined' && nonce) { %>
    <script nonce="<%= nonce %>">
        (function() {
            'use strict';
            
            // ✅ Focus on password field when error exists
            window.addEventListener("DOMContentLoaded", function () {
                <% if (typeof error !== 'undefined' && error) { %>
                    var passwordField = document.getElementById("password");
                    if (passwordField) {
                        passwordField.focus();
                        passwordField.select();
                    }
                <% } %>
            });
            
            // ✅ Form validation
            var form = document.querySelector('form[action*="reset_old_password"]');
            if (form) {
                form.addEventListener('submit', function(e) {
                    var password = document.getElementById('password').value;
                    var password2 = document.getElementById('password2').value;
                    
                    // Check if passwords match
                    if (password !== password2) {
                        e.preventDefault();
                        alert('Οι κωδικοί δεν ταιριάζουν');
                        document.getElementById('password2').focus();
                        return false;
                    }
                    
                    // Check length
                    if (password.length < 8) {
                        e. preventDefault();
                        alert('Ο κωδικός πρέπει να έχει τουλάχιστον 8 χαρακτήρες');
                        document.getElementById('password').focus();
                        return false;
                    }
                    
                    // Check password strength (optional)
                    var regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])/;
                    if (!regex.test(password)) {
                        e. preventDefault();
                        alert('Ο κωδικός πρέπει να περιέχει:\n• Κεφαλαία γράμματα (A-Z)\n• Πεζά γράμματα (a-z)\n• Αριθμούς (0-9)\n• Ειδικούς χαρακτήρες (@$!%*?&)');
                        document.getElementById('password').focus();
                        return false;
                    }
                });
            }
        })();
    </script>
<% } %>