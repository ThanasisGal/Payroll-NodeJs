<div
    class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3-0 pb-2-0 mb-3 mt-2-5 border-bottom">
</div>

<%- include('../partials/flash') %>

</br></br>
<div class="container-fluid height-vh-90 pad-0">
    <form action="/login/reset_old_password/<%= uid %>/<%= token %>" method="POST" novalidate>

        <%- include('../partials/_csrfField') %>
        
        <div class="card d-flex flex-column z-depth-5 width-percent-60 margin-left-percent-20 overflow-visible">
            <div class="card-header p-2 height-rem-3_5>
                <label class="text-center w-100 headers-content sectionTitle">
                    Ορισμός νέου κωδικού πρόσβασης
                </label>
            </div>

            <div class="card-body overflow-auto flex-grow-1 w-100 bg-whitw">

                <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger mb-3" role="alert"><%= error %></div>
                <% } %>

                <div class="row form-group g-3 align-items-center mt-2 mb-1">
                    <div class="col-4 right-align mt-n-0-5">
                        <label for="password" class="col-form-label label-font-size field-required">Νέος κωδικός</label>
                    </div>
                    <div class="col-6">
                        <input
                            type="password"
                            name="password"
                            id="password"
                            class="form-control"
                            required
                            minlength="8"
                            placeholder="8 χαρακτήρες minimum"
                            <% if (!error) { %>autofocus<% } %>
                            aria-invalid="<%= error ? 'true' : 'false' %>"
                            aria-describedby="passwordHelp"
                        />
                        <!-- <small id="passwordHelp" class="form-text text-muted">Τουλάχιστον 8 χαρακτήρες.</small> -->
                    </div>
                </div>

                <div class="row form-group g-3 align-items-center">
                    <div class="col-4 right-align">
                        <label for="password2" class="col-form-label label-font-size field-required">Επιβεβαίωση κωδικού</label>
                    </div>
                    <div class="col-6">
                        <input
                            type="password"
                            name="password2"
                            id="password2"
                            class="form-control"
                            required
                            minlength="8"
                            placeholder="8 χαρακτήρες minimum"
                            value="<%= typeof values !== 'undefined' && values && values.password2 ? values.password2 : '' %>"
                        />
                    </div>
                </div>
                </br>
            </div>

            <div 
                class="card-footer margin-left--1rem margin-right--1rem">
                <div
                    class="d-inline-block d-flex cardFooter01">
                    <button
                        type="submit"
                        class="btn btn-brown rounded-4 buttons-contents mt-2 w-20">
                        <i class="bi bi-floppy"></i> Αποθήκευση
                    </button>
                    <a
                        class="btn btn-brown rounded-4 buttons-contents mt-2 w-20"
                        href="/">
                        <i class="bi bi-x-octagon"></i> Ακύρωση
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <script nonce="<%= nonce %>">
    // Όταν υπάρχει error από τον server, κάνε focus στο πεδίο password
    window.addEventListener("DOMContentLoaded", function () {
        var el = document.getElementById("password");
        if (el) el.focus();
    });
    </script>
<% } %>