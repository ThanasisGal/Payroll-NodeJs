<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 mt-2 border-bottom bg-hero-cdn">
</div>

<!-- ✅ FLASH MESSAGES -->
<%- include('../partials/flash') %>

<br><br>

<div class="container-fluid height-vh-90 pad-0">
    <form action="/login/reset_old_password/<%= uid %>/<%= token %>" method="POST" novalidate>
        <%- include('../partials/_csrfField') %>
        
        <div class="card d-flex flex-column z-depth-5 width-percent-60 margin-left-percent-20 overflow-visible">
            <div class="card-header p-2 height-rem-3_5">
                <label class="text-center w-100 headers-content sectionTitle">
                    Ορισμός νέου κωδικού πρόσβασης
                </label>
            </div>

            <div class="card-body overflow-auto flex-grow-1 w-100 bg-white">
                <!-- ✅ DIRECT ERROR DISPLAY (Server-side validation result) -->
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                        <strong><i class="bi bi-exclamation-triangle-fill"></i> Σφάλμα: </strong> <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <!-- Email Display -->
                <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-4 right-align">
                        <label for="email" class="col-form-label label-font-size">
                            Email
                        </label>
                    </div>
                    <div class="col-6">
                        <input 
                            type="email" 
                            id="email" 
                            class="form-control" 
                            value="<%= email %>" 
                            readonly 
                            tabindex="-1"
                        />
                    </div>
                </div>

                <!-- Password field -->
                <div class="row form-group g-3 align-items-center mt-2 mb-1">
                    <div class="col-4 right-align mt-n-0-5">
                        <label for="password" class="col-form-label label-font-size field-required">
                            Νέος κωδικός
                        </label>
                    </div>
                    <div class="col-6">
                        <input 
                            type="password" 
                            name="password" 
                            id="password" 
                            class="form-control" 
                            required 
                            minlength="8" 
                            placeholder="Τουλάχιστον 8 χαρακτήρες" 
                            autofocus
                            aria-invalid="<%= (typeof error !== 'undefined' && error) ? 'true' : 'false' %>" 
                            aria-describedby="passwordHelp" 
                        />
                        <!-- ✅ PASSWORD REQUIREMENTS HINT (updates in real-time) -->
                        <small id="passwordHelp" class="form-text text-muted">
                            <i class="bi bi-info-circle"></i>
                            Τουλάχιστον: 1 κεφαλαίο (A-Z), 1 πεζό (a-z), 1 αριθμό (0-9), 1 ειδικό (@$! %*?&)
                        </small>
                    </div>
                </div>

                <!-- Password confirmation field -->
                <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-4 right-align">
                        <label for="password2" class="col-form-label label-font-size field-required">
                            Επιβεβαίωση κωδικού
                        </label>
                    </div>
                    <div class="col-6">
                        <input 
                            type="password" 
                            name="password2" 
                            id="password2" 
                            class="form-control" 
                            required 
                            minlength="8" 
                            placeholder="Επαναλάβετε τον κωδικό" 
                        />
                        <!-- ✅ Match indicator -->
                        <small id="password2Help" class="form-text text-muted"></small>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="card-footer margin-left--1rem margin-right--1rem">
                <div class="d-inline-block d-flex cardFooter01">
                    <button type="submit" id="submitBtn" class="btn btn-brown rounded-4 buttons-contents mt-2 w-20">
                        <i class="bi bi-floppy"></i> Αποθήκευση
                    </button>
                    <a class="btn btn-brown rounded-4 buttons-contents mt-2 w-20" href="/login">
                        <i class="bi bi-x-octagon"></i> Ακύρωση
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- ✅ REAL-TIME UX FEEDBACK (NOT validation) -->
<% if (typeof nonce !== 'undefined' && nonce) { %>
    <script nonce="<%= nonce %>">
        (function() {
            'use strict';
            
            var passwordField = document.getElementById('password');
            var password2Field = document.getElementById('password2');
            var passwordHelp = document.getElementById('passwordHelp');
            var password2Help = document.getElementById('password2Help');
            var submitBtn = document.getElementById('submitBtn');
            
            // ✅ REAL-TIME PASSWORD STRENGTH INDICATOR (UX only, not validation)
            if (passwordField && passwordHelp) {
                passwordField.addEventListener('input', function() {
                    var value = this.value;
                    
                    if (value.length === 0) {
                        passwordHelp.innerHTML = '<i class="bi bi-info-circle"></i> Τουλάχιστον: 1 κεφαλαίο (A-Z), 1 πεζό (a-z), 1 αριθμό (0-9), 1 ειδικό (@$! %*?&)';
                        passwordHelp.className = 'form-text text-muted';
                        return;
                    }
                    
                    var feedback = [];
                    var hasLength = value.length >= 8;
                    var hasLower = /[a-z]/.test(value);
                    var hasUpper = /[A-Z]/.test(value);
                    var hasDigit = /\d/.test(value);
                    var hasSpecial = /[@$!%*?&]/. test(value);
                    
                    if (! hasLength) feedback.push('8+ χαρακτήρες');
                    if (!hasLower) feedback.push('πεζά (a-z)');
                    if (!hasUpper) feedback.push('κεφαλαία (A-Z)');
                    if (!hasDigit) feedback.push('αριθμό (0-9)');
                    if (!hasSpecial) feedback.push('ειδικό (@$!%*?&)');
                    
                    if (feedback.length === 0) {
                        passwordHelp. innerHTML = '<i class="bi bi-check-circle-fill"></i> Ισχυρός κωδικός!';
                        passwordHelp.className = 'form-text text-success';
                    } else {
                        passwordHelp.innerHTML = '<i class="bi bi-exclamation-circle"></i> Λείπει:  ' + feedback.join(', ');
                        passwordHelp. className = 'form-text text-warning';
                    }
                    
                    // Trigger password match check
                    if (password2Field. value) {
                        password2Field. dispatchEvent(new Event('input'));
                    }
                });
            }
            
            // ✅ REAL-TIME PASSWORD MATCH INDICATOR (UX only)
            if (password2Field && password2Help) {
                password2Field.addEventListener('input', function() {
                    var password = passwordField.value;
                    var password2 = this.value;
                    
                    if (password2. length === 0) {
                        password2Help.innerHTML = '';
                        password2Help.className = 'form-text text-muted';
                        return;
                    }
                    
                    if (password === password2) {
                        password2Help.innerHTML = '<i class="bi bi-check-circle-fill"></i> Οι κωδικοί ταιριάζουν';
                        password2Help.className = 'form-text text-success';
                    } else {
                        password2Help.innerHTML = '<i class="bi bi-x-circle-fill"></i> Οι κωδικοί δεν ταιριάζουν';
                        password2Help. className = 'form-text text-danger';
                    }
                });
            }
            
            // ✅ FOCUS MANAGEMENT (if server returned error)
            window.addEventListener('DOMContentLoaded', function() {
                <% if (typeof error !== 'undefined' && error) { %>
                    if (passwordField) {
                        passwordField.focus();
                        passwordField.select();
                    }
                <% } %>
            });
            
            // ✅ MINIMAL CLIENT-SIDE VALIDATION (only critical checks)
            // Server-side validation is AUTHORITATIVE
            var form = document.querySelector('form[action*="reset_old_password"]');
            if (form) {
                form.addEventListener('submit', function(e) {
                    var password = passwordField.value;
                    var password2 = password2Field.value;
                    
                    // ✅ Only check critical issues (empty, mismatch)
                    // Server will handle detailed strength validation
                    
                    if (! password || !password2) {
                        e.preventDefault();
                        passwordField.focus();
                        return false;
                    }
                    
                    if (password !== password2) {
                        e.preventDefault();
                        password2Field.focus();
                        password2Field.select();
                        return false;
                    }
                    
                    // ✅ Let server handle strength validation
                    // (Real-time indicators already gave user feedback)
                    return true;
                });
            }
        })();
    </script>
<% } %>