<div
    class="d-flex justify-content-between flex-wrap flex-md nowrap align-items-center pt-3-0 pb-2-0 mb-3 mt-2-5 border-bottom">
</div>

<%- include('../partials/flash') %>

</br></br>
<div class="container w-40">
    <form action="/login/change_password/changepassword" method="POST">

        <%- include('../partials/_csrfField') %>
        
        <div class="card z-depth-5">
            <label class="card-header bg-header text-center">
                <h4>Αλλαγή Password</h4>
            </label>

            <div class="card-body">
                <div class="row form-group g-3 align-items-center mt-2 mb-3">
                    <div class="col-4 left-align">
                        <label for="email" class="col-form-label field-required">
                            @Email
                        </label>
                    </div>
                    <div class="col-8">
                        <input
                            type="email"
                            name="email"
                            id="email"
                            class="form-control"
                            required 
                        />
                    </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-4 left-align">
                        <label for="old_password" class="col-form-label field-required">
                            Τρέχον Password
                        </label>
                    </div>
                    <div class="col-8">
                        <input
                            type="password"
                            name="old_password"
                            id="old_password"
                            class="form-control"
                            required
                        />
                    </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-4 left-align">
                        <label for="password" class="col-form-label field-required">
                            Νέο Password
                        </label>
                    </div>
                    <div class="col-8">
                        <input
                            type="password"
                            name="password"
                            id="password"
                            class="form-control"
                            minlength="8"
                            placeholder="8 χαρακτήρες minimum"
                            required
                        />
                    </div>
                </div>

                <div class="row form-group g-3 align-items-center mb-3">
                    <div class="col-4 left-align">
                        <label for="password_confirmation" class="col-form-label field-required">
                            Επιβεβαίωση Password
                        </label>
                    </div>
                    <div class="col-8">
                        <input
                            type="password"
                            name="password_confirmation"
                            id="password_confirmation"
                            class="form-control"
                            minlength="8"
                            placeholder="8 χαρακτήρες minimum"
                            required
                        />
                    </div>
                </div>
            </div>

            <div class="card-footer cardFooter"">
                <div
                    class="d-inline-block d-flex cardFooter01">
                    
                    <button type="submit" class="btn btn-brown rounded-4 w-25 mb-1 mt-2"><i class="bi bi-arrow-left-right"></i> Αλλαγή</button>
                    <a class="btn btn-brown rounded-4 w-25 mb-1 mt-2" href="/login"><i class="bi bi-x-octagon"></i> Ακύρωση</a>
                </div>
            </div>
        </div>
    </form>
</div>
