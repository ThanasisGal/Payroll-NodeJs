# ============================================================================
# Κλειδιά και διαπιστευτήρια
# ============================================================================
*.pem
.env
.env.*
.aws/
credentials.json

# ============================================================================
# Uploads - PDF Documents (exclude all uploaded files)
# ============================================================================
uploads/pdfs/**
!uploads/pdfs/.gitkeep

# Optional: Keep subdirectory structure with .gitkeep files
!uploads/pdfs/**/
!uploads/pdfs/**/.gitkeep

# Text Cache
public/txt-cache/

# Test files
server/utils/test-*.js

# ============================================================================
# Παραγόμενα αρχεία (generated files)
# ============================================================================
public/json/*.json
!public/json/.gitkeep

public/pdf/*.pdf
!public/pdf/.gitkeep

public/xlsx/*.xlsx
!public/xlsx/.gitkeep

public/xml/*.xml
!public/xml/.gitkeep

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
package-lock.json          # Προαιρετικό - αν χρησιμοποιείς npm
# yarn.lock                # Uncomment αν χρησιμοποιείς yarn

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# OS Files
# ============================================================================
. DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# IDE / Editor
# ============================================================================
. vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# Build / Dist
# ============================================================================
dist/
build/
.cache/

# ============================================================================
# Temporary Files
# ============================================================================
tmp/
temp/
*.tmp
# Minified/Obfuscated JavaScript (generated by deployment)
public/min.js/
*.min.js.map

uploads/s3-mock/contracts/
uploads/s3-mock/pdfs/
uploads/s3-mock/txt/
uploads/s3-mock/xlsx/**
uploads/s3-mock/xmls/
